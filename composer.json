{
  "name": "deheerhoreca/openmage",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.2 <=8.3",
    "adbario/php-dot-notation": "^3.3",
    "amnuts/opcache-gui": "^3.5",
    "aoepeople/aoe_blackholesession": "dev-dhh-fixes",
    "aoepeople/aoe_dbretry": "dev-master",
    "aoepeople/aoe_profiler": "dev-master",
    "aoepeople/aoe_templatehints": "^0.4.4",
    "aschroder/smtp_pro": "^2",
    "aydin-hassan/magento-core-composer-installer": "^2.1.0",
    "bower-asset/prototypejs": "^1.7",
    "bower-asset/scriptaculous-bower": "^1.9",
    "cmixin/business-day": "^1.18",
    "colinmollenhour/magento-redis-session": "dev-master as 3.2.0",
    "dekor/php-array-table": "^2.0",
    "fballiano/openmage-cssjs-versioning": "^0.3.0",
    "firegento/debug": "^1.5",
    "illuminate/support": "^10",
    "mathieuviossat/arraytotexttable": "^1.0",
    "michelf/php-markdown": "^2.0",
    "mikehaertl/php-shellcommand": "^1.7",
    "n98/magerun": "^1.97",
    "nesbot/carbon": "^2 || ^3",
    "npm-asset/glightbox": "^3.3",
    "npm-asset/jquery": "^3.7",
    "npm-asset/lite-youtube-embed": "^0.3.3",
    "oomphinc/composer-installers-extender": "^2.0",
    "openmage/magento-lts": "20.5.0",
    "paynl/magento-plugin": "dev-master",
    "rector/rector": "^1.1",
    "sabberworm/php-css-parser": "^8.5",
    "symfony/cache": "^6.4",
    "symfony/css-selector": "^6.4",
    "symfony/var-dumper": "^6.4"
  },
  "require-dev": {
    "ergebnis/composer-normalize": "^2.42"
  },
  "replace": {
    "symfony/polyfill-ctype": "*",
    "symfony/polyfill-mbstring": "*",
    "symfony/polyfill-php70": "*",
    "symfony/polyfill-php71": "*",
    "symfony/polyfill-php72": "*",
    "symfony/polyfill-php73": "*",
    "symfony/polyfill-php74": "*",
    "symfony/polyfill-php80": "*",
    "symfony/polyfill-php81": "*",
    "symfony/polyfill-php82": "*"
  },
  "suggest": {
    "aoepeople/aoe_blackholesession": "Skip creating a real session for bots",
    "aoepeople/aoe_jscsststamp": "Automatic Versioning of JS and CSS files",
    "aoepeople/aoe_scheduler": "Advanced cron scheduling management",
    "aschroder/smtp_pro": "Support for sending emails via SMTP",
    "avstudnitz/fast-simple-import": "Imports products and customers from arrays",
    "colinmollenhour/Perfect_Watermarks": "Replacement for OpenMage's GD2 image adapter with imagemagick",
    "colinmollenhour/cache-backend-redis": "Support for storing OpenMage's cache in Redis",
    "colinmollenhour/magento-redis-session": "Support for storing OpenMage' sessions in Redis",
    "fballiano/magento1-image-cleaner": "Identify and remove orphan images",
    "fballiano/openmage-lesti-fpc": "PHP bases Full Page Cache",
    "firegento/logger": "Advanced logging capabilities"
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/deheerhoreca/Aoe_BlackHoleSession",
      "only": [
        "aoepeople/aoe_blackholesession"
      ]
    },
    {
      "type": "vcs",
      "url": "https://github.com/deheerhoreca/Aoe_Profiler",
      "only": [
        "aoepeople/aoe_profiler"
      ]
    },
    {
      "type": "vcs",
      "url": "https://github.com/vianetz/aoe-scheduler-magento1",
      "only": [
        "aoepeople/aoe_scheduler"
      ]
    },
    {
      "type": "vcs",
      "url": "https://github.com/deheerhoreca/paynl-openmage",
      "only": [
        "paynl/magento-plugin"
      ]
    },
    {
      "type": "vcs",
      "url": "https://github.com/deheerhoreca/Cm_RedisSession"
    },
    {
      "type": "composer",
      "url": "https://packages.firegento.com",
      "only": [
        "firegento/debug"
      ]
    },
    {
      "type": "composer",
      "url": "https://asset-packagist.org",
      "only": [
        "npm-asset/*",
        "bower-asset/*"
      ]
    }
  ],
  "autoload": {
    "files": [
      "lib/Chefstore/Utils.php",
      "lib/Chefstore/Functions.php"
    ]
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "aydin-hassan/magento-core-composer-installer": true,
      "composer/installers": true,
      "cweagans/composer-patches": true,
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "ergebnis/composer-normalize": true,
      "magento-hackathon/magento-composer-installer": true,
      "oomphinc/composer-installers-extender": true
    },
    "apcu-autoloader": true,
    "classmap-authoritative": false,
    "magento-core-deploy": {
      "excludes": [
        ".htaccess",
        ".htaccess.sample",
        "README.md",
        "index.php.sample",
        "install.php",
        "php.ini.sample",
        "RELEASE_NOTES.txt",
        "app/etc/local.xml",
        "app/etc/local.xml.template",
        "CODE_OF_CONDUCT.md",
        "LICENSE.txt",
        "LICENSE_AFL.txt",
        "robots.txt.sample",
        ".all-contributorsrc"
      ]
    },
    "optimize-autoloader": true,
    "process-timeout": 3600,
    "sort-packages": true
  },
  "extra": {
    "auto-append-gitignore": false,
    "composer-exit-on-patch-failure": true,
    "enable-patching": true,
    "magento-core-package-type": "magento-source",
    "magento-root-dir": ".",
    "composer-normalize": {
      "indent-size": 2,
      "indent-style": "space"
    },
    "installer-paths": {
      "skin/assets/{$name}/": [
        "type:bower-asset",
        "type:npm-asset"
      ]
    },
    "installer-types": [
      "bower-asset",
      "npm-asset"
    ]
  },
  "scripts": {
    "sniffer:php80-all": "phpcs -p ./ --standard=vendor/phpcompatibility/php-compatibility/PHPCompatibility --runtime-set testVersion 8.0",
    "sniffer:php80-errors": "phpcs -n -p ./ --standard=vendor/phpcompatibility/php-compatibility/PHPCompatibility --runtime-set testVersion 8.0"
  }
}
