#!/usr/bin/env bash

: "───────────────────────────────────────────────────────────────────────────────────────────────────────────────
${HOME}/workspace/openmage/shell/om-compress-assets                                           # 10 sec
─────────────────────────────────────────────────────────────────────────────────────────────────────────────────"

export PREFER_HOST=prod
export NO_DEV=0

. ${HOME}/.profile || die "Failed to load ~/.profile"
cm || die "Failed to go to the openmage directory"
. ./shell/cron-bootstrap.sh || die "Failed to run ./shell/cron-bootstrap.sh"

set -euo pipefail
IFS=$'\n\t'

# Ensure the trailing slash exists for find
DIR="${HOME}/workspace/openmage/media/min"

if [[ ! -d "$DIR" ]]; then
  echo "Error: Directory $DIR does not exist."
  exit 1
fi

# Find all relevant assets
# Optimization: only process files that don't have a matching .br (or are newer than their .br)
find "$DIR" -type f \( -iname "*.css" -o -iname "*.js" -o -iname "*.json" -o -iname "*.svg" -o -iname "*.xml" \) | while read -r file; do
  
  # Skip if compressed version exists AND is NOT older than source (handles identical mtime)
  if [[ -f "${file}.br" && -f "${file}.gz" && ! "${file}.br" -ot "${file}" ]]; then
    continue
  fi
  
  echo "Compressing: ${file}"
  
  # Brotli (Level 11 is slow, but worth it for static assets)
  /home/linuxbrew/.linuxbrew/bin/brotli -q 11 --force -o "${file}.br" "${file}"
  
  # Zstd (Level 19)
  /home/linuxbrew/.linuxbrew/bin/zstd -19 -k -f "${file}" > /dev/null 2>&1
  
  # Gzip (Best)
  gzip --keep --best --force "${file}"
  
  # --- CRITICAL: Sync mtime ---
  # This tells Nginx the compressed file is up-to-date with the source
  touch -r "${file}" "${file}.br"
  touch -r "${file}" "${file}.gz"
  touch -r "${file}" "${file}.zst"
done
echo "Compression complete and mtimes synchronized."

# Remove minified CSS/JS files that are over 14 days old
cm || die "Failed to go to the openmage directory"
if [ -d "media/min" ]; then
  find media/min -type f \( -name '*.js' -o -name '*.css' -o -name '*.br' \) -mtime +14 -print -exec rm -f {} \;
  touch media/min/CACHEDIR.TAG
  echo "Trimmed minified CSS/JS files in media/min/ (removed files older than 14 days)"
else
  echo "Directory media/min does not exist, skipping trimming of minified files"
fi

# Wrap up
cm || die "Failed to go to the openmage directory"
. ./shell/cron-wrapup.sh
