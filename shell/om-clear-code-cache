#!/bin/bash

: '---------------------------------------------------------------------------------------------------------------
${HOME}/workspace/openmage/shell/om-clear-code-cache                                          # 5 sec
Clear various caches to ensure code changes are picked up.
- Sequence: First use safe bash commands to clear FS paths, only then use cachetool.
- The cachetool commands will fail harmlessly except on the production server, but we need the
  other commands to succeed on all hosts.
------------------------------------------------------------------------------------------------------------------'

set -u # Treat unset variables as an error when substituting

. ${HOME}/.profile || die "Failed to load ~/.profile"
cm || die "Failed to go to the openmage directory"
. ./shell/cron-bootstrap.sh || die "Failed to run ./shell/cron-bootstrap.sh"

# Clear PHP opcache stored in shared memory
if [ -d /dev/shm/openmage-php-opcache ]; then
  rm -rf /dev/shm/openmage-php-opcache/* && touch /dev/shm/openmage-php-opcache/CACHEDIR.TAG
  log_line "Cleared PHP opcache in /dev/shm/openmage-php-opcache/" "INFO"
else
  log_line "Skipped PHP opcache clear: /dev/shm/openmage-php-opcache/ does not exist" "INFO"
fi

# Clear Magento/OpenMage caches
n98-magerun.phar cache:clean
log_line "Cleared OpenMage caches" "INFO"

# Clear APCu and Opcache via cachetool
ELASTIC_APM_ENABLED=false cachetool --config=.cachetool.yaml apcu:cache:clear
ELASTIC_APM_ENABLED=false cachetool --config=.cachetool.yaml opcache:reset
ELASTIC_APM_ENABLED=false cachetool --config=.cachetool-cli.yaml opcache:reset
log_line "Cleared APCu and Opcache caches via cachetool" "INFO"

# Wrap up
cm || die "Failed to go to the openmage directory"
. ./shell/cron-wrapup.sh
