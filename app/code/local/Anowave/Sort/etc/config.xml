<?xml version="1.0"?>
<config>
    <modules>
        <Anowave_Sort>
            <version>0.0.0.1</version>
        </Anowave_Sort>
    </modules>
    <global>
    	<models>
		    <sort>
		        <class>Anowave_Sort_Model</class>
		        <resourceModel>sort_resource</resourceModel>
		    </sort>
		    <sort_resource>
                <class>Anowave_Sort_Model_Resource</class>
                <entities>
	                <coupon>
	                    <table>anowave_birthday_coupon</table>
	                </coupon>
	            </entities>
            </sort_resource>
		</models>
		<blocks>
			<sort>
                <class>Anowave_Sort_Block</class>
            </sort>
            <adminhtml>
            	<rewrite>
            		<catalog_category_tab_product>Anowave_Sort_Block_Catalog_Category_Tab_Product</catalog_category_tab_product>
            	</rewrite>
            </adminhtml>
		</blocks>
		<helpers>
	        <sort>
	            <class>Anowave_Sort_Helper</class>
	        </sort>
	    </helpers>
		<resources>
		    <anowave_sort_setup>
		        <setup>
		            <module>Anowave_Sort</module>
		        </setup>
		    </anowave_sort_setup>
		    <anowave_sort_write>
				<connection>
					<use>core_write</use>
				</connection>
			</anowave_sort_write>
			<anowave_sort_read>
				<connection>
					<use>core_read</use>
				</connection>
			</anowave_sort_read>
		</resources>
		<events>
			<core_block_abstract_to_html_after>
                <observers>
                    <modify>
                        <class>Anowave_Sort_Model_Observer</class>
                        <method>modify</method>
                    </modify>
                </observers>
            </core_block_abstract_to_html_after>
            <admin_system_config_changed_section_sort>
            	<observers>
                    <config>
                        <type>singleton</type>
                        <class>sort/config</class>
                        <method>notify</method>
                    </config>
                </observers>
            </admin_system_config_changed_section_sort>
		</events>
    </global>
    <admin>
        <routers>
            <adminhtml>
                <args>
                    <modules>
                        <anowave_sort after="Mage_Adminhtml">Anowave_Sort</anowave_sort>
                    </modules>
                </args>
            </adminhtml>
        </routers>
    </admin>
    <adminhtml>
    	<layout>
            <updates>
                <anowave_sort module="Anowave_Sort">
                    <file>sort.xml</file>
                </anowave_sort>
            </updates>
        </layout>
        <acl>
            <resources>
            	<all>
					<title>Allow Everything</title>
				</all>
                <admin>
                    <children>
                        <system>
                            <children>
                                <config>
                                    <children>
                                		<sort>
											<title>Drag and Drop Sorting</title>
										</sort>
                                    </children>
                                </config>
                            </children>
                        </system>
                    </children>
                </admin>
            </resources>
        </acl>
    </adminhtml>
    <default>
    	<view>
    		<config>
	   			<select>20</select>
	   		</config>
    	</view>
    </default>
</config>
