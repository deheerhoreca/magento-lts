<?xml version="1.0"?>
<config>
    <modules>
        <DeHeerHoreca_Fpc>
            <version>0.1.0</version>
        </DeHeerHoreca_Fpc>
    </modules>
    <global>
        <helpers>
            <deheerhoreca_fpc>
                <class>DeHeerHoreca_Fpc_Helper</class>
            </deheerhoreca_fpc>
        </helpers>
        <models>
            <deheerhoreca_fpc>
                <class>DeHeerHoreca_Fpc_Model</class>
            </deheerhoreca_fpc>
        </models>
    </global>
    <frontend>
        <routers>
            <deheerhoreca_fpc>
                <use>standard</use>
                <args>
                    <module>DeHeerHoreca_Fpc</module>
                    <frontName>deheerhorecafpc</frontName>
                </args>
            </deheerhoreca_fpc>
        </routers>
        <events>
            <!-- Serve cached HTML as early as possible, but late enough to have all necessary state in place -->
            <controller_action_predispatch>
                <observers>
                    <DeHeerHoreca_Fpc_Model_Observer>
                        <type>singleton</type>
                        <class>deheerhoreca_fpc/observer</class>
                        <method>ServeCachedHTML</method>
                    </DeHeerHoreca_Fpc_Model_Observer>
                </observers>
            </controller_action_predispatch>
            
            <!-- Opportunity to modify layout before it is loaded -->
            <controller_action_layout_load_before>
                <observers>
                    <customer_is_logged_in_observer>
                        <type>singleton</type>
                        <class>deheerhoreca_fpc/observer</class>
                        <method>removePerItemLayoutHandleInCache</method>
                    </customer_is_logged_in_observer>
                </observers>
            </controller_action_layout_load_before>
            
            <!-- Collect all loaded cache tags to associate with page -->
            <model_load_after>
                <observers>
                    <fpc_extra_cache_tags>
                        <type>singleton</type>
                        <class>deheerhoreca_fpc/observer</class>
                        <method>modelLoadAfter</method>
                    </fpc_extra_cache_tags>
                </observers>
            </model_load_after>
            
            <!-- Send HTTP headers before response is sent -->
            <http_response_send_before>
                <observers>
                    <diehard>
                        <type>singleton</type>
                        <class>deheerhoreca_fpc/observer</class>
                        <method>httpResponseSendBefore</method>
                    </diehard>
                </observers>
            </http_response_send_before>
        </events>
    </frontend>
    <adminhtml>
        <layout>
            <updates>
                <deheerhoreca_fpc>
                    <file>deheerhoreca_fpc/deheerhoreca_fpc.xml</file>
                </deheerhoreca_fpc>
            </updates>
        </layout>
        <events>
            <!-- Maybe also necessary: -->
            <!-- <catalog_product_stock_item_mass_change> -->
            <!-- <catalog_product_to_website_change> -->
            <catalog_product_attribute_update_after>
                <observers>
                    <DeHeerHoreca_Fpc_Model_Observer>
                        <type>singleton</type>
                        <class>deheerhoreca_fpc/observer</class>
                        <method>clearProductsCache</method>
                    </DeHeerHoreca_Fpc_Model_Observer>
                </observers>
            </catalog_product_attribute_update_after>
            <catalog_product_save_commit_after>
                <observers>
                    <DeHeerHoreca_Fpc_Model_Observer>
                        <type>singleton</type>
                        <class>deheerhoreca_fpc/observer</class>
                        <method>clearProductCache</method>
                    </DeHeerHoreca_Fpc_Model_Observer>
                </observers>
            </catalog_product_save_commit_after>
            <catalog_category_save_commit_after>
                <observers>
                    <DeHeerHoreca_Fpc_Model_Observer>
                        <type>singleton</type>
                        <class>deheerhoreca_fpc/observer</class>
                        <method>clearCategoryCache</method>
                    </DeHeerHoreca_Fpc_Model_Observer>
                </observers>
            </catalog_category_save_commit_after>
        </events>
    </adminhtml>
</config>
