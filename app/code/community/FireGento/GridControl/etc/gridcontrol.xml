<?xml version="1.0"?>

<!---
- Use <filter>0</filter>, not true/false
-->

<gridcontrol>
  <grids>
    
    <!-- Products Grid -->
    
    <productGrid>

      <set_name>
        <remove/>
      </set_name>

      <!-- To enable, also enable addWebsiteNamesToResult() -->
      <!-- app/code/local/DeHeerHoreca/Util/Adminhtml/Block/Catalog/Product/Grid.php -->
      <websites>
        <remove/>
      </websites>
      
      <entity_id>
        <!-- <remove/> -->
        <updateColumn>
          <width>5%</width>
        </updateColumn>
      </entity_id>
      
      <sku>
        <updateColumn>
          <header>SKU</header>
          <width>8%</width>
        </updateColumn>
      </sku>
      
      <name>
        <updateColumn>
          <width>30%</width>
        </updateColumn>
        <after>sku</after>
      </name>
      
      <type>
        <updateColumn>
          <width>100</width>
        </updateColumn>
        <after>name</after>
      </type>
      
      <visibility>
        <!-- <remove/> -->
      </visibility>
      
      <!-- <action> -->
        <!-- <remove/> -->
      <!-- </action> -->

      <eol>
        <add>
          <header>EOL</header>
          <size>5</size>
          <type>options</type>
          <index>eol</index>
          <options>firegento_gridcontrol/utility::getDropdownAttributeLabelOptionArray(eol)</options>
        </add>
        <after>status</after>
      </eol>

      <manufacturer>
        <add>
          <header>Merk</header>
          <size>5</size>
          <type>options</type>
          <index>manufacturer</index>
          <options>firegento_gridcontrol/utility::getDropdownAttributeLabelOptionArray(manufacturer)</options>
        </add>
        <after>eol</after>
      </manufacturer>
      
      <!-- <supplier> -->
        <!-- <add> -->
          <!-- <header>Leverancier</header> -->
          <!-- <type>options</type> -->
          <!-- <index>supplier</index> -->
          <!-- <options>firegento_gridcontrol/utility::getDropdownAttributeLabelOptionArray(supplier)</options> -->
        <!-- </add> -->
        <!-- <after>manufacturer</after> -->
      <!-- </supplier> -->
      
      <ean>
        <add>
          <header>EAN</header>
          <size>10</size>
          <type>text</type>
          <index>ean</index>
        </add>
        <after>manufacturer</after>
      </ean>
      
      <!-- To enable, also enable code block in -->
      <!-- app/code/local/DeHeerHoreca/Util/Adminhtml/Block/Catalog/Product/Grid.php -->
      <qty>
        <remove/>
      </qty>
      
      <product_type>
        <add>
          <header>Type</header>
          <size>100</size>
          <type>options</type>
          <index>product_type</index>
          <options>firegento_gridcontrol/utility::getDropdownAttributeLabelOptionArray(product_type)</options>
        </add>
        <after>ean</after>
      </product_type>
      
      <bol_category>
        <add>
          <header>Bol Category</header>
          <size>100</size>
          <type>text</type>
          <index>bol_category</index>
        </add>
        <after>product_type</after>
      </bol_category>
      
      <massaction>
        <updateColumn>
          <width>5%</width>
        </updateColumn>
      </massaction>

    </productGrid>
    
    <!-- Category Products Grid -->
    
    <catalog_category_products>
      
      <entity_id>
        <!-- <remove/> -->
      </entity_id>
      
      <sku>
        <after>name</after>
      </sku>
      
      <name>
        <after>sku</after>
      </name>
      
      <product_type>
        <add>
          <header>Product Type</header>
          <type>options</type>
          <index>product_type</index>
          <options>firegento_gridcontrol/utility::getDropdownAttributeLabelOptionArray(product_type)</options>
        </add>
        <after>name</after>
      </product_type>
      
      <status>
        <add>
          <header>Status</header>
          <type>options</type>
          <index>status</index>
          <options>catalog/product_status::getOptionArray</options>
        </add>
        <after>product_type</after>
      </status>
      
      <eol>
        <add>
          <header>EOL</header>
          <type>options</type>
          <index>eol</index>
          <options>firegento_gridcontrol/utility::getDropdownAttributeLabelOptionArray(eol)</options>
        </add>
        <after>status</after>
      </eol>
      
      <!-- <supplier> -->
        <!-- <add> -->
          <!-- <header>Leverancier</header> -->
          <!-- <type>options</type> -->
          <!-- <index>supplier</index> -->
          <!-- <options>firegento_gridcontrol/utility::getDropdownAttributeLabelOptionArray(supplier)</options> -->
        <!-- </add> -->
        <!-- <after>eol</after> -->
      <!-- </supplier> -->

      <manufacturer>
        <add>
          <header>Merk</header>
          <type>options</type>
          <index>manufacturer</index>
          <options>firegento_gridcontrol/utility::getDropdownAttributeLabelOptionArray(manufacturer)</options>
        </add>
        <after>eol</after>
      </manufacturer>
      
      <qty>
        <remove/>
      </qty>
      
    </catalog_category_products>
    
    <!-- Orders Grid -->

    <sales_order_grid>
    
      <massaction>
        <updateColumn>
          <width>10px</width>
          <filter>false</filter>
          <sortable>false</sortable>
        </updateColumn>
      </massaction>
      
      <store_id>
        <remove/>
      </store_id>
      
    </sales_order_grid>
    
    <!-- Product Sub Grids in Admin -->
    
    <cross_sell_product_grid>
      
      <sku>
        <after>entity_id</after>
      </sku>
      
    </cross_sell_product_grid>
    
    <related_product_grid>
      
      <sku>
        <after>entity_id</after>
      </sku>
      
    </related_product_grid>
    
    <up_sell_product_grid>
      
      <sku>
        <after>entity_id</after>
      </sku>
      
    </up_sell_product_grid>
    
    <!-- Attribute Grid -->
    
    <attributeGrid>
    
      <attribute_id>
        <add>
          <align>center</align>
          <header>ID</header>
          <type>text</type>
          <index>attribute_id</index>
          <width>50</width>
          <filter>0</filter>
        </add>
        <after>attribute_code</after>
      </attribute_id>
      
      <attribute_code>
        <after>attribute_id</after>
      </attribute_code>
      
      <position>
        <add>
          <align>center</align>
          <header>Positie</header>
          <type>text</type>
          <index>position</index>
          <width>50</width>
        </add>
        <after>attribute_code</after>
      </position>
    
      <frontend_label>
        <add>
          <header>Label</header>
          <type>text</type>
          <index>frontend_label</index>
          <width>200</width>
        </add>
        <after>position</after>
      </frontend_label>
      
      <frontend_input>
        <add>
          <align>center</align>
          <header>Type</header>
          <type>text</type>
          <index>frontend_input</index>
          <width>100</width>
        </add>
        <after>frontend_label</after>
      </frontend_input>
    
      <!-- <is_html_allowed_on_front> -->
        <!-- <add> -->
          <!-- <align>center</align> -->
          <!-- <header>HTML</header> -->
          <!-- <type>options</type> -->
          <!-- <index>is_html_allowed_on_front</index> -->
          <!-- <options> -->
            <!-- <option_1> -->
              <!-- <key>1</key> -->
              <!-- <value>Ja</value> -->
            <!-- </option_1> -->
            <!-- <option_0> -->
              <!-- <key>0</key> -->
              <!-- <value>Nee</value> -->
            <!-- </option_0> -->
          <!-- </options> -->
        <!-- </add> -->
        <!-- <after>is_global</after> -->
      <!-- </is_html_allowed_on_front> -->
      
      <is_used_for_promo_rules>
        <add>
          <align>center</align>
          <header>PromoRules</header>
          <type>options</type>
          <index>is_used_for_promo_rules</index>
          <options>
            <option_1>
              <key>1</key>
              <value>Ja</value>
            </option_1>
            <option_0>
              <key>0</key>
              <value>Nee</value>
            </option_0>
          </options>
        </add>
        <after>frontend_label</after>
      </is_used_for_promo_rules>
      
      <is_visible_in_advanced_search>
        <remove />
        <!-- <add> -->
          <!-- <align>center</align> -->
          <!-- <header>Adv. Search</header> -->
          <!-- <type>options</type> -->
          <!-- <index>is_visible_in_advanced_search</index> -->
          <!-- <options> -->
            <!-- <option_1> -->
              <!-- <key>1</key> -->
              <!-- <value>Ja</value> -->
            <!-- </option_1> -->
            <!-- <option_0> -->
              <!-- <key>0</key> -->
              <!-- <value>Nee</value> -->
            <!-- </option_0> -->
          <!-- </options> -->
        <!-- </add> -->
        <!-- <after>frontend_label</after> -->
      </is_visible_in_advanced_search>
      
      <used_in_product_listing>
        <add>
          <align>center</align>
          <header>InCategory</header>
          <type>options</type>
          <index>used_in_product_listing</index>
          <options>
            <option_1>
              <key>1</key>
              <value>Ja</value>
            </option_1>
            <option_0>
              <key>0</key>
              <value>Nee</value>
            </option_0>
          </options>
        </add>
        <after>frontend_label</after>
      </used_in_product_listing>
      
      <is_global>
        <remove />
      </is_global>
      
      <is_user_defined>
        <remove />
      </is_user_defined>
      
      <is_comparable>
        <remove />
      </is_comparable>
    
    </attributeGrid>
    
  </grids>
</gridcontrol>
