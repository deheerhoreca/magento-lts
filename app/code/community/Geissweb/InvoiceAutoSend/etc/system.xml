<config>
    <sections>
        <sales_email translate="label" module="geissweb_invoiceautosend">
            <groups>
                <invoice_autosend translate="label">
                    <label>Auto send invoice for payment methods</label>
                    <tab>sales</tab>
                    <frontend_type>text</frontend_type>
                    <sort_order>990</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>1</show_in_website>
                    <show_in_store>1</show_in_store>
                    <fields>
                        <notice translate="label">
                            <label>Informations</label>
                            <frontend_type>text</frontend_type>
                            <frontend_model>invoiceautosend/adminhtml_system_info</frontend_model>
                            <sort_order>0</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </notice>
                        <attach_pdf>
                            <label>Attach invoice as PDF</label>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <comment>Attach the invoice as a PDF file to the invoice email</comment>
                        </attach_pdf>
                        <included_pm_autosend>
                            <label>Payment methods</label>
                            <frontend_type>multiselect</frontend_type>
                            <source_model>invoiceautosend/system_config_activepm</source_model>
                            <sort_order>20</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <comment>For the selected methods, this extension will automatically send the invoice PDF.</comment>
                        </included_pm_autosend>
                        <filename_template>
                            <label>PDF Filename</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>30</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <comment><![CDATA[
                            Template for the PDF filename. Possible replacements:<br/>
                            <i>{increment_id}</i> - Invoice Increment ID<br/>
                            <br/>
                            Example: Invoice_{increment_id}.pdf will result in Invoice_10000123.pdf
                            ]]></comment>
                        </filename_template>
                    </fields>
                </invoice_autosend>
            </groups>
        </sales_email>
    </sections>
</config>
