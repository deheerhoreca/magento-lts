<config>
    <modules>
        <Geissweb_InvoiceAutoSend>
            <version>0.9.2</version>
        </Geissweb_InvoiceAutoSend>
    </modules>
    <global>
        <blocks>
            <invoiceautosend>
                <class>Geissweb_InvoiceAutoSend_Block</class>
            </invoiceautosend>
        </blocks>
        <models>
            <invoiceautosend>
                <class>Geissweb_InvoiceAutoSend_Model</class>
                <resourceModel>geissweb_invoiceautosend_resource</resourceModel>
            </invoiceautosend>
            <invoiceautosend_resource>
                <class>Geissweb_InvoiceAutoSend_Model_Resource</class>
            </invoiceautosend_resource>
            <sales>
                <rewrite>
                    <!--<order>Geissweb_InvoiceAutoSend_Model_Order</order>-->
                    <order_invoice>Geissweb_InvoiceAutoSend_Model_Invoice</order_invoice>
                </rewrite>
            </sales>
            <core>
                <rewrite>
                    <email_template>Geissweb_InvoiceAutoSend_Model_Email_Template</email_template>
                    <email_template_mailer>Geissweb_InvoiceAutoSend_Model_Email_Template_Mailer</email_template_mailer>
                </rewrite>
            </core>
        </models>
        <helpers>
            <invoiceautosend>
                <class>Geissweb_InvoiceAutoSend_Helper</class>
            </invoiceautosend>
        </helpers>
        <events>
            <sales_order_invoice_save_after>
                <observers>
                    <geissweb_invoiceautosend_observer>
                        <type>singleton</type>
                        <class>Geissweb_InvoiceAutoSend_Model_Observer</class>
                        <method>salesOrderInvoiceSaveAfter</method>
                    </geissweb_invoiceautosend_observer>
                </observers>
            </sales_order_invoice_save_after>
        </events>
    </global>
    <default>
        <sales_pdf>
            <invoice_autosend>
                <filename_template>Invoice_{increment_id}.pdf</filename_template>
            </invoice_autosend>
        </sales_pdf>
    </default>
</config>