<ol class="opc opc-firststep-<?php echo $this->getActiveStep() ?> <?php 
$logged=Mage::getSingleton('customer/session')->isLoggedIn();
    if(! $logged){
       echo 'clznotloggedchecko';
    }else{
         echo  'clzloggedchecko';
    } ?>" id="checkoutSteps">
<?php $i=0; foreach($this->getSteps() as $_stepId => $_stepInfo): ?>
<?php if (!$this->getChild($_stepId) || !$this->getChild($_stepId)->isShow()): continue; endif; $i++ ?>
    <li id="opc-<?php echo $_stepId ?>" class="section<?php echo !empty($_stepInfo['allow'])?' allow':'' ?><?php echo !empty($_stepInfo['complete'])?' saved':'' ?>">
        <div class="step-title">
            <span class="number"><?php echo $i ?></span>
            <h2><?php echo $_stepInfo['label'] ?></h2>
            <a href="#"><?php echo $this->__('Edit') ?></a>
        </div>
        <div id="checkout-step-<?php echo $_stepId ?>" class="step a-item" style="display:none;">
            <?php echo $this->getChildHtml($_stepId) ?>
        </div>
    </li>
<?php endforeach ?>
</ol>
<script type="text/javascript">

    var accordion = new Accordion('checkoutSteps', '.step-title', true);
    <?php if($this->getActiveStep()): ?>
    accordion.openSection('opc-<?php echo $this->getActiveStep() ?>');
    <?php endif ?>
    var checkout = new Checkout(accordion,{
        progress: '<?php echo $this->getUrl('checkout/onepage/progress') ?>',
        review: '<?php echo $this->getUrl('checkout/onepage/review') ?>',
        saveMethod: '<?php echo $this->getUrl('checkout/onepage/saveMethod') ?>',
        failure: '<?php echo $this->getUrl('checkout/cart') ?>'}
    );
	
	
	
	Accordion.prototype.openSection = Accordion.prototype.openSection.wrap(
    function(parentMethod, section) {
        // Call parent method
        parentMethod(section);
		sect=accordion.currentSection;
      //  alert(sect);
		
		if(sect=='opc-billing'){
			jQuery('#checkout-step-login').addClass('clzloginshow');
			jQuery('#opc-billing').addClass('clzbillactive');
			
			jQuery('.checkout-number').removeClass('cheknoactive');
			jQuery('#checkout-step-1 .checkout-number').addClass('cheknoactive');
						
		}
		else{
			jQuery('#checkout-step-login').removeClass('clzloginshow');
			jQuery('#opc-billing').removeClass('clzbillactive');
		}
		
		
		
		if(sect=='opc-login'){
			jQuery('.stpactive').removeClass('stpactive');
			jQuery('#checkout-step-1').addClass('stpactive');
		}		
		if(sect=='opc-billing'){
			jQuery('.stpactive').removeClass('stpactive');
			jQuery('#checkout-step-2').addClass('stpactive');
		}
		if(sect=='opc-shipping'){
			jQuery('.stpactive').removeClass('stpactive');
			jQuery('#checkout-step-3').addClass('stpactive');
			
		}
		if(sect=='opc-shipping_method'){
			jQuery('.stpactive').removeClass('stpactive');
			jQuery('#checkout-step-4').addClass('stpactive');
			
		}
		if(sect=='opc-payment'){
			jQuery('.stpactive').removeClass('stpactive');
			jQuery('#checkout-step-5').addClass('stpactive');
			
		}
		
		if(sect=='opc-review'){
			jQuery('.stpactive').removeClass('stpactive');
			jQuery('#checkout-step-6').addClass('stpactive');
		}
		
		
		
    });
	
jQuery(function(){		
		<?php
		if($logged==true){
			?>
			jQuery('#checkout-step-2').addClass('stpactive');
			<?php
		}
		else{
			?>
			jQuery('#checkout-step-1').addClass('stpactive');
			<?php
		}
		?>		
		
		jQuery('#btncaguest').click(function(){
			jQuery('#co-billing-form > h1').hide();
			jQuery('input[value="guest"]').prop('checked',true);
			jQuery('#onepage-guest-register-button').trigger('click');
			jQuery('.col-2.logindvchecko').hide();
			jQuery('#checkout-step-login .col-1').css('width','100%');
			
			jQuery('.clzregcheckout .buttons-set').hide();
		});		
		
		jQuery('#btncareg').click(function(){
			jQuery('#co-billing-form > h1').hide();
			jQuery('input[value="register"]').prop('checked',true);
			jQuery('#onepage-guest-register-button').trigger('click');
			jQuery('.col-2.logindvchecko').hide();
			jQuery('#checkout-step-login .col-1').css('width','100%');
			
			jQuery('.clzregcheckout .buttons-set').hide();
		});		
		
	});
//<![CDATA[	
	
