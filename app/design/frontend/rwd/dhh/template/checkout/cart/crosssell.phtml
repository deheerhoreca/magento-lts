<?php
/**
 * Cart cross sell items template
 *
 * @see Mage_Checkout_Block_Cart_Crosssell
 */
?>
<?php if($this->getItemCount()): ?>
<div class="crosssell product-collateral">
    <h2><?php echo $this->__('Based on your selection, you may be interested in the following items:') ?></h2>
    <?php foreach ($this->getItems() as $_item): ?>
      <a class="product-image" href="<?php echo $_item->getProductUrl() ?>" title="<?php echo $this->htmlEscape($_item->getName()) ?>">
        <div class="col-sx-12 col-sm-1 items cross-sell-product">
          <div class="cross-sell-thumbnail">
            <img class="cross-sell-thumbnail" src="<?php echo $this->helper('catalog/image')->init($_item, 'small_image')->resize(240, 240); ?>" alt="<?php echo $this->htmlEscape($_item->getName()) ?>" />
          </div>
          <div class="cross-sell-text-container">
            <div class="cross-sell-text-title">
              <?php echo $this->htmlEscape($_item->getName()) ?>
            </div>
            <div class="cross-sell-text-price">
              <?php echo $this->getPriceHtml($_item, true) ?>
            </div>
          </div>
        </div>
      </a>
    <?php endforeach; ?>
    <?php // <script type="text/javascript">decorateList('crosssell-products-list', 'none-recursive')</script> ?>
</div>
<?php endif; ?>
