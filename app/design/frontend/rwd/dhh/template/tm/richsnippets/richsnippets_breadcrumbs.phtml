    $dataBreadcrumbs["@context"]        = "http://schema.org";
    $dataBreadcrumbs["@type"]           = "BreadcrumbList";
    $dataBreadcrumbs["itemListElement"] = [];
    
    if($crumbs && is_array($crumbs)) {
      foreach($crumbs as $_crumbName => $_crumbInfo) {
        $dataBreadcrumbs["itemListElement"][$position - 1]["@type"]         = "ListItem";
        $dataBreadcrumbs["itemListElement"][$position - 1]["position"]      = $position;
        $dataBreadcrumbs["itemListElement"][$position - 1]["item"]["name"]  = $_crumbInfo["label"];
        if($_crumbName === "product" && !empty($product_image_url_cdn)) {
          $dataBreadcrumbs["itemListElement"][$position - 1]["item"]["@id"]   = getOmDhhUtilHelper()->getFullProductUrl($_product);
          $dataBreadcrumbs["itemListElement"][$position - 1]["item"]["image"] = $product_image_url_cdn;
        } else {
          $dataBreadcrumbs["itemListElement"][$position - 1]["item"]["@id"]   = $_crumbInfo["link"];
        }
        $position++;
      }
    }
    
    if($crumbs && is_array($crumbs) && sizeof($crumbs) > 1) {
      echo '<nav aria-label="breadcrumb"><ol class="breadcrumb">';
      $n = sizeof($crumbs);
      $i = 0;
      
      foreach($crumbs as $_crumbName => $_crumbInfo) {
        if(in_array($_crumbName, $ignored_category_keys, true)) {
          continue;
        }
        if($n > 2 && $_crumbName === "product") {
          continue;
        }
        
        $label = $this->htmlEscape($_crumbInfo["label"]);
        $label = getOmDhhUtilHelper()->cleanCategoryName($label);
        $label = trim((string) $label);
        
        $title = $this->htmlEscape($_crumbInfo["title"]);
        $title = getOmDhhUtilHelper()->cleanCategoryName($title);
        $title = trim((string) $title);
        
        if($_crumbName === "home") { ?>
          <li class="breadcrumb-item"><a title="<?=$title?>" href="<?=$_crumbInfo["link"]?>"><i class="fa fa-home"></i></a></li><?php
        } elseif($_crumbInfo["link"] && ($_crumbInfo["last"] !== true || $_product)) {
          // echo "<a title='{$title}' class='button no-transition' href='{$_crumbInfo['link']}'>{$label}</a>"?>
          <li class="breadcrumb-item"><a title="<?=$title?>" href="<?=$_crumbInfo["link"]?>"><?=$label?></a></li><?php
        } else { ?>
          <li class="breadcrumb-item active" aria-current="page"><?=$label?></li><?php
        }
        $i++;
      }
      echo "</ol></nav>";
    }
    
    // Print LDJSON for the breadcrumbs
    if(!empty($dataBreadcrumbs["itemListElement"])) {
      $json = Mage::helper("core")->jsonEncode($dataBreadcrumbs);
      echo "<script type=\"application/ld+json\">{$json}</script>";
    }
