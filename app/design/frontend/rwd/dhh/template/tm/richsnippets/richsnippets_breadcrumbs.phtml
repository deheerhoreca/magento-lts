$_helper = Mage::helper("richsnippets");

if($_helper->snippetsEnabled()) {
  $store      = Mage::app()->getStore();
  $store_name = $store->getFrontendName();
  
  /* PRE-PROCESSING */
  
  /** @var Mage_Catalog_Model_Product $_product */
  if($_product = Mage::registry("current_product")) {
    
    /** @var Mage_Catalog_Helper_Image $cat_image_helper */
    // $cat_image_helper   = Mage::helper("catalog/image");
    // $product_image_url  = $cat_image_helper->init($_product, "image")->__toString();
    $product_image_type = "thumbnail";
    
    if(filled($_product->getData($product_image_type)) && $_product->getData($product_image_type) !== "no_selection") {
      $media              = Mage::getBaseUrl(Mage_Core_Model_Store::URL_TYPE_MEDIA);
      $image_url          = "{$media}catalog/product{$_product->getData($product_image_type)}";
      $cdn_img_options    = [
        "url"               => $image_url,
        "url_only"          => true,
        "xform"             => "omcatprddtlh",
        "cm"                => "pad_resize",
        "add_mod_time"      => true,
        "relative_url"      => false,
      ];
    } else {
      $product_image_url_cdn = "";
    }
    
    if(is_array($crumbs) && sizeof($crumbs) > 2 && isset($crumbs["product"])) {
      unset($crumbs["product"]);
    }
  }
  
  if(is_array($crumbs) && sizeof($crumbs) > 0) {
    $currentUrl = Mage::helper("core/url")->getCurrentUrl();
