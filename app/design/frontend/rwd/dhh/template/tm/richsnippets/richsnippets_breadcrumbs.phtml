<?php

/* Ignore these categories in the breadcrumb */
// $ignored_categorie_keys = [
  // "category834",      // Promotions
// ];
$ignored_categorie_keys = [];

$store = Mage::app()->getStore();
$store_name = $store->getFrontendName();

if($_product = Mage::registry('current_product')) {
  $product_image = $_product->getImageUrl();
  $product_url = Mage::helper("deheerhoreca_util/util")->getFullProductUrl($_product);
  
  if(is_array($crumbs) && sizeof($crumbs) > 2 && isset($crumbs["product"]) === true) {
    unset($crumbs["product"]);
  }
}

$currentUrl = Mage::helper('core/url')->getCurrentUrl();

/* Pre-processing */
if(is_array($crumbs) && sizeof($crumbs) > 0) {
  foreach($crumbs as $_crumbName => $_crumbInfo) {
    if(strlen($_crumbInfo['title']) < 1) {
      $crumbs[$_crumbName]['title'] = $crumbs[$_crumbName]['label'];
    }
    if($crumbs[$_crumbName]['first']) {
      $crumbs[$_crumbName]['label'] = $store_name;
    }
    if($crumbs[$_crumbName]['last'] && strlen($crumbs[$_crumbName]['link']) < 1) {
      $crumbs[$_crumbName]['link'] = $currentUrl;
    }
  }
}

if(Mage::helper('richsnippets')->snippetsEnabled()) {
  $snippetsType = Mage::getStoreConfig('richsnippets/general/snippetsType');
  if ($snippetsType == '0') { // if JSON enabled
    $position = 1;

    $dataBreadcrumbs = array();
    $dataBreadcrumbs['@context']    = "http://schema.org";
    $dataBreadcrumbs['@type']       = "BreadcrumbList";
    $dataBreadcrumbs['itemListElement'] = [];
    if($crumbs && is_array($crumbs)) {
      foreach($crumbs as $_crumbName => $_crumbInfo) {
        $dataBreadcrumbs['itemListElement'][$position - 1]['@type']         = 'ListItem';
        $dataBreadcrumbs['itemListElement'][$position - 1]['position']      = $position;
        $dataBreadcrumbs['itemListElement'][$position - 1]['item']['name']  = $_crumbInfo['label'];
        if($_crumbName === "product" && isset($product_image)) {
          $dataBreadcrumbs['itemListElement'][$position - 1]['item']['@id']   = $product_url;
          $dataBreadcrumbs['itemListElement'][$position - 1]['item']['image'] = $product_image;
        } else {
          $dataBreadcrumbs['itemListElement'][$position - 1]['item']['@id']   = $_crumbInfo['link'];
        }
        $position++;
      }
    }
    
    // if($crumbs && is_array($crumbs) && sizeof($crumbs) > 1) {
      // if(_dhh_debug()) {
        // printr($crumbs);
      // }
    // }
    
    if($crumbs && is_array($crumbs) && sizeof($crumbs) > 1) {
      echo '<nav aria-label="breadcrumb"><ol class="breadcrumb">'.PHP_EOL;
      $n = sizeof($crumbs);
      $i = 0;
      
      foreach($crumbs as $_crumbName => $_crumbInfo) {
        
        if(in_array($_crumbName, $ignored_categorie_keys) !== false) {
          continue;
        }
        
        if($n > 2 && $_crumbName === "product") {
          continue;
        }
        
        $label = $this->htmlEscape($_crumbInfo['label']);
        $label = Mage::helper("deheerhoreca_util/util")->cleanCategoryName($label);
        $label = trim($label);
        
        $title = $this->htmlEscape($_crumbInfo['title']);
        $title = Mage::helper("deheerhoreca_util/util")->cleanCategoryName($title);
        $title = trim($title);
        
        if($_crumbName === "home") {
          echo "              <li class='breadcrumb-item'>";
          echo "<a title='{$title}' href='{$_crumbInfo['link']}'><i class='fa fa-home'></i></a></li>";
        } elseif($_crumbInfo['link'] && ($_crumbInfo['last'] !== true || $_product)) {
          // echo "<a title='{$title}' class='button no-transition' href='{$_crumbInfo['link']}'>{$label}</a>";
          echo "              <li class='breadcrumb-item'>";
          echo "<a title='{$title}' href='{$_crumbInfo['link']}'>{$label}</a></li>";
        } else {
          echo "              <li class='breadcrumb-item active' aria-current='page'>{$label}</li>";
        }
        
        echo PHP_EOL;        
        $i++;
      }
      echo '            </ol></nav>'.PHP_EOL;
    }
    
    // Print JSON
    if(empty($dataBreadcrumbs['itemListElement']) === false) {
      $json = Mage::helper('core')->jsonEncode($dataBreadcrumbs);
      if(isset($_SERVER['MAGE_IS_DEVELOPER_MODE'])) {
        $json = json_encode(json_decode($json), JSON_PRETTY_PRINT); // During development
      }
      echo "  <script type=\"application/ld+json\">{$json}</script>".PHP_EOL;
    }
  } elseif ($snippetsType == '1') {
    if($crumbs && is_array($crumbs)) { ?>
      <div class="breadcrumbs">
        <ul itemscope itemtype="http://schema.org/BreadcrumbList">
          <?php
          foreach($crumbs as $_crumbName=>$_crumbInfo) {
            
            $label = $this->htmlEscape($_crumbInfo['label']);
            $label = Mage::helper("deheerhoreca_util/util")->cleanCategoryName($label);
            $label = trim($label);
            
            $title = $this->htmlEscape($_crumbInfo['title']);
            $title = Mage::helper("deheerhoreca_util/util")->cleanCategoryName($title);
            $title = trim($title);
            
            echo "<li class='{$_crumbName}'";
            if($_crumbInfo['link']) {
              echo "itemprop='itemListElement' itemscope itemtype='http://schema.org/ListItem'";
            }
            echo ">";
            if($_crumbInfo['link']) {
              ?>
              <a itemprop="item" href="<?php echo $_crumbInfo['link'] ?>" title="<?php echo $title; ?>">
                <span itemprop="name"><?php echo $label; ?></span>
              </a>
              <?php
            } elseif($_crumbInfo['last']) {
              echo "<strong>{$label}</strong>";
            } else {
              echo $label;
            }
            
            if(!$_crumbInfo['last']) {
              echo "<span>/ </span>";
            }
            echo "</li>";
          }
          ?>
        </ul>
      </div>
    <?php
    }
  }
}
