<?php

declare(strict_types=1);

/** @var TM_RichSnippets_Block_Product $this */

if(Mage::helper("richsnippets")->snippetsEnabled() && Mage::getStoreConfig("richsnippets/general/snippetsType") == "0") {
  $_product       = Mage::registry("current_product");
  $json           = "";
  $cache_key      = "dhh_richsnippet_product_{$_product->getId()}";
  $dhhHelperFpc ??= Mage::helper("deheerhoreca_fpc/data");
  
  // Serve from cache
  if(DeHeerHoreca_Fpc_Helper_Data::is_read_cache_enabled(true, true, "tm_richsnippets")) {
    // $json = Mage::app()->getCache()->load($cache_key);
    $json = omCacheGet($cache_key);
    if(empty($json)) {
      DeHeerHoreca_Fpc_Helper_Data::log("MISS {$cache_key}");
    } else {
      DeHeerHoreca_Fpc_Helper_Data::log("HIT {$cache_key}");
      echo "<script type=\"application/ld+json\">{$json}</script>";
      return;
    }
  }
  
  // Serve fresh
  $json = (string) $this->getJsonSnippetsProduct();
  echo "<script type=\"application/ld+json\">{$json}</script>";
  
  // Defer cache SAVE
  if(DeHeerHoreca_Fpc_Helper_Data::is_write_cache_enabled(true, true, "tm_richsnippets")) {
    $supplier_sys_upper = strtoupper((string) preg_replace("/\s+/", "", (string) _get_product_attribute($_product, "supplier")));
    $cache_tags = [
      "DHH_SUPPLIER_{$supplier_sys_upper}",
      "DHH_TM_RICHSNIPPETS",
      strtoupper(Mage_Catalog_Model_Product::CACHE_TAG)."_{$_product->getId()}",
    ];
    DeHeerHoreca_Fpc_Helper_Data::saveToCacheDeferred($cache_key, $json, $cache_tags, 86400 * 7, minifyHtml: false);
  }
}
