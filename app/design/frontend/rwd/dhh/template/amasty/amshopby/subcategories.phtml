return;

/** @var Amasty_Shopby_Block_Subcategories $this */
/** @var Mage_Catalog_Model_Resource_Category_Collection|Mage_Catalog_Model_Resource_Category_Flat_Collection $subcategories */
$subcategories = $this->getSubcategories();
$haschild = false;

echo '<div style="clear: both;"></div>';

if($subcategories->count() > 1) {
  $media_path     = Mage::getBaseDir('media');
  $media_url      = rtrim((string) Mage::getBaseUrl(Mage_Core_Model_Store::URL_TYPE_MEDIA), "/");
  $media_dir      = rtrim((string) Mage::getBaseDir(Mage_Core_Model_Store::URL_TYPE_MEDIA), "/");
  
  // Logic cloned:
  // - catalog/product/list.phtml
  // - amasty/amshopby/subcategories.phtml
  
  echo "<ul class='grid-shadow-tiles-text'>".PHP_EOL;
  
  foreach($subcategories as $i => $subcategory) {
    if(!in_array((int) $subcategory->getId(), EXCLUDED_CATEGORY_IDS, true)) {
      continue;
    }
    $haschild           = true;
    // $category_name      = Mage::helper("deheerhoreca_util/util")->cleanCategoryName($subcategory->getName());
    $category_name      = (string) $subcategory->getName();
    $category_name_safe = htmlspecialchars($category_name);
    $image              = $subcategory->getImage();
    $category_url       = $subcategory->getUrl();
    $image_path         = "{$media_path}/catalog/category/{$image}";
    $img_html           = "";
    
    if(is_file($image_path)) {
      $image_url        = "{$media_url}/catalog/category/{$image}";
      $col_width        = 140;
      $cdn_img_options  = [
        "identifier"      => $subcategory->getId(),
        "fs_path"         => $image_path,
        "url"             => $image_url,
        "fit"             => "contain",
        "width"           => $col_width,
        "height"          => $col_width,
        "lazy"            => ($i < 5),
        "add_mod_time"    => true,
        "class"           => "trans-opacity",
        "title"           => $category_name,
        "alt"             => $category_name,
        "quality"         => 80,
        "relative_url"    => true,
      ];
      $img_html         = Mage::helper("deheerhoreca_util/util")->_cdn_img($cdn_img_options);
    }
    
    echo "<li style='max-width: 180px'>";
    echo "<a href='{$category_url}' title='{$category_name_safe}'>{$img_html}<strong>{$category_name}</strong>";
    echo "</a></li>".PHP_EOL;
  }
  echo "</ul>".PHP_EOL;
  if($haschild) {
    echo "<style>#sidebar-nav {display: block;}</style>";
  }
}
