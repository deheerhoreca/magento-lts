declare(strict_types=1);

use \Illuminate\Support\Arr;

/** @var Amasty_Shopby_Block_Catalog_Layer_Filter_Attribute $this */

// ─── Display type constants (readability shorthand) ───────────────────────────
$DT_LABELS        = Amasty_Shopby_Model_Source_Attribute::DT_LABELS_ONLY;
$DT_IMAGES        = Amasty_Shopby_Model_Source_Attribute::DT_IMAGES_ONLY;
$DT_IMAGES_LABELS = Amasty_Shopby_Model_Source_Attribute::DT_IMAGES_AND_LABELS;
$DT_DROPDOWN      = Amasty_Shopby_Model_Source_Attribute::DT_DROPDOWN;
$DT_2_COLUMNS     = Amasty_Shopby_Model_Source_Attribute::DT_LABELS_IN_2_COLUMNS;

$displayType    = $this->getDisplayType();
$attributeName  = htmlspecialchars((string) $this->getRequestValue());

// ─── Build CSS classes for <ol> ───────────────────────────────────────────────
$classes = [];
if ($this->getCollapsed() && !$this->getHasSelection()) {
  $classes[] = 'no-display-current';
}
if ($this->getSingleChoice()) {
  $classes[] = 'single-choice';
}
if ($this->getSortFeaturedFirst() && in_array($displayType, [$DT_LABELS, $DT_IMAGES_LABELS])) {
  $classes[] = 'sort-featured-first-'.$this->getRequestValue();
}
$classAttr = trim(implode(' ', $classes));

// ─── Prepare items ────────────────────────────────────────────────────────────
$items = $this->getItemsAsArray();
$items = Arr::map($items, function ($item) {
  if (dg($item, "countValue")) {
    $item['countValue'] = (int) $item['countValue'];
  }
  if (isset($item["url"])) {
    $item["url"] = str_replace("https://www.chefstore.nl/", "/", (string) $item["url"]);
  }
  if (isset($item['label'])) {
    $item['label'] = (string) $item['label'];
  }
  if (isset($item['css'])) {
    $item['css'] = (string) $item['css'];
  }
  return $item;
});
$items = array_values(array_filter($items));

// ─── Coverage-based filter display control ────────────────────────────────────
$productCountThresholdPath            = 'deheerhoreca_layered_navigation/settings/coverage_product_count_threshold';
$percentageThresholdPath              = 'deheerhoreca_layered_navigation/settings/coverage_percentage_threshold';
$defaultCoverageProductCountThreshold = 65;   // @todo fine-tune
$defaultCoveragePercentageThreshold   =  7;   // @todo fine-tune

$coverageExemptAttributeCodes  = [
  "recommended_product",
];
$coverageProductCountThreshold = (int) Mage::getStoreConfig($productCountThresholdPath);
$coveragePercentageThreshold   = (int) Mage::getStoreConfig($percentageThresholdPath);

if ($coverageProductCountThreshold < 1) {
  $coverageProductCountThreshold = $defaultCoverageProductCountThreshold;
}
if ($coveragePercentageThreshold <= 0) {
  $coveragePercentageThreshold = $defaultCoveragePercentageThreshold;
}

$shouldRenderFilter   = true;
$categoryProductCount = null;
$coveredProductCount  = null;
$coveragePercentage   = null;

if($this instanceof Amasty_Shopby_Block_Catalog_Layer_Filter_Attribute) {
  $attributeCode = (string) $this->getRequestValue();
  
  if(!in_array($attributeCode, $coverageExemptAttributeCodes, true)) {
    $categoryProductCount = (int) $this->getCurrentLayerProductCount();
    
    if($categoryProductCount >= $coverageProductCountThreshold) {
      $countValues = [];
      foreach($items as $item) {
        if(is_array($item) && isset($item['countValue'])) {
          $countValues[] = (int) $item['countValue'];
        }
      }
      $coveredProductCount = min((int) array_sum($countValues), $categoryProductCount);
      $coveragePercentage  = $categoryProductCount > 0
        ? (int) ($coveredProductCount / $categoryProductCount * 100) : 0;
      
      if($coveragePercentage < $coveragePercentageThreshold) {
        $shouldRenderFilter = false;
      }
    }
  }
}

$coveragePercentage = isset($coveragePercentage) ? round($coveragePercentage, 2) : null;

// devDump([
//   'attribute'                     => $this->getRequestValue(),
//   'categoryProductCount'          => $categoryProductCount,
//   'coverageExemptAttributeCodes'  => $coverageExemptAttributeCodes,
//   'coveragePercentage'            => $coveragePercentage,
//   'coveragePercentageThreshold'   => $coveragePercentageThreshold,
//   'coverageProductCountThreshold' => $coverageProductCountThreshold,
//   'coveredProductCount'           => $coveredProductCount,
//   'shouldRenderFilter'            => $shouldRenderFilter,
// ]);

// ─── Helper: build <li> attribute string ──────────────────────────────────────
$buildLiAttrs = function (array $item): string {
  $attrs = [];
  if (!empty($item['style'])) {
    $attrs[] = $item['style'];
  }
  if (isset($item['default_sort'])) {
    $attrs[] = 'data-default_sort="'.htmlspecialchars((string) $item['default_sort']).'"';
  }
  if (isset($item['featured_sort'])) {
    $attrs[] = 'data-featured_sort="'.htmlspecialchars((string) $item['featured_sort']).'"';
  }
  $attrs[] = 'data-text="'.htmlspecialchars((string) $item['label']).'"';
  return implode(' ', $attrs);
};

// ─── Helper: cap a count value for display ────────────────────────────────────
$capCount = function ($count, int $max = 100): string {
  if (is_numeric($count) && $count > $max) {
    return $max.'+';
  }
  return (string) $count;
};

// ─── Helper: build hover attributes for image items ───────────────────────────
$buildImageHover = function (array $item): array {
  $preloadHtml = '';
  $onHover     = '';
  if (!empty($item['image_hover'])) {
    $hoverSrc    = htmlspecialchars($item['image_hover']);
    $imageSrc    = htmlspecialchars($item['image']);
    $preloadHtml = '<img src="'.$hoverSrc.'" style="display: none;">';
    $onHover     = "onmouseover=this.src='".$hoverSrc."' onmouseout=this.src='".$imageSrc."'";
  }
  return [$preloadHtml, $onHover];
};

// ─── Helper: ensure rel attribute ─────────────────────────────────────────────
$ensureRel = function (array &$item): void {
  if (empty($item['rel'])) {
    $item['rel'] = "rel='nofollow'";
  }
};

if (!$shouldRenderFilter) {
  return;
}
?>
<ol class="<?= htmlspecialchars($classAttr) ?>" data-filled="<?= htmlspecialchars((string) $coveragePercentage ?? "")?>">
  <?php if ($this->getSortFeaturedFirst()) { ?>
  <input type="hidden" id="field_sort_featured_<?= $attributeName ?>" value="default_sort">
  <?php } ?>

  <?php switch ($displayType) {

    // ══════════════════════════════════════════════════════════════════════════
    // Labels only
    // ══════════════════════════════════════════════════════════════════════════
    case $DT_LABELS:
      if ($this->getShowSearch()) { ?>
  <li rel="search">
    <input id="amshopby_attr_search_<?= $attributeName ?>" type="text" class="input-text amshopby_attr_search input-text" onkeyup="amshopby_attr_search(this)" autocomplete="off" placeholder="">
  </li>
  <?php   }

      foreach ($items as $item) {
        if (strtolower($item['label']) === 'n.v.t.') {
          continue;
        }
        $ensureRel($item);

        $count     = $capCount($item['countValue']);
        $countHtml = "<span class='count'>{$count}</span>";

        $label = $item['label'];
        if (mb_strlen($label) > 27) {
          $label = mb_substr($label, 0, 24).'...';
        }

        $checkboxHtml = str_contains($item['css'], 'amshopby-attr-selected')
          ? '<span class="amshopby-choice"></span>'
          : '';

        $liAttrStr = $buildLiAttrs($item);
      ?>
  <li <?= $liAttrStr ?>>
    <a class="<?= htmlspecialchars($item['css']) ?>" <?= $item['rel'] ?> href="<?= $item['url'] ?>" data-config='<?= $item['data-config'] ?>'
      title="<?= htmlspecialchars($item['label']) ?>"><?= htmlspecialchars($label).$countHtml ?></a>
    <?= $checkboxHtml ?>
  </li>
  <?php   }
      break;

    // ══════════════════════════════════════════════════════════════════════════
    // Images only
    // ══════════════════════════════════════════════════════════════════════════
    case $DT_IMAGES: ?>
  <li>
    <?php foreach ($items as $item) {
          [$preloadHtml, $onHover] = $buildImageHover($item);
          echo $preloadHtml;
        ?>
    <a <?= $item['style'].$item['rel'] ?> class="<?= htmlspecialchars($item['css']) ?>" href="<?= $item['url'] ?>" data-config='<?= $item['data-config'] ?>'>
      <img src="<?= htmlspecialchars($item['image']) ?>" <?= $onHover ?> title="<?= htmlspecialchars($item['label']) ?>" alt="<?= htmlspecialchars($item['label']) ?>">
    </a>
    <?php   } ?>
  </li>
  <?php break;

    // ══════════════════════════════════════════════════════════════════════════
    // Images and labels
    // ══════════════════════════════════════════════════════════════════════════
    case $DT_IMAGES_LABELS:
      if ($this->getShowSearch()) { ?>
  <li rel="search">
    <input type="text" class="amshopby_attr_search">
  </li>
  <?php   }

      foreach ($items as $item) {
        $count                   = $capCount($item['count'], 1000);
        $liAttrStr               = $buildLiAttrs($item);
        [$preloadHtml, $onHover] = $buildImageHover($item);
        echo $preloadHtml;
      ?>
  <li <?= $liAttrStr ?>>
    <a class="<?= htmlspecialchars($item['css']) ?>" <?= $item['rel'] ?> href="<?= $item['url'] ?>" data-config='<?= $item['data-config'] ?>'>
      <?php if (!empty($item['image'])) { ?>
      <img src="<?= htmlspecialchars($item['image']) ?>" <?= $onHover ?> title="<?= htmlspecialchars($item['label']) ?>" alt="<?= htmlspecialchars($item['label']) ?>">
      <?php       } ?>
      <?= htmlspecialchars($item['label']).htmlspecialchars($count) ?>
    </a>
  </li>
  <?php   }
      break;

    // ══════════════════════════════════════════════════════════════════════════
    // Dropdown
    // ══════════════════════════════════════════════════════════════════════════
    case $DT_DROPDOWN: ?>
  <li>
    <select onchange="if(this.value) window.location.href = this.value" class="amshopby-select amshopby-ajax-select">
      <option value="<?= htmlspecialchars($this->getRemoveUrl()) ?>" data-config='<?= $this->getRemoveOptionConfig() ?>'>
        <?= Mage::helper('amshopby')->__('Selecteer ...') ?>
      </option>
      <?php foreach ($items as $item) {
            $count = $capCount($item['count']);
          ?>
      <option <?= $item['css'].$item['rel'] ?> value="<?= $item['url'] ?>" data-config='<?= $item['data-config'] ?>'>
        <?= htmlspecialchars($item['label']).htmlspecialchars($count) ?>
      </option>
      <?php       } ?>
    </select>
  </li>
  <?php break;

    // ══════════════════════════════════════════════════════════════════════════
    // Labels in 2 columns
    // ══════════════════════════════════════════════════════════════════════════
    case $DT_2_COLUMNS:
      $size = count($items);
      $half = (int) ceil($size / 2);
    ?>
  <li>
    <div class="amshopby-column">
      <?php for ($i = 0; $i < $half; $i++) {
            $item  = $items[$i];
            $count = $capCount($item['count']);
          ?>
      <a class="<?= htmlspecialchars($item['css']) ?>" <?= $item['rel'] ?> href="<?= $item['url'] ?>" data-text="<?= htmlspecialchars($item['label']) ?>"
        data-config='<?= $item['data-config'] ?>'><?= htmlspecialchars($item['label']).htmlspecialchars($count) ?></a><br>
      <?php       } ?>
    </div>
    <div class="amshopby-column">
      <?php for ($i = $half; $i < $size; $i++) {
            $item  = $items[$i];
            $count = $capCount($item['count']);
          ?>
      <a class="<?= htmlspecialchars($item['css']) ?>" <?= $item['rel'] ?> href="<?= $item['url'] ?>" data-text="<?= htmlspecialchars($item['label']) ?>"
        data-config='<?= $item['data-config'] ?>'><?= htmlspecialchars($item['label']).htmlspecialchars($count) ?></a><br>
      <?php       } ?>
    </div>
  </li>
  <?php break;
  } ?>

  <?php
  // ─── Show Less / More ─────────────────────────────────────────────────────────
  if (
    $this->getShowLessMore()
    && in_array($displayType, [$DT_LABELS, $DT_IMAGES, $DT_IMAGES_LABELS])
  ) {
    $total                = count($items);
    $short                = $this->getMaxOptions();
    $countSelectedOptions = $this->getCountSelectedOptions();
    $add                  = $countSelectedOptions > $short ? $total - $countSelectedOptions : $total - $short;

    if ($add > 0) { ?>
  <li class="amshopby-clearer">
    <a id="amshopby-more-<?= htmlspecialchars($this->getRequestValue()) ?>" class="amshopby-more" href="#"><?= $this->__('Meer opties') ?></a>
  </li>
  <?php } ?>
  <li class="amshopby-clearer">
    <a id="amshopby-less-<?= htmlspecialchars($this->getRequestValue()) ?>" class="amshopby-less" href="#" style="display:none"><?= $this->__('Minder opties') ?></a>
  </li>
  <?php } ?>
</ol>
