// Logic exists in multiple places, keep in sync:
// - deheerhoreca-magento/app/design/frontend/rwd/dhh/template/magiczoomplus/media.phtml
//   - USES realpath() NOT get_absolute_path()
// - deheerhoreca-intel/lib/intel.inc.php
//   - USES get_absolute_path() NOT realpath()
// Allows for arbitrary number of dashes in the SKU
function _extract_data_from_optimized_image_name($optimized_image, string $dhh_sku = "NO_SKU") {
  $filename = pathinfo((string) $optimized_image, PATHINFO_FILENAME);
  $parts    = explode("-", $filename);
  $count    = sizeof($parts);
  
  if($count >= 5) {
    
    $optimized_image_data = [
      "input"       => $optimized_image,
      "path"        => null,
      "supplier"    => $parts[0],
      // "sku"         => $parts[1],
      "nr"          => $parts[$count-3],
      "type"        => $parts[$count-2],
      "hash"        => $parts[$count-1],
    ];
    
    // get_absolute_path() on intel, realpath() in OpenMage
    if(function_exists("get_absolute_path")) {
      $optimized_image_data["path"] = get_absolute_path($optimized_image);
    } else {
      $optimized_image_data["path"] = realpath($optimized_image);
    }
    
    if($optimized_image_data["path"] === $filename) {
      $msg = "{$dhh_sku} ".__FUNCTION__." failed: Need full image path, not ".var_export($optimized_image, true);
      if(function_exists("logger")) {
        logger($msg, "ERROR");
      } else {
        Mage::log($msg, null, "system.log", true);
      }
      if(function_exists("im")) {
        im("imgs_extract_data_failed");
      }
      return false;
    }
    
    $replaces = [
      "{$optimized_image_data["path"]}-",
      "{$optimized_image_data["supplier"]}-",
      "-{$optimized_image_data["nr"]}",
      "-{$optimized_image_data["type"]}-", // Watch this... "-a" or "-b" matches the hash sometimes
      "{$optimized_image_data["hash"]}",
    ];
    $optimized_image_data["sku"] = str_replace($replaces, "", $filename);
    
    $msg = "{$dhh_sku} Extract data from ".var_export($optimized_image, true)." OK";
    if(function_exists("logger")) {
      logger($msg, "VERBOSE");
    } else {
      if(_dhh_debug()) {
        Mage::log($msg, null, "verbose.txt", true);
      }
    }
    if(function_exists("im")) {
      im("imgs_extract_data_ok");
    }    
    return $optimized_image_data;    
  } else {
    $msg = "{$dhh_sku} Failed to extract data from ".var_export($optimized_image, true).", was the image named correctly?";
    if(function_exists("logger")) {
      logger($msg, "NOTICE");
    } else {
      Mage::log($msg, null, "system.log", true);
    }
    if(function_exists("im")) {
      im("imgs_extract_data_failed");
    }
  }
  return false;
}

// Logic exists in multiple places, keep in sync:
// - deheerhoreca-magento/app/design/frontend/rwd/dhh/template/magiczoomplus/media.phtml
// - deheerhoreca-intel/actions/pushers/catalog-magento1/functions-products.inc.php
function _get_watermarked_image_filename($optimized_image, string $dhh_sku = "UNKNOWN_SKU") {
  
  $result = _extract_data_from_optimized_image_name($optimized_image, $dhh_sku);
  
  if($result === false) {
    $path = $optimized_image;
    if(function_exists("get_absolute_path")) {
      $path = get_absolute_path($optimized_image);
    }
    $msg = "{$dhh_sku} Failed to extract data from ".var_export($path, true).", was the image named correctly?";
    if(function_exists("logger")) {
      logger($msg, "NOTICE");
    } else {
      Mage::log($msg, null, "system.log", true);
    }
    if(function_exists("im")) {
      im("imgs_get_watermark_image_nok");
    }
    return false;
  }
  
  $supplier    = $result["supplier"];
  $sku         = $result["sku"];
  $nr          = $result["nr"];
  $type        = $result["type"];
  $hash        = $result["hash"];
  
  $extension   = pathinfo((string) $optimized_image, PATHINFO_EXTENSION);
  $hash        = substr(md5($nr.$sku.FILENAME_SECRET), 0, 4);
  $wm_path     = "{$supplier}-{$sku}-{$nr}-a-{$hash}.{$extension}";
  
  $msg = "{$dhh_sku} ".__FUNCTION__.": ".var_export(basename((string) $optimized_image), true)." => ".var_export($wm_path, true);
  if(function_exists("logger")) {
    logger($msg, "VERBOSE");
  } else {
    if(_dhh_debug()) {
      Mage::log($msg, null, "verbose.txt", true);
    }
  }
  
  if(function_exists("im")) {
    im("imgs_get_watermark_image_ok");
  }
  
  return $wm_path;
}














