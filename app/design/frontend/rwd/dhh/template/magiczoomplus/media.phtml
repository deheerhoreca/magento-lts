            if(!file_exists($baseDir.$magic360Image['file'])) {
                continue;
            }

            $bigImage = $magic360ImageHelper->init($magic360Image['file'])->__toString();

            //NOTE: for speed up (issue #75916)
            //$magic360Image['size'] = $magic360ImageHelper->getOriginalSizeArray();
