		//add mask
		jQuery('#billing-address input[title=BTW-nummer]').val('');
		jQuery('#billing-address input[title=BTW-nummer]').css('background-color','#E4E4E4');
		jQuery('#billing-address input[title=BTW-nummer]').attr('readonly','readonly');
}

jQuery('.clztoggleulx li > a').click(function(ev){
	ev.preventDefault();
	jQuery('.clztoggleulx span').hide();
	jQuery(this).next('span').fadeIn().css('display','block');
});

jQuery('#billing-address select[title=Land]').change(function(){
	var ct=jQuery(this).val();
	if(ct=='NL'){
		//add mask
		jQuery('#billing-address input[title=BTW-nummer]').val('');
		jQuery('#billing-address input[title=BTW-nummer]').css('background-color','#E4E4E4');
		jQuery('#billing-address input[title=BTW-nummer]').attr('readonly','readonly');
	}
	else{
		//remove mask
		jQuery('#billing-address input[title=BTW-nummer]').css('background-color','#FFFFFF');
		jQuery('#billing-address input[title=BTW-nummer]').removeAttr("readonly");
	}
});


jQuery('body.firecheckout-index-index  li#shipping-new-address-form fieldset ul li.wide div.input-box input[title=BTW-nummer]').parent().parent().hide();


