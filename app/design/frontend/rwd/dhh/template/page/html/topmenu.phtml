<?php

// ! getHtml() returns FALSE, avoid filled()/blank()

declare(strict_types=1);

$read_cache   = DeHeerHoreca_Fpc_Helper_Data::is_read_cache_enabled(true, true, "topmenu");
$write_cache  = DeHeerHoreca_Fpc_Helper_Data::is_write_cache_enabled(true, true, "topmenu");
$_html        = "";

if(!$read_cache) {
  $_html = (string) $this->getHtml("level-top");
} else {
  $_html = Mage::app()->getCache()->load(DHH_FPC_NAV_KEY);
  if(empty($_html)) {
    $_html = (string) $this->getHtml("level-top");
  } else {
    $write_cache = false; // No need to write if we read from cache
  }
}

if(!empty($_html)) {
  $_html = \Chefstore\Html::minifyHtml($_html);
}

if($write_cache && !empty($_html)) {
  DeHeerHoreca_Fpc_Helper_Data::saveToCacheDeferred(DHH_FPC_NAV_KEY, $_html, ["DHH_CMS"], 86400, minifyHtml: false);
  // Mage::app()->getCache()->save($_html, DHH_FPC_NAV_KEY, ["DHH_CMS"], 86400);
} ?>

