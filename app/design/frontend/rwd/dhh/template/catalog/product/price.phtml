              <span class="price-including-tax italic small">
                <span class="price">
                  <?php echo _fixPrice($_coreHelper->formatPrice($_finalPriceInclTax, false)) ?>
                </span>
              <span class="label">incl. btw</span>
              </span>
              <?php
            } ?>
          </div>
          <?php
        } else {
          ?>
          <div class="special-price">
            <span class="price-label"><?php echo $_specialPriceStoreLabel ?></span>
            <span class="price">
            <?php echo _fixPrice($_coreHelper->formatPrice($_finalPrice, false)) ?>
            </span>
          </div>
        <?php
        }

        // SHOW DISCOUNT IF >2%
        if($_discount_pct > 2 && $controller_name !== "category" && $controller_name !== "cart" && $controller_name !== "index") {
          echo _displayDiscount($_discount_abs_formatted, $_discount_pct_formatted, $_id.$this->getIdSuffix());
        }

        if($controller_name !== "category" && $controller_name !== "cart" && $controller_name !== "index") {
          echo _displayPriceDates($_store, $_special_price_from_date, $_special_price_to_date);
        }
      } 
    } /* if($_finalPrice == $_price): */

    /* CONTEXT 14 -- Volume discount */

    if($showMinPrice && $_minimalPriceValue && $_minimalPriceValue < $_convertedFinalPrice) {
      $debug_lines[] = "Context 14";
      $_minimalPriceDisplayValue = $_minimalPrice;
      if($_weeeTaxAmount && $_weeeHelper->typeOfDisplay($_product, [0, 1, 4])) {
        $_minimalPriceDisplayValue = $_minimalPrice + $_weeeTaxAmount;
      }

      if($this->getUseLinkForAsLowAs()) {
        echo "<a href='{$_product->getProductUrl()}' class='minimal-price-link'>";
      } else {
        echo "<span class='minimal-price-link'>";
      }
      ?>
      <span class='label'><?php echo $this->__("As low as:") ?></span>
      <span class='price hidden' id='product-minimal-price-<?php echo $_id.$this->getIdSuffix(); ?>'>
        <?php echo $_coreHelper->formatPrice($_minimalPriceDisplayValue, false); ?>
      </span>
      <?php
      if($this->getUseLinkForAsLowAs()) {
        echo "</a>";
      } else {
        echo "</span>";
      }
    }
    ?>
    </div>

  <?php

  /* CONTEXT: 15 -- Grouped Products */

  } else { /* if(!$_product->isGrouped()): */
    $debug_lines[] = "Context 15";

    if($showMinPrice && $_minimalPriceValue) {
      $_exclTax = $_taxHelper->getPrice($_product, $_minimalPriceValue);
      $_inclTax = $_taxHelper->getPrice($_product, $_minimalPriceValue, true);
      $price = $showMinPrice ? $_minimalPriceValue : 0;
    } else {
      $price = $_convertedFinalPrice;
      $_exclTax = $_taxHelper->getPrice($_product, $price);
      $_inclTax = $_taxHelper->getPrice($_product, $price, true);
    }

    if($price) {
      ?>
      <div class="price-box nowrap">
        <p<?php if($showMinPrice): ?> class="minimal-price"<?php endif ?>>
          <?php if($showMinPrice): ?>
            <span class="price-label"><?php echo $this->__('Starting at:') ?></span>
          <?php endif ?>
          <?php if($_taxHelper->displayBothPrices()) { ?>
            <span class="price-excluding-tax">
              <span class="label"><?php echo $this->helper('tax')->__('Excl. Tax:') ?></span>
              <span class="price">
                <?php echo _fixPrice($_coreHelper->formatPrice($_exclTax, false)) ?>
              </span>
            </span>
            <?php
            if($controller_name !== "category" && $controller_name !== "cart" && $controller_name !== "index") { ?>
              <span class="price-including-tax italic small">
                <span class="price">
                  <?php echo _fixPrice($_coreHelper->formatPrice($_inclTax, false)) ?>
                </span>
              <span class="label">incl. btw</span>
              </span>
              <?php
            }
          } else {
            $_showPrice = $_inclTax;
            if(!$_taxHelper->displayPriceIncludingTax()) {
              $_showPrice = $_exclTax;
            }
            ?>
            <span class="price" id="product-minimal-price-<?php echo $_id.$this->getIdSuffix(); ?>">
            <?php echo $_coreHelper->formatPrice($_showPrice, false) ?>
          </span>
          <?php } ?>
        </p>
      </div>
    <?php
    }
  }

