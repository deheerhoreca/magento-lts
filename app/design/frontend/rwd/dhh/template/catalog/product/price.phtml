if(function_exists('_fixPrice') === false) {
  function _fixPrice($price, $keep_sign = false) {
    if($keep_sign === false) {
      $price = str_replace(["€", "&nbsp;"], "", (string) $price);    // Remove euro symbol
    }
    $price = str_replace(",00", ",-", (string) $price);                // Trim zero cents
    $price = str_replace(".", "", $price);                    // Remove thousand separator
    $price = preg_replace("/(^\s+)|(\s+$)/us", "", $price);   // An utf8 trim()
    $price = strip_tags(trim((string) $price));
    
    return $price;
  }
}

if(function_exists('_displayMsrp') === false) {
  function _displayMsrp($msrp_formatted, $msrpStoreLabel, $id) {
    return "<div class='old-price'><span>{$msrpStoreLabel}: </span><span class='price strike' id='old-price-{$id}'>{$msrp_formatted}</span></div>";
  }
}

if(function_exists('_displayRegularPriceDuringSpecialPrice') === false) {
  function _displayRegularPriceDuringSpecialPrice($price_formatted) {
    return "<div class='my-2 old-price bit-bigger'><span>Normaal: </span><span class='price strike'>{$price_formatted}</span></div>";
  }
}

if(function_exists('_displayDiscount') === false) {
  function _displayDiscount($_discount_abs_formatted, $discount_perc, $id) {
    return "<div class='productdetail__discount'>Bespaar <span class=strong>{$_discount_abs_formatted}</span></div>";
  }
}

if(function_exists('_displayPriceDates') === false) {
  function _displayPriceDates($store, $_special_price_from_date, $_special_price_to_date) {
    
    if(empty($_special_price_to_date)) return null;
    
    if(Mage::app()->getLocale()->isStoreDateInInterval($store, $_special_price_from_date, $_special_price_to_date)) {
      setlocale(LC_TIME, "nl_NL");
      $_special_price_to_ts = strtotime((string) $_special_price_to_date);
      $display_date = strftime("%A %e %B", $_special_price_to_ts);
      return "<div class='special_price_dates pt-1'>SALE eindigt <strong>{$display_date}</strong></div>";
    }
    
    return null;
  }
}

