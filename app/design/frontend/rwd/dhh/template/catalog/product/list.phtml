/* CATEGORY HEADER & SEO */

if($carct && ($category === "category")) {
  $catid                = (int) $carct->getId();
  $category_name        = $carct->getName();
  $category_name        = Mage::helper("deheerhoreca_util/util")->cleanCategoryName($category_name);
  $category_name_lwr    = strtolower($category_name);
  $orig_category_desc   = $carct->getDescription();
  
  // Assemble category description
  if($have_active_filters === true || $on_first_page === false) {
    $category_desc      = "";
  }
  if(strlen($category_desc) < 5) {
    $category_desc      = "<h1>{$category_name}</h1>";
  }
  // In case of shop-by-brand, do not show another H1
  if(defined("CTDESC_H1_SENT") === true) {
    $category_desc = str_ireplace("h1>", "h2>", $category_desc);
  }
  
  if(empty($category_desc) === false) {
    if(strpos($category_desc, "<!--no_auto_desc-->") === false) {      
      $manufacturers = Mage::helper("deheerhoreca_util/util")->getBrandsPerCategory($catid);
      if($on_first_page === true && $have_active_filters === false && is_array($manufacturers) === true && sizeof($manufacturers) > 0) {
        $category_desc .= "<p>Chefstore.nl verkoopt o.a. ";
        $n = sizeof($manufacturers);
        $i = 0;
        foreach($manufacturers as $manufacturer) {
          if(strlen($manufacturer) < 3) continue;
          $category_desc .= "{$manufacturer} {$category_name_lwr}";
          $i++;
          if($i === $n-1) {
            $category_desc .= " en ";
          } elseif($i < $n) {
            $category_desc .= ", ";
          } else {
            $category_desc .= ".";
          }
        }
        $category_desc .= " Veelal uit voorraad en dus vaak binnen 24 of 48 uur al leverbaar.</p>";
      }
      
      if($on_first_page === true && $have_active_filters === false) {
        if(empty($_productCollection) === false
        && Mage::helper("deheerhoreca_util/util")->getAvgPrice($_productCollection) > 500) {
          $category_desc .= "Wij bieden u een breed assortiment keukenapparatuur voor de horeca keuken. Bekijk alle soorten {$category_name_lwr} in ons aanbod en bestel vandaag. Bijna alle items kunnen wij uit voorraad leveren en binnen 24 tot 48 uur leveren. Bij Chefstore.nl kunt u ook {$category_name_lwr} leasen. Wenst u meer informatie of hulp bij het kiezen van {$category_name_lwr} dan kunt u altijd contact opnemen via <a href='tel:+31850441003' title='Bel ons'>085-0441003</a>, <a href=\"javascript:\$zopim.livechat.window.show();\">chat</a> of <a href='mailto:sales@chefstore.nl' title='Bel ons'>e-mail</a>.</p>";
        } else {
          $category_desc .= "<p>Wij bieden u een breed assortiment keukenapparatuur voor de horeca keuken. Bekijk alle soorten {$category_name_lwr} in ons aanbod en bestel vandaag. Bijna alle items kunnen wij uit voorraad leveren en binnen 24 tot 48 uur leveren. Wenst u meer informatie of hulp bij het kiezen van {$category_name_lwr} dan kunt u altijd contact opnemen via <a href='tel:+31850441003' title='Bel ons'>085-0441003</a>, <a href=\"javascript:\$zopim.livechat.window.show();\">chat</a> of <a href='mailto:sales@chefstore.nl' title='Bel ons'>e-mail</a>.</p>";
        }
      }
    }
  }
  
  if(empty($category_desc) === false) {
    
    echo "<div class='ctdesc std' id='ctdesc'>";
    // Optionally cut off description and show a 'More' button    
    if(strpos($category_desc, "<!--no_more_btn-->") !== false || strlen($category_desc) < 1000) {
      echo "<div id='cat-text'>{$category_desc}</div>";
    } else {
      echo "<div id='cat-text' class='short'>{$category_desc}</div>";
      ?>
      <button id="toggle-cat-text"><i id="cat-btn-arrow" class="fa fa-arrow-down" aria-hidden="true"></i>&nbsp;<span>Lees meer</span></button>
      <script>
        jQuery(document).ready(function(){
          jQuery(document).on('click', '#toggle-cat-text', function(){
            if(jQuery('#cat-text').hasClass("short")) {
              jQuery('#ctdesc .short').addClass('full');
              jQuery('#ctdesc .short').removeClass('short');
              jQuery('#cat-btn-arrow').addClass('fa-arrow-up');
              jQuery('#cat-btn-arrow').removeClass('fa-arrow-down');
              jQuery('#toggle-cat-text span').html('Minder');
            } else {
              jQuery('#ctdesc .full').addClass('short');
              jQuery('#ctdesc .full').removeClass('full');
              jQuery('#cat-btn-arrow').addClass('fa-arrow-down');
              jQuery('#cat-btn-arrow').removeClass('fa-arrow-up');
              jQuery('#toggle-cat-text span').html('Meer');
            }
          });
        });
      </script>
      <?php
    }
    echo "</div>";
  }
}

/* SUBCATEGORIES */

$appliedFilters = Mage::getSingleton("catalog/layer")->getState()->getFilters();
if(empty($carct) === false && $amschk !== "amshopby"
&& empty($appliedFilters) === true && strpos($orig_category_desc, "<!--no_cat_tiles-->") === false) {
  
  // Slow
  $subcategories = Mage::getModel("catalog/category")->getCategories($carct->getId(), 0, true);
  
  $subcategories = $carct->getCollection()
    ->addIdFilter($carct->getChildren())
    ->addAttributeToFilter("is_active", 1)
    ->addAttributeToSelect("url_key")
    ->addAttributeToSelect("name")
    ->addAttributeToSelect("all_children")
    ->addAttributeToSelect("is_anchor")
    ->setOrder("position", Varien_Db_Select::SQL_ASC)
    ->joinUrlRewrite();
  $subcategories->addAttributeToSelect("image");
  
  if($subcategories->getFirstItem()) {
    
    echo "<ul class='grid-shadow-tiles-text'>";
    
    // Logic copied to amasty/amshopby/subcategories.phtml
    $category_thumbs_dimensions = $category_thumbs_dimensions * 1.5;
    
    foreach($subcategories as $subcategory) {
      if(in_array($subcategory->getId(), EXCLUDED_CATEGORY_IDS) !== false) {
        continue;
      }
      // if(_dhh_debug()) {
        // var_dump($subcategory->getId());
      // }
      $haschild           = true;
      // Slow: $subcategory         = Mage::getModel("catalog/category")->load($subcategory->getId());
      $category_name      = Mage::helper("deheerhoreca_util/util")->cleanCategoryName($subcategory->getName());
      $category_name_safe = htmlspecialchars($category_name);
      $image              = $subcategory->getImage();
      $category_url       = $subcategory->getUrl();
      $img_path           = "{$media_path}/catalog/category/{$image}";
      $resized_img_name   = $category_thumbs_dimensions."_{$subcategory->getId()}.".pathinfo($img_path, PATHINFO_EXTENSION);;
      $resized_img_path   = Mage::getBaseDir(Mage_Core_Model_Store::URL_TYPE_MEDIA).DS."catalog/category/resized".DS.$resized_img_name;
      $resized_img_url    = Mage::getBaseUrl(Mage_Core_Model_Store::URL_TYPE_MEDIA)."catalog/category/resized".DS.$resized_img_name;
      
      if(is_file($resized_img_path) === false && is_file($img_path) === true) {
        $imageObj = new Varien_Image($img_path);
        $imageObj->constrainOnly(true);
        $imageObj->keepAspectRatio(true);
        $imageObj->keepFrame(true);
        $imageObj->backgroundColor(array(255,255,255));
        $imageObj->resize($category_thumbs_dimensions, $category_thumbs_dimensions);
        $imageObj->save($resized_img_path);
      }
      echo "<li style='max-width: 180px;'><a href='{$category_url}' title='{$category_name_safe}'>";
      if(empty($image) === false) {
        echo "<img class='lazy trans-opacity' data-src='{$resized_img_url}' alt='Bekijk {$category_name}' title='Bekijk {$category_name}' 
        height='{$category_thumbs_dimensions}' width='{$category_thumbs_dimensions}'>";
      }
      echo "<strong>{$category_name}</strong></a></li>";
    }
    echo "</ul>";
    if($haschild === true) {
      echo "<style>#sidebar-nav {display: block;}</style>";
    }
  }
}

// Optional block category-ID is shown below the category tiles
echo $category_block_html;

/* LIST PRODUCTS */

if($show_products === true && $_productCollection->getFirstItem()) {
  echo "<div class='category-products'>";
    if($show_toolbar === true) {
      echo "<div class='top_toolbar'>{$this->getToolbarHtml()}</div>";
    }
    echo "<ul class='products-grid products-grid--max-{$_columnCount}-col'>";
    $i = 0;
    foreach($_productCollection as $_product) {
      // $hideQuoteButton = Mage::helper("qquoteadv")->hideQuoteButton($_product);
      $i++;
      $html = null;
      
      $productUrl = false;
      // If a product is present in multiple categories, we don't want to change that in this view
      // This function does a best guess
      // $productUrl = Mage::helper("deheerhoreca_util/util")->getFullProductUrlFromRewrites($_product);
      if($productUrl === false) {
        $productUrl = $_product->getProductUrl(); // Fallback
      }
      
      // @todo fix this? want to show the product link under the current category, and not link to another category
      // if(_dhh_debug()) {
        // // printr($catid);
        // $_category = Mage::getModel('catalog/category')->load($catid);
        // printr(get_class($_category));
        // if (!$_category instanceof Mage_Catalog_Model_Category) {
          // echo "bier";
        // }
        // // printr($_product->getUrlPath($_product, $_category));
      // }
      
      $price_html           = $this->getPriceHtml($_product, true); // ListView version
      //$price_html           = $productBlock->getPriceHtml($_product, true); // FeaturedProdcts version
      $finalPrice           = (float) $_product->getFinalPrice();
      
      $stock_data           = Mage::helper("deheerhoreca_util/util")->getStockInfo($_product, "listview");
      
      $stock_message        = $stock_data["stock_message"];
      $stock_class          = $stock_data["txtcltcz"];
      $stock_qty            = $stock_data["stock_qty"];
      $in_stock             = $stock_data["in_stock"];
      $backorders           = $stock_data["backorders"];
      $saleable             = $stock_data["saleable"];
      $eol                  = $stock_data["eol"];
      $eol_replacement_sku  = $stock_data["eol_replacement_sku"];
      $manage_stock         = $stock_data["manage_stock"];
      $extra_delivery_time  = $stock_data["extra_delivery_time"];
      $overall_stock_status = $stock_data["overall_stock_status"];
      $txtstockdate         = $stock_data["txtstockdate"];
      $levertijd            = $stock_data["levertijd"];
      
      $additional_delivery_messages = null;
      
      switch($overall_stock_status) {
        case "in_stock":
          if($finalPrice >= $freeshipping_from) {
            $additional_delivery_messages .= "<br /><span class='buyblock-usp' style='line-height: 1.5em;'><strong>Gratis</strong> bezorgd</span>";
          }
          break;
        case "backorder":
          if($finalPrice >= $freeshipping_from) {
            $additional_delivery_messages .= "<br /><span class='buyblock-usp' style='line-height: 1.5em;'><strong>Gratis</strong> bezorgd</span>";
          }
          $stock_class = "buyblock-usp";
          break;
      }
      
      $brand            = _get_product_attribute($_product, "manufacturer");
      $sku_seller       = _get_product_attribute($_product, "sku_seller");
      $tagline          = _get_product_attribute($_product, "tagline");
      
      $usp_options      = [
        "context"         => "listview",
        "category_name"   => $category_name,
      ];
      $usps             = Mage::helper("deheerhoreca_util/util")->getProductUsps($_product, $usp_options, 8);
      
      // Price Block
      $price_html       = str_replace(",00", ",-", $price_html);
      $price_html       = str_replace("€", null, $price_html);
      
      // Black friday
      if($show_black_friday === true && ($overall_stock_status === "in_stock" || $overall_stock_status === "backorder")) {
        $html .= "<span class='bf-banner-list'></span>";
      } else {
        // Product label
        $productlabel = Mage::helper("deheerhoreca_util/util")->auto_productlabel($_product, "list");
        if(isset($productlabel) === true) {
          $html .= "<span class='lblprolist'>{$productlabel}</span>";
        }
      }
      
      // Package quantity
      $value = intval(_get_product_attribute($_product, "eenheid"));
      if($value > 1) {
        $html .= "<span class='product-label-right white bg-blue border-blue border-1'>{$value} X</span>";
      }

      // Energy rating
      $value = _get_product_attribute($_product, "energy_efficiency_class_a_g");
      if(empty($value) === false) {
        $enclz = "";
        switch ($value) {
          case "A":     $enclz = "enrgclz1";  break;
          case "B":     $enclz = "enrgclz2";  break;
          case "C":     $enclz = "enrgclz3";  break;
          case "D":     $enclz = "enrgclz4";  break;
        }
        if($enclz !== "") {
          $html .= "<span class='lblenergylabel {$enclz}' title='Energielabel {$value}'>{$value}</span>";
        }
      }
      
      // Product name
      $product_name = $product_long_name = $_helper->productAttribute($_product, $_product->getName(), 'name');
      ?>
      <li class="item<?php if(($i - 1) % $_columnCount === 0) { ?> first<?php } elseif($i % $_columnCount === 0) { ?> last<?php } ?>">
        <?php
        echo $html;
        $title = $product_long_name;
        ?>
        <a href="<?php echo $productUrl; ?>" title="<?php echo $title; ?> details" class="product-image">
        <?php
          echo "<img class='lazy trans-opacity' id='product-collection-image-{$_product->getId()}'
            data-src='{$this->helper('catalog/image')->init($_product, 'small_image')->resize($_imgSize)}'
            alt='{$this->stripTags($this->getImageLabel($_product, 'small_image'), null, true)}'
            width='{$displaySize}' height='{$displaySize}' />";
        ?>
        </a>
        <div class="product-info">
          <div class="info">
            <span class="brand-name small fw-600 gray"><?php echo "{$brand} <span class=light-gray>{$sku_seller}</span>"; ?></span>
            <h2 class="product-name ellipsed ellipsed-2">
              <a href='<?php echo $productUrl; ?>' title='<?php echo $product_long_name; ?> details'><?php echo $product_name; ?></a>
            </h2>
            <?php
            if($this->getChild("name.after")) {
              $_nameAfterChildren = $this->getChild("name.after")->getSortedChildren();
              foreach ($_nameAfterChildren as $_nameAfterChildName) {
                $_nameAfterChild = $this->getChild("name.after")->getChild($_nameAfterChildName);
                $_nameAfterChild->setProduct($_product);
                echo $_nameAfterChild->toHtml();
              }
            }
            
            if(isset($tagline) === true) {
              echo "<div class='product-list-tagline'>{$tagline}</div>";
            }
            
            if(empty($usps) === false) {
              echo "<ul class='product-list-highlights inline-list'>";
              foreach($usps as $usp) {
                echo "<li>{$usp}</li>";
              }
              echo "</ul>";
            }
            
            // Volume discount tag
            if(empty($_product->getTierPrice()) === false) {
              echo "<span class='small' style='line-height: 2em;'>
                <i class='fa fa-eur' aria-hidden='true'></i>&nbsp;<em>Volumekorting</em></span>";
            }
            ?>
          </div>
          <?php
          echo $price_html;
          ?>
          <div class="actions">
            <?php
            if(!$_product->canConfigure()) {
              if($_product->isSaleable()) {
                // Simple product, sellable
                ?>
                <div class="float-left">
                  <span class="<?php echo $stock_class; ?>" style='line-height: 1.5em;'><?php echo $stock_message; ?></span>
                  <?php echo $additional_delivery_messages; ?>
                </div>
                <button type="button" title="<?php echo $this->quoteEscape($this->__('Add to Cart')) ?>" class="button btn-cart" onclick="setLocation('<?php echo $this->getAddToCartUrl($_product) ?>')"><i class="fa fa-shopping-cart"></i></button>
                <?php
              } else {
                // Simple product, not sellable
                ?>
                <div class="float-left">
                  <span class="<?php echo $stock_class; ?>" style='line-height: 1.5em;'><?php echo $stock_message; ?></span>
                  <?php echo $additional_delivery_messages; ?>
                </div>
                <a title="<?php echo $this->quoteEscape($this->__("Details")) ?>" class="button btn-cart" href="<?php echo $_product->getProductUrl() ?>" style="padding-top: 5px;"><i class="fa fa-info-circle"></i></a>
                <?php
              }
            } else {
              // Configurable product
              ?>
              <div class="float-left">
                <span class="buyblock-usp" style='line-height: 1.5em;'>Meerdere varianten</span>
                <?php echo $additional_delivery_messages; ?>
              </div>
              <a title="<?php echo $this->quoteEscape($this->__("Details")) ?>" class="button btn-cart" href="<?php echo $_product->getProductUrl() ?>" style="padding-top: 5px;"><i class="fa fa-info-circle"></i></a>
            <?php } ?>
          </div>
        </div>
      </li>

      <?php
      if(($i === $_columnCount || ($i - $_columnCount) % ($_columnCount*2) === 0)) { ?>
        </ul>
          <div class="new-tab-contant-text mobile-hide">
            <div class="col-md-3 new-contant">
              <p><i class="fa fa-check"></i>Altijd de beste prijs</p>
              <p><i class="fa fa-check"></i>Advies door professionals</p>
            </div>
            <div class="col-md-3 new-contant">
              <p><i class="fa fa-check"></i>Wij vergelijken de prijzen</p>
              <p><i class="fa fa-check"></i>Gratis verzending vanaf &euro;150,-</p>
            </div>
            <div class="col-md-3 new-contant">
              <p><i class="fa fa-check"></i>Professionele apparatuur</p>
              <p><i class="fa fa-check"></i>Snelle levering</p>
            </div>
          </div>
        <ul class="products-grid products-grid--max-<?php echo $_columnCount; ?>-col">
        <?php
      }
    }
    ?>
    </ul>
    <?php
    if($show_toolbar === true) {
      echo "<div class='toolbar-bottom'>{$this->getToolbarHtml()}</div>";
    }
    ?>
