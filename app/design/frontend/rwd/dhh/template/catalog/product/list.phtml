<?php
/**
 * Product list template
 *
 * @see Mage_Catalog_Block_Product_List
 */
/* @var $this Mage_Catalog_Block_Product_List */

$_productCollection           = $this->getLoadedProductCollection();
$_helper                      = $this->helper('catalog/output');
$category                     = $this->getRequest()->getControllerName();
$catid                        = null;
$carct                        = Mage::registry('current_category');
$amschk                       = $this->getRequest()->getRouteName();
$haschild                     = false;
$short_name_cats              = [10, 119, 434, 174, 24, 38, 23, 104, 3, 544];
$short_name_parent_cats       = [3];
$max_product_info_items       = 3;
$max_product_highlight_items  = 6;
$category_thumbs_dimensions   = 140;
$parent_categories_ids        = [];
$freeshipping_from            = (float) Mage::getStoreConfig("carriers/freeshipping/free_shipping_subtotal");

/*
 * Bug fix: Using require_stock_items there was a bug that lead
 * to wrong stock info on listview during flat index rebuild.
 * addItemsToProducts() seems to add stock data correctly even during a reindex
 *
 * However, with addItemsToProducts() we are missing essential stock data like
 * manage_stock, leading to wrong results.
 *
 * We now use both as an experiment...
 */
$_productCollection->setFlag('require_stock_items', true);
Mage::getModel('catalogInventory/stock')->addItemsToProducts($_productCollection);

/*
 * If the sorting is by position, put the recommended products on top
 * http://www.rob-st.com/2016/11/29/sort-magento-category-multiple-values-keep-newest-products-top/
 */

$currentOrder = $this->getChild('toolbar')->getCurrentOrder();
$currentDirection = $this->getChild('toolbar')->getCurrentDirection();

if($currentOrder === "position") {
  $query = $_productCollection->getSelect()->__toString();
  if(strstr($query, "tagline") !== false) { // if somehow this field is not there
    $sortByRcm  = "IF(e.tagline = '' OR e.tagline IS NULL, 1, 0) ASC";
    $_productCollection->getSelect()->reset(Zend_Db_Select::ORDER);
    $_productCollection->getSelect()->order(new Zend_Db_Expr($sortByRcm));
    $_productCollection->getSelect()->order($currentOrder.' '.$currentDirection);
    
    // if($_SERVER["REMOTE_ADDR"] === "185.127.111.251" && isset($_GET['nofpc'])) {
      // printr($_productCollection->getSelect()->__toString());
    // }
     
    // Collection was loaded already...reloading...(yeah I know)
    $_productCollection->clear();
    $_productCollection->load();
  }
}

$_collectionSize = $_productCollection->count();

/* CATEGORY HEADER & SEO */

$current_page_nr = Mage::app()->getRequest()->getParam('p');
$on_first_page = (empty($current_page_nr) === false && $current_page_nr > 1) ? false : true;

if($carct && ($category === 'category')) {
  $parent_categories  = $carct->getParentCategories();
  $catid              = (int) $carct->getId();
  $category_desc      = $carct->getDescription();
  $category_name      = $carct->getName();
  $category_name      = str_replace("[V] ", null, $category_name);
  if(strlen($category_desc) < 5) {
    $category_desc      = "<h1>{$category_name}</h1>";
  }
  $category_name_lwr  = strtolower($category_name);
  
  foreach($parent_categories as $parent) {
    $parent_categories_ids[] = (int) $parent->getEntityId();
  }
  $parent_categories_ids[] = $catid;
  
  // In case of shop-by-brand, do not show another H1
  if(defined("CTDESC_H1_SENT") === true) {
    $category_desc = str_ireplace("h1>", "h2>", $category_desc);
  }

  echo "<div class='ctdesc std' id='ctdesc'>";
  if(empty($category_desc) === false) {

    /* Augment category description */
    
    if(strstr($category_desc, "<!--no_auto_desc-->") === false) {
    
      $manufacturers = Mage::helper("deheerhoreca_util/util")->getBrandsPerCategory($catid);
      if($on_first_page === true && is_array($manufacturers) === true && sizeof($manufacturers) > 0) {
        $category_desc .= "<p>Chefstore.nl verkoopt o.a. ";
        $n = sizeof($manufacturers);
        $i = 0;
        foreach($manufacturers as $manufacturer) {
          if(strlen($manufacturer) < 3) continue;
          $category_desc .= "{$manufacturer} {$category_name_lwr}";
          $i++;
          if($i === $n-1) {
            $category_desc .= " en ";
          } elseif($i < $n) {
            $category_desc .= ", ";
          } else {
            $category_desc .= ".";
          }
        }
        $category_desc .= " Veelal uit voorraad en dus vaak binnen 24 of 48 uur al leverbaar.</p>";
      }
      
      if($on_first_page === true) {
        if(Mage::helper("deheerhoreca_util/util")->getAvgPrice($_productCollection) > 500) {
          $category_desc .= "Wij bieden u een breed assortiment keukenapparatuur voor de horeca keuken. Bekijk alle soorten {$category_name_lwr} in ons aanbod en bestel vandaag. Bijna alle items kunnen wij uit voorraad leveren en binnen 24 tot 48 uur leveren. Bij Chefstore.nl kunt u ook {$category_name_lwr} leasen. Wenst u meer informatie of hulp bij het kiezen van {$category_name_lwr} dan kunt u altijd contact opnemen via <a href='tel:+31850441003' title='Bel ons'>085-0441003</a>, <a href=\"javascript:\$zopim.livechat.window.show();\">chat</a> of <a href='mailto:service@chefstore.nl' title='Bel ons'>e-mail</a>.</p>";
        } else {
          $category_desc .= "<p>Wij bieden u een breed assortiment keukenapparatuur voor de horeca keuken. Bekijk alle soorten {$category_name_lwr} in ons aanbod en bestel vandaag. Bijna alle items kunnen wij uit voorraad leveren en binnen 24 tot 48 uur leveren. Wenst u meer informatie of hulp bij het kiezen van {$category_name_lwr} dan kunt u altijd contact opnemen via <a href='tel:+31850441003' title='Bel ons'>085-0441003</a>, <a href=\"javascript:\$zopim.livechat.window.show();\">chat</a> of <a href='mailto:service@chefstore.nl' title='Bel ons'>e-mail</a>.</p>";
        }
      }
    }
    
    /* Optionally cut off description and show a 'More' button */
    
    if(strstr($category_desc, "<!--no_more_btn-->") !== false || strlen($category_desc) < 1000) {
      echo "<div id='cat-text'>{$category_desc}</div>";
    } else {
      echo "<div id='cat-text' class='short'>{$category_desc}</div>";
      ?>
      <button id="toggle-cat-text"><i id="cat-btn-arrow" class="fa fa-arrow-down" aria-hidden="true"></i>&nbsp;<span>Lees meer</span></button>
      <script>
        jQuery(document).ready(function(){
          jQuery(document).on('click', '#toggle-cat-text', function(){
            if(jQuery('#cat-text').hasClass("short")) {
              jQuery('#ctdesc .short').addClass('full');
              jQuery('#ctdesc .short').removeClass('short');
              jQuery('#cat-btn-arrow').addClass('fa-arrow-up');
              jQuery('#cat-btn-arrow').removeClass('fa-arrow-down');
              jQuery('#toggle-cat-text span').html('Minder');
            } else {
              jQuery('#ctdesc .full').addClass('short');
              jQuery('#ctdesc .full').removeClass('full');
              jQuery('#cat-btn-arrow').addClass('fa-arrow-down');
              jQuery('#cat-btn-arrow').removeClass('fa-arrow-up');
              jQuery('#toggle-cat-text span').html('Lees meer');
            }
          });
        });
      </script>
      <?php
    }
  }
  echo "</div>";
}

/* SUBCATEGORIES */

if(empty($carct) === false && $amschk !== 'amshopby') {

  $media_path       = Mage::getBaseDir('media');
  $subcategories    = Mage::getModel('catalog/category')->getCategories($carct->getId(), 0, true);
  
  if(sizeof($subcategories) > 0) {
    ?>
    <h3>Populair</h3>
    <ul class="grid-shadow-tiles-text">
    <?php
    // Logic copied to amasty/amshopby/subcategories.phtml
    $category_thumbs_dimensions = $category_thumbs_dimensions * 1.5;
    
    foreach($subcategories as $category) {
      $haschild         = true;
      $category         = Mage::getModel('catalog/category')->load($category->getId());
      $categoryName     = str_replace("[V] ", null, $category->getName());
      $image            = $category->getImage();
      $img_path         = "{$media_path}/catalog/category/{$image}";
      $resized_img_name = $category_thumbs_dimensions."_{$category->getId()}.".pathinfo($img_path, PATHINFO_EXTENSION);;
      $resized_img_path = Mage::getBaseDir(Mage_Core_Model_Store::URL_TYPE_MEDIA).DS."catalog/category/resized".DS.$resized_img_name;
      $resized_img_url  = Mage::getBaseUrl(Mage_Core_Model_Store::URL_TYPE_MEDIA)."catalog/category/resized".DS.$resized_img_name;
      
      // if($_SERVER["REMOTE_ADDR"] === "185.127.111.251" && isset($_GET['nofpc'])) {
        // echo "<pre>";
        // echo sizeof($subcategories);
        // printr($categoryName);
        // echo "</pre>";
      // }
      
      if(empty($image) === false && is_file($resized_img_path) !== true && is_file($img_path) === true) {
        $imageObj = new Varien_Image($img_path);
        $imageObj->constrainOnly(true);
        $imageObj->keepAspectRatio(true);
        $imageObj->keepFrame(true);
        $imageObj->backgroundColor(array(255,255,255));
        $imageObj->resize($category_thumbs_dimensions, $category_thumbs_dimensions);
        $imageObj->save($resized_img_path);
      }
      ?>
      <li style='max-width: 180px;'>
        <a href="<?php echo $category->getUrl() ?>" title='<?php echo $categoryName; ?>'>
          <?php
          if(empty($image) === false) {
            echo "<img class='lazy trans-opacity' data-src='{$resized_img_url}' alt='Bekijk {$categoryName}' title='Bekijk {$categoryName}' 
            height='".($category_thumbs_dimensions)."' width='".($category_thumbs_dimensions)."' />";
          }
          ?>
          <strong><?php echo $categoryName; ?></strong>
        </a>
      </li>
      <?php
    }
    echo "</ul>";
    if($haschild === true) {
      echo "<style>#sidebar-nav {display: block;}</style>";
    }
  }
}

/* CHILD CATEGORY, SHOW PRODUCTS */

//if($catid === 4 || ($amschk === 'amshopby' || ($haschild === false || $catid === 544))) {
if($_collectionSize > 0) {
?>
  <div class="category-products">
    <div class="top_toolbar"><?php echo $this->getToolbarHtml() ?></div>
    <?php
    $_columnCount   = 4;
    $displaySize    = 200;
    $_imgSize       = 1 * $displaySize;
    
    echo "<ul class='products-grid products-grid--max-{$_columnCount}-col'>";
    
    $i = 0;
    foreach($_productCollection as $_product) {
      $i++;
      $html = null;
      
      $productUrl = false;
      // If a product is present in multiple categories, we don't want to change that in this view
      //$productUrl = Mage::helper("deheerhoreca_util/util")->getFullProductUrlFromRewrites($_product);
      if($productUrl === false) {
        $productUrl = $_product->getProductUrl(); //fallback
      }
      
      $price_html           = $this->getPriceHtml($_product, true);
      $finalPrice           = (float) $_product->getFinalPrice();
      
      $stock_data           = Mage::helper("deheerhoreca_util/util")->getStockInfo($_product);
      
      $stock_message        = $stock_data["stock_message"];
      $stock_class          = $stock_data["txtcltcz"];
      $stock_qty            = $stock_data["stock_qty"];
      $in_stock             = $stock_data["in_stock"];
      $backorders           = $stock_data["backorders"];
      $saleable             = $stock_data["saleable"];
      $eol                  = $stock_data["eol"];
      $eol_replacement_sku  = $stock_data["eol_replacement_sku"];
      $manage_stock         = $stock_data["manage_stock"];
      $extra_delivery_time  = $stock_data["extra_delivery_time"];
      $overall_stock_status = $stock_data["overall_stock_status"];
      $txtstockdate         = $stock_data["txtstockdate"];
      $levertijd            = $stock_data["levertijd"];
      
      $additional_delivery_messages = null;
      
      switch($overall_stock_status) {
        case "in_stock":
          if($finalPrice >= $freeshipping_from) {
            $additional_delivery_messages .= "<br /><span class='buyblock-usp' style='line-height: 1.5em;'><strong>Gratis</strong> bezorgd</span>";
          }
          break;
        case "backorder":
          if($finalPrice >= $freeshipping_from) {
            $additional_delivery_messages .= "<br /><span class='buyblock-usp' style='line-height: 1.5em;'><strong>Gratis</strong> bezorgd</span>";
          }
          $stock_class = "buyblock-usp dark-color";
          $stock_message = "Op nabestelling";
          break;
        case "not_sellable":
          $stock_message = "Niet op voorraad";
        case "eol":
          break;
      }
      
      $energy_rating  = $_product->getAttributeText('energieklasse');
      $productlabel   = $_product->getProductLabel();
      $gnvalue        = $_product->getAttributeText("gn"); // can be an array if multiselect
      $tagline        = $_product->getTagline();
      
      /* Listview Info */
      $product_info   = [];
              
      

      if($catid === 72) {
        $attribute_value = $_product->getInhoudAantalGn();
        if($attribute_value !='') {
          $product_info[] = "{$attribute_value} x {$gnvalue}";
        }
      }
      
      /* Listview USPs */
      
      $usps = [];
      
      $width          = ($_product->getBreedte() + 0) / 10;
      $height         = ($_product->getHoogte()  + 0) / 10;
      $depth          = ($_product->getDiepte()  + 0) / 10;
      
      if($width  > 10) $width  = round($width);
      if($depth  > 10) $depth  = round($depth);
      if($height > 10) $height = round($height);
      
      if($width > 0 && $height > 0 && $depth > 0) {
        // $usps[] = "B: {$width}cm D: {$depth}cm H: {$height}cm";
      } else {
        $width = $_product->getBreedte();
        if($width != '' && $width > 0) {
          // $usps[] = "Breedte: ".($width/10)."cm";
        }
      }
      
      $attribute_value = $_product->getData('diameter_mm');
      if($attribute_value != ''){
        $usps[] = "Ø {$attribute_value} mm";
      }
      
      // Length
      $code = "length_mm";
      $attribute_value = $_product->getResource()->getAttribute($code)->getFrontend()->getValue($_product);
      if($attribute_value != ''){
        $usps[] = "Ø {$attribute_value} mm";
      }
      
      // Quantity
      $attribute_value = (int) $_product->getData('eenheid');
      if($attribute_value > 1) {
        $usps[] = "{$attribute_value} stuks";
      }
      
      // Size
      $attribute_value = $_product->getAttributeText('size');
      if(is_scalar($attribute_value) && strlen($attribute_value) > 0) {
        $usps[] = "Maat: {$attribute_value}";
      }
      
      // Material
      $attribute_value = $_product->getResource()->getAttribute('material_group')->getFrontend()->getValue($_product);
      if(strlen($attribute_value) > 0) {
        foreach(explode(",", $attribute_value) as $value) {
          $value = str_ireplace(["(Roestvast staal)"], null, $value);
          $usps[] = trim($value);
        }
      }
      
      /* Uitvoering */
      $attribute_value = $_product->getAttributeText('uitvoering');
      if(is_array($attribute_value) === true) {
        $attribute_value = implode(", ", $attribute_value);
      }
      if(is_scalar($attribute_value) === true && strlen($attribute_value) > 0) {
        $usps[] = $attribute_value;
      }
      
      $attribute_value = $_product->getAttributeText('type_koeling');
      if(empty($attribute_value) === false){
        $usps[] = $attribute_value;
      }
      
      /* Blikjes */
      $attribute_value = (int) $_product->getData("aantal_blikjes");
      if($attribute_value > 0) {
        $usps[] = "{$attribute_value}x 33cl";
      }
      
      /* Flessen */
      $attribute_value = (int) $_product->getData("aantal_flessen");
      if($attribute_value > 0) {
        $usps[] = "{$attribute_value} flessen";
      }
      
      /* Capacity: Wine Bottels */
      $attribute_value = (int) $_product->getData("capacity_wine_bottles");
      if($attribute_value > 0) {
        $usps[] = "{$attribute_value} flessen";
      }
      
      /* GN maat if not in a GN category */
      if(empty($gnvalue) === false
        && empty($category_name) === false
        && strstr($category_name, "GN") === false) {
          if(is_array($gnvalue)) {
            $gnvalue = implode(" ", $gnvalue);
          }
          $usps[] = "{$gnvalue} GN";
      }
      
      /* Custom highlights */
      $attribute_value = $_product->getData("custom_highlights");
      $parts = explode(",", $attribute_value);
      if(sizeof($parts) > 0) {
        foreach($parts as $part) {
          $part = trim($part);
          if(strlen($part) > 0) {
            $usps[] = trim($part);
          }
        }
      }            
      
      /* Inhoud */
      $attribute_value = $_product->getInhoudLiters();
      if(strlen($attribute_value) > 0) {
        $usps[] = round($attribute_value, 2)." liter";
      }
      
      $power_usp_done = false;
      
      /* Total Power */
      if(in_array(3, $parent_categories_ids) === false) { // skip "Koelingen" and everything underneath
        $attribute_value = $_product->getData("total_power_watt");
        
        if(empty($attribute_value) === false) {
          if($attribute_value  >= 5000) {
            $attribute_value   /= 1000;
            $attribute_value    = number_format($attribute_value, 2, ",", ".");
            $usps[] = "{$attribute_value} kW";
          } else {
            $attribute_value = (int) number_format($attribute_value, 0, ",", "");
            $usps[] = "{$attribute_value} W";
          }
          $power_usp_done = true;
        }
      }
      
      /* Electrical Power */
      if($power_usp_done !== true && in_array(3, $parent_categories_ids) === false) { // skip "Koelingen" and everything underneath
        $attribute_value = $_product->getVermogen();
        if(empty($attribute_value) === false) {
          if($attribute_value < 3) {
            $attribute_value *= 1000;
            $usps[] = "{$attribute_value} Watt";
          } else {
            //$attribute_value = str_replace(".", null, $attribute_value);
            //$attribute_value = str_replace(",", ".", $attribute_value);
            $attribute_value = number_format($attribute_value, 1, ",", ".");
            $attribute_value = str_replace(",0", null, $attribute_value);
            $usps[] = "{$attribute_value} kW";
          }
        }
      }
      
      /* Gas Power */
      $attribute_value = $_product->getVermogenKw();
      if($power_usp_done !== true && empty($attribute_value) === false) {
        if($attribute_value < 3) {
          $attribute_value *= 1000;
          $usps[] = "{$attribute_value} Watt";
        } else {
          $attribute_value = number_format($attribute_value, 1, ",", ".");
          $attribute_value = str_replace(",0", null, $attribute_value);
          $usps[] = "{$attribute_value} kW";
        }
      }
      
      /* M3/hour capacity */
      $attribute_value = $_product->getAantalM3Uur();
      if(strlen($attribute_value) > 0) {
        $usps[] = round($attribute_value, 2)." m3/UUR";
      }
      
      /* Warranty */
      $attribute_value = $_product->getAttributeText('garantie');
      if($attribute_value === "24 maanden") {
        $usps[] = "24M Garantie";
      }
      
      /* Cooling Zones */
      $attribute_code = "number_of_cooling_zones";
      $attribute_value = (int) $_product->getResource()->getAttribute($attribute_code)->getFrontend()->getValue($_product);
      if($attribute_value === 2) {
        $usps[] = "Dual-Zone";
      } elseif($attribute_value === 3) {
        $usps[] = "Triple-Zone";
      } elseif($attribute_value > 3) {
        $usps[] = "{$attribute_value} Zones";
      }
      
      /* Cooking Zones */
      $attribute_value = $_product->getCookingZones();
      if(strlen($attribute_value) > 0 && (double) $attribute_value > 1) {
        $usps[] = round($attribute_value, 2)." Zones";
      }
      
      /* Aftap */
      $attribute_value = $_product->getAttributeText('aftap');
      if($attribute_value === "Ja") {
        $usps[] = "Met Aftap";
      }
      
      /* Afsluitbaar */
      $attribute_value = $_product->getAttributeText("afsluitbaar");
      if($attribute_value === "Ja") {
        $usps[] = "Afsluitbaar";
      }
      
      /* ------------------------------------- */
      
      /* Price Block */
      $price_html = str_replace(",00", ",-", $price_html);
      $price_html = str_replace("€", null, $price_html);
      
      /* Automatic Label: Product */
      if(isset($productlabel) === true) {
        $html .= "<span class=\"lblprolist\">{$productlabel}</span>";
      }

      /* Automatic Label: Energy */
      if(isset($energy_rating) === true) {
        $enclz = null;
        switch ($energy_rating) {
          case 'A++++': $enclz = 'enrgclz1';  break;
          case 'A+++':  $enclz = 'enrgclz2';  break;
          case 'A++':   $enclz = 'enrgclz3';  break;
          case 'A+':    $enclz = 'enrgclz4';  break;
          case 'A':     $enclz = 'enrgclz5';  break;
          case 'B':     $enclz = 'enrgclz6';  break;
          default: break;
        }
        if(isset($enclz) === true) {
          $html .= "<span class='lblenergylabel {$enclz}' title='Energielabel {$energy_rating}'>{$energy_rating}</span>";
        }
      }
      
      /* Product name */
      $product_name = $_helper->productAttribute($_product, $_product->getName(), 'name');
      if(in_array($catid, $short_name_cats)) {
        $product_name = $_product->getData("name_short");
      } elseif(!empty(array_intersect($parent_categories_ids, $short_name_parent_cats))) {
        $product_name = $_product->getData("name_short");
      }
      
      // if($_SERVER["REMOTE_ADDR"] === "85.144.117.179" && isset($_GET['nofpc'])) {
        // printr($parent_categories_ids);
        // printr($short_name_parent_cats);
        // printr($product_name);
      // }
      
      ?>
      <li class="item<?php if(($i - 1) % $_columnCount === 0) { ?> first<?php } elseif($i % $_columnCount === 0) { ?> last<?php } ?>">
        <?php echo $html; ?>
        <a href="<?php echo $productUrl; ?>" title="<?php echo $this->stripTags($this->getImageLabel($_product, 'small_image'), null, true) ?>" class="product-image">
        <?php
          echo "<img class='lazy trans-opacity' id='product-collection-image-{$_product->getId()}'
            data-src='{$this->helper('catalog/image')->init($_product, 'small_image')->resize($_imgSize)}'
            alt='{$this->stripTags($this->getImageLabel($_product, 'small_image'), null, true)}'
            width='{$displaySize}' height='{$displaySize}' />";
        ?>
        </a>
        <div class="product-info">
          <div class="info">
            <h2 class='product-name'>
              <a href='<?php echo $productUrl; ?>' title='<?php echo $this->stripTags($product_name);?> kopen'><?php echo $product_name; ?></a>
            </h2>
            <?php
            if($this->getChild('name.after')) {
              $_nameAfterChildren = $this->getChild('name.after')->getSortedChildren();
              foreach ($_nameAfterChildren as $_nameAfterChildName) {
                $_nameAfterChild = $this->getChild('name.after')->getChild($_nameAfterChildName);
                $_nameAfterChild->setProduct($_product);
                echo $_nameAfterChild->toHtml();
              }
            }
            ?>
          
            <?php
            if(isset($tagline) === true) {
              echo "<div class='product-list-tagline'>{$tagline}</div>";
            }
            
            if(sizeof($product_info) > 0) {
              echo "<ul>";
              foreach($product_info as $key => $item) {
                if($key === $max_product_info_items) break;
                echo "<li class='angle_before'>{$item}</li>";
              }
              echo "</ul>";
            }
            
            if(sizeof($usps) > 0) {
              echo "<ul class='product-list-highlights'>";
              foreach($usps as $usp) {
                echo "<li>{$usp}</li>";
              }
              echo "</ul>";
            }
            ?>
          </div>
          <?php
          echo $price_html;
          if(0 && $_product->getRatingSummary()) {
            echo $this->getReviewsSummaryHtml($_product, 'short');
          }
          ?>
          <div class="actions">
            <?php
            if(!$_product->canConfigure()) {
              if($_product->isSaleable()) {
                // Simple product, sellable
                ?>
                <div class="float-left">
