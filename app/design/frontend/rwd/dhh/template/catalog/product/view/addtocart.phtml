            background: '#f08324',
            fontColor: '#FFFFFF',
            type: 'false',
            height: 600,
            width: 700,
            openOnLoad: false,
            iframeParameters: {
              'product': <?php echo json_encode($_product->getName()); ?>
            },
          });
        </script>
        
        <button type="button" title="<?php echo $buttonTitle_lease ?>" class="button btn lightbox-200152323289044" style="margin-top:1em; background-color:#2a71db !important;">
          <i class="fa fa-shopping-cart" style="font-size: 1.3em; margin-right: 10px;"></i>
          <?php echo $buttonTitle_lease; ?>
        </button>
