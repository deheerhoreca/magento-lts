<?php
/**
 * Category layered navigation
 *
 * @see Mage_Catalog_Block_Layer_View
 */

if($this->canShowBlock()) {
  $classes = "block block-layered-nav";
  // $filters = Mage::getSingleton("catalog/layer")->getState()->getFilters();
  // if(!$filters) {
    // $classes .= " block-layered-nav--no-filters";
  // }
  echo "<div class='{$classes}'>";
    ?>
    <div class="block-content toggle-content">
      <?php
      echo $this->getStateHtml();
      if($this->canShowOptions()) {
        ?>
        <p class="block-subtitle block-subtitle--filter"><?php echo $this->__("Filter") ?></p>
        <dl id="narrow-by-list">
          <?php
          $_filters = $this->getFilters();
          foreach($_filters as $_filter) {
            $sys_name = $_filter->getName();
            Varien_Profiler::start("DHH_AMSHOPBY_FILTER_{$sys_name}");
            if($_filter->getItemsCount()) {
              $name = $this->__($sys_name);
              
              // Special handling of Category filter
              if($name === "Categorie") {                
                // Don't display this filter if there are no subcategories
                $name = "Verder verfijnen"; // DHH
                $items = $_filter->getItems();
                $good_to_go = false;
                foreach($items as $item) {
                  if($item->getLevel() > 1) {
                    $good_to_go = true;
                    break;
                  }
                }
                if($good_to_go === false) {
                  continue;
                }
              }
              echo "<dt>{$name}</dt>".PHP_EOL;
              echo "<dd>{$_filter->getHtml()}</dd>".PHP_EOL;
            }
            Varien_Profiler::stop("DHH_AMSHOPBY_FILTER_{$sys_name}");
          }
          ?>
        </dl>
        <script>decorateDataList("narrow-by-list")</script>
      <?php
      }
      ?>
    </div>
  </div>
<?php
}
