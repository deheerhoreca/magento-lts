<?php

$helper = Mage::helper("eke_ogmeta");
if(!$helper->isOgMetaEnabled()) {
  return;
}

$product    = Mage::registry("current_product");
$html       = "";
$cache_key  = "eke_ogmeta_category_".Mage::getModel("catalog/layer")->getCurrentCategory()->getId()."_";

if(Mage::helper("deheerhoreca_fpc/data")->is_read_cache_enabled(true, true, "eke_ogmeta_category")) {
  $html = Mage::app()->getCache()->load($cache_key);
  if(empty($html)) {
    DeHeerHoreca_Fpc_Helper_Data::log("MISS {$cache_key}");
  }
}

if(empty($html) === false) {
  DeHeerHoreca_Fpc_Helper_Data::log("HIT {$cache_key}");
  echo unserialize($html);
} else {
  
  // DHH CORE HACK: we can do better than this...
  $categoryImage = Mage::getModel("catalog/layer")->getCurrentCategory()->getImage();
  if(strlen((string) $categoryImage) < 1) {
    $image_url = $helper->getOgImage();
    $image_file = null;
  } else {
    $image_url = Mage::getBaseUrl("media")."catalog/category/".$categoryImage;
    $image_file = Mage::getBaseDir("media")."/catalog/category/".$categoryImage;
  }
  $siteName = $helper->getSiteName();
  
  // DHH We must supress errors since the image might not exist
  if($image_file !== null) {
    $imageAttr = getimagesize($image_file);
    try {
      $imageAttr = getimagesize($image_file);
    } catch(Exception) {
      Mage::log("Failed to getimagesize({$image_file})", null, "exception.log", true);
      $imageAttr = [];
    }
  }
  
  $html = "";
  $html .= '<meta property="og:locale" content="nl_NL">'.PHP_EOL;
  $html .= '<meta property="og:locale:alternate" content="nl_BE">'.PHP_EOL;
  $html .= '<meta property="og:title" content="'.$this->getLayout()->getBlock("head")->getTitle().'">'.PHP_EOL;
  $html .= '<meta property="og:site_name" content="'.$siteName.'">'.PHP_EOL;
  $html .= '<meta property="og:type" content="product.group">'.PHP_EOL;
  $html .= '<meta property="og:url" content="'.$this->helper("core/url")->getCurrentUrl().'">'.PHP_EOL;
  $html .= '<meta property="og:description" content="'.$this->getLayout()->getBlock("head")->getDescription().'">'.PHP_EOL;
  $html .= '<meta property="og:image" content="'.$image_url.'">'.PHP_EOL;
  if(empty($imageAttr["mime"]) === false) {
    $html .= '<meta property="og:image:type" content="'.$imageAttr["mime"].'">'.PHP_EOL;
  }
  if(empty($imageAttr[0]) === false) {
    $html .= '<meta property="og:image:width" content="'.$imageAttr[0].'">'.PHP_EOL;
  }
  if(empty($imageAttr[1]) === false) {
    $html .= '<meta property="og:image:height" content="'.$imageAttr[1].'">'.PHP_EOL;
  }
  $html .= '<meta property="og:image:alt" content="'.$this->getLayout()->getBlock("head")->getTitle().'">'.PHP_EOL;
  $html .= '<meta name="twitter:card" content="summary">'.PHP_EOL;
  // ------------ STOP REGULAR FLOW
  
  echo $html;
  
  // Store in Magento cache
  if(DeHeerHoreca_Fpc_Helper_Data::is_write_cache_enabled(true, true, "eke_ogmeta")) {
    if(Mage::app()->getCache()->save(serialize($html), $cache_key, ["DHH_EKE_OGMETA"], 86400 * 7)) {
      DeHeerHoreca_Fpc_Helper_Data::log("SAVED {$cache_key} chars");
    }
  }
}
