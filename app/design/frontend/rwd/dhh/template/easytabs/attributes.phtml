<?php
/**
 * Product additional attributes template
 *
 * @see Mage_Catalog_Block_Product_View_Attributes
 */

Varien_Profiler::start("DHH_PRODUCT_DETAILVIEW_PREPARE_ATTRIBUTES");

// Taken from https://community.magento.com/t5/Magento-1-x-Programming/How-to-display-Attribute-Group-Name-on-Product-page/td-p/12156
$_helper    = $this->helper("catalog/output");
$_product   = $this->getProduct();
$supplier   = strtolower((string) $_product->getAttributeText("supplier"));

// Tooltips
$attr_tooltips = [
  "shipping_weight_gram"  => "Dit is het gewicht van het product zoals het wordt verstuurd, in een pakket of op een pallet",
  "koeltemperatuur"       => "De behaalde temperatuur kan variëren. Factoren die van invloed zijn, zijn onder andere: koelmethode, omgevingstemperatuur, open-frequentie, ventilatie rondom het apparaat, de klimaatklasse, en de koelcyclus",
  "aantal_blikjes"        => "Het exacte aantal kan iets variëren met de exacte grootte",
  "deur_omkeerbaar"       => "Indien de draairichting van de deur wordt omgedraaid is het slot niet altijd meer bruikbaar en zijn eventuele afbeeldingen op de deur omgekeerd.",
  "temp_range_from_c"     => "De behaalde temperatuur kan iets variëren, afhankelijk van omgevingsfactoren.",
  "geluidsniveau"         => "Professionele koelingen zijn doorgaans uitgerust met ventilatoren en krachtige koelmotoren en produceren meestal meer geluid dan een consumentenkoeling. Nog steeds zijn sommige koelingen veel stiller dan andere. Twijfelt u over de juiste koeling, neem dan contact met ons op.",
  "climate_class"         => "De klimaatklasse geeft aan in welke omgevingstemperatuur deze koeling zich fijn voelt. Zet de koeling niet in een te koude of te warme omgeving. Een krachtige, geforceerde koeling kan een hogere omgevingstemperatuur aan. Er zijn ook speciale koelingen voor koude omgevingen.",
];
$attr_tooltips["vriestemperatuur"]      = $attr_tooltips["koeltemperatuur"];
$attr_tooltips["aantal_flessen"]        = $attr_tooltips["aantal_blikjes"];
$attr_tooltips["capacity_wine_bottles"] = $attr_tooltips["aantal_blikjes"];
$attr_tooltips["temp_range_to_c"]       = $attr_tooltips["temp_range_from_c"];

if($supplier === "maxima") {
  $attr_tooltips["garantie"] = "2 jaar garantie op alle Maxima producten gekocht vanaf 1 oktober 2025";
}

// No decimals, with number formatting
$attr_remove_decimals = [
  "hoogte_intern", "breedte_intern", "diepte_intern", "diameter", "breedte", "hoogte", "diepte", "magnetron_output_watt", 
  "grill_output_watt", "aantal_m3_uur", "aantal_deuren", "aantal_roosters", "aantal_kippen", "aantal_kuipen",
  "aantal_platen", "aantal_borden", "aantal_bakken", "aantal_zetsystemen", "aantal_manden", "aantal_pizzas",
  "aantal_elementen", "aantal_etages", "aantal_filters", "aantal_borden_korven", "aantal_glas_korven", "aantal_snelheden",
  "aantal_blikjes", "aantal_wasprogrammas", "eenheid", "capacity_wine_bottles", "geluidsniveau",
  "number_of_cooling_zones", "aantal_flessen", "cooking_zones", "length_mm", "isolatiedikte", "number_of_slots",
  "max_geleiders", "package_height_mm", "package_width_mm", "package_depth_mm", "shipping_weight_gram",
  "temp_range_from_c", "temp_range_to_c", "thickness_mm", "hoogte_borden_max", "hoogte_glazen_max", "max_baskets_per_hour",
  "tank_temperature_c", "breedte_deur", "capacity_people",
];

// No zero decimals, with number formatting
$attr_trim_decimals   = ["inhoud_liters", "inhoud_m3", "voorraadbunker_kg",
  "inhoud_wastank_liter", "vermogen_boiler", "weight", "volume_freezer_liter",
  "volume_refrigerator_liter","volume_net_liter", "ijs_productie", "ijs_bunker",
  "annual_energy_consumption_kwh", "capaciteit_boiler", "laadhoogte", "weight_fabric",
  "gewicht_vlees_max", "water_verbruik", "water_verbruik_cyclus", "temp_resistance_from",
  "temp_resistance_to", "guide_set_distance_mm", "inhoud_vetpan_liter", "max_load_per_shelf_kg",
  "max_load_total_kg", "gross_weight_gram", "amps", "etaleer_oppervlak_m2", "blade_length_mm",
];

// Allow to show "No" values for these attributes
$attr_show_no         = ["microwave_safe", "oven_safe", "dishwasher_safe", "assembly_required"];

$attr_show_zero       = ["temp_range_from_c", "temp_range_to_c"];
$attr_hide_zero       = array_diff(array_merge($attr_trim_decimals, $attr_remove_decimals), $attr_show_zero);

// Do not show these values
$value_skip           = ["N.v.t.", "n.v.t.", "Geen / n.v.t."];

// Do not retrieve these attribute_codes
$skipped_attributes   = [];

// Do not show these attribute_codes
$hidden_attributes    = ["external_documents_json"];

// Track to-be-deleted attributes
$delete_these         = [];

// Main attribute output array
$attributes           = [];

Varien_Profiler::stop("DHH_PRODUCT_DETAILVIEW_PREPARE_ATTRIBUTES");

Varien_Profiler::start("DHH_PRODUCT_DETAILVIEW_PREPROCESS_ATTRIBUTES");

if($_additionalgroup = $this->getAdditionalDataCustom($skipped_attributes)) {
  $attr_remove_decimals = array_flip($attr_remove_decimals);
  $attr_trim_decimals   = array_flip($attr_trim_decimals);
  $attr_hide_zero       = array_flip($attr_hide_zero);
  
  // Optionally delete other attributes if certain ones are filled
  foreach($_additionalgroup as $_additional) {    
    foreach($_additional["items"] as $_data) {
      switch($_data["code"]) {
        case "gn_capacity":                 $delete_these[] = "inhoud_aantal_gn";         break;
// @todo add N.v.t. exception        case "energy_efficiency_class_a_g": $delete_these[] = "energieklasse";            break;
        
        case "temp_range_from_c":
        case "temp_range_to_c":
          $delete_these[] = "koeltemperatuur";
          $delete_these[] = "vriestemperatuur";
          break;
      }
    }
  }
  
  // if(_dhh_debug()) printr($_additionalgroup);
  
  foreach($_additionalgroup as $_additional) {
    
    foreach($_additional["items"] as $_data) {
      $values         = $_data["value"];
      $code           = $_data["code"];
      $output_values  = [];
      $link_url       = "";
      $link_title     = "";
            
      foreach($values as $value) {
        
        if(strlen((string) $code) < 1 || in_array($code, $hidden_attributes, true)) {
          continue;
        }
        
        /* Pre-processing individual attributes */
        switch($code) {
          case "eenheid":
            if(($value > 1) === false) {
              continue 2;
            }
            break;
          
          case "ean":
            $eans = _getAlternativeEans($value);
            $value = implode(", ", $eans);
            break;
          
          case "manufacturer":
          case "brand_series":
            if(empty($_data["option_id"]) === false) {
              $seo_tag    = Mage::helper("deheerhoreca_util/util")->getUrlSlug($value);
              $link_url   = "/shop?{$_data["code"]}={$_data["option_id"]}&title={$seo_tag}";
              $link_title = "Bekijk meer producten van {$value}";
            }
            break;
        }
        
        // @todo Testing if this is really necessary, it's already filled with getStoreLabel()
        $label = $this->htmlEscape($this->__($_data["label"]));
        // $labal   = $_data["label"];
        $prefix  = "";
        $postfix = "";
        
        /* Processing individual attributes */
       
        switch($code) {
          
          // "°C" postfix
          case "temp_range_from_c":
          case "temp_range_to_c":
          case "temp_resistance_from":
          case "temp_resistance_to":
          case "tank_temperature_c":
          case "naspoel_temperatuur":
          case "temperatuur_water_aanvoer":
            if($value >= 0) {
              $prefix = "+";
            }
            $postfix = " °C";
            break;
          
          // "kg" postfix
          case "voorraadbunker_kg":
          case "ijs_productie":
          case "ijs_bunker":
          case "max_load_per_shelf_kg":
          case "max_load_total_kg":
            $postfix = " kg";
            break;
          
          // "liter" postfix
          case "capaciteit_boiler":
          case "inhoud_liters":
          case "inhoud_vetpan_liter":
          case "inhoud_wastank_liter":
          case "volume_freezer_liter":
          case "volume_net_liter":
          case "volume_refrigerator_liter":
            $postfix = " liter";
            break;

          // "m2" postfix
          case "etaleer_oppervlak_m2":
            $value = number_format($value, 2, ",", ".");
            $postfix = " m²";
            break;
                    
          // "m3" postfix
          case "inhoud_m3":
            $postfix = " m³";
            break;
          
          // {mm cm m} postfix depending on number for units in mm
          case "hoogte":
          case "breedte":
          case "diepte":
          case "diameter":
          case "hoogte_intern":
          case "breedte_intern":
          case "diepte_intern":
          case "thickness_mm":
          case "insulation_thickness_mm":
          case "isolatiedikte":
          case "breedte_deur":
          case "length_mm":
          case "package_height_mm":
          case "package_width_mm":
          case "package_depth_mm":
          case "hoogte_borden_max":
          case "hoogte_glazen_max":
          case "blade_length_mm":
            $postfix = " mm";
            if($value < 100) {
              $postfix = " mm";
            } elseif($value < 5000) {
              $value /= 10;
              $postfix = " cm";
            } else {
              $value /= 1000;        // Foils and such...
              $postfix = " meter";
            }
            break;
          
          // " cm" postfix depending on number for units in cm
          case "laadhoogte":
            $postfix = " cm";
            break;
          
          // " personen" postfix
          case "capacity_people":
            $postfix = " personen";
            break;
          
          // " Liter per Uur" postfix
          case "water_verbruik":
            $postfix = " Liter per Uur";
            break;
          
          // " Liter per Cyclus" postfix
          case "water_verbruik_cyclus":
            $postfix = " Liter per Cyclus";
            break;
          
          // " A" postfix
          case "amps":
            $postfix = " A";
            break;
          
          // " kWh/jaar" postfix
          case "annual_energy_consumption_kwh":
            $postfix = " kWh per jaar";
            break;
          
          // {Watt kW} postfix for units in kW
          case "vermogen_kw":
          case "vermogen":
          case "vermogen_boiler":
            if($value < 5) {
              $value *= 1000;
              $postfix = " Watt";
            } else {
              $value = number_format($value, 2, ",", ".");
              $postfix = " kW";
            }
            break;
          
          // {Watt kW} postfix for units in Watt
          case "total_power_watt":
            if($value  >= 5000) {
              $value   /= 1000;
              $value    = number_format($value, 2, ",", ".");
              $postfix  = " kW";
            } else {
              $value = (int) number_format($value, 0, ",", "");
              $postfix = " Watt";
            }
            break;
          
          // {gr kg} postfix for units in gram
          case "gross_weight_gram":
          case "shipping_weight_gram":
            if($value < 3000) {
              $postfix = " gr";
            } else {
              $value  /= 1000;
              $postfix = " kg";
            }
            break;
          
          // {gr kg} postfix for units in kg
          case "weight":
            if($value < 1) {
              $value *= 1000;
              $postfix = " gr";
            } else {
              $postfix = " kg";
            }
            break;
          
          // " Korven per uur" postfix
          case "number_of_baskets_per_hour":
          case "max_baskets_per_hour":
            $postfix = " Korven per uur";
            break;
          
          // Conditional warranty supplement
          case "warranty_remarks":
            if($supplier === "combisteel") {
              $link_url   = "/garantievoorwaarden-combisteel";
              $link_title = "Aanvullende garantievoorwaarden Combisteel";
            }
            break;
          
          default:
            $value = $_helper->productAttribute($_product, $value, $code);
        }
      
        /* Post-process individual attributes */
        if(isset($attr_hide_zero[$code]) && $value == 0) {
          continue;
        }
        if(isset($attr_remove_decimals[$code])) {
          $value = (int) number_format($value, 0, ",", "");
        }
        if(isset($attr_trim_decimals[$code])) {
          $value = Mage::helper("deheerhoreca_util/util")->trim_decimals($value);
        }
        switch($code) {
          case "number_of_cooling_zones":
            if($value === 1) $value .= " (Single-Zone)";
            elseif($value === 2) $value .= " (Dual-Zone)";
            elseif($value === 3) $value .= " (Triple-Zone)";
            break;
        }
        
        /* Post-process all attributes */
        if($value === "Nee" && in_array($code, $attr_show_no, true) === false) {
          $value = "-";
        }
        
        if(empty($link_url) === false && empty($link_title) === false) {
          $output_values[] = "<a href='{$link_url}' title='{$link_title}' target='_blank'>{$prefix}{$value}{$postfix}</a>";
        } else {
          $output_values[] = "{$prefix}{$value}{$postfix}";
        }
      }
      
      $output_values = array_unique($output_values);
      $_output_value = implode("<i style='font-size:8px;color:#adadad;padding:0 5px;' class='fa fa-minus' aria-hidden='true'></i>", $output_values);
      
      // Post-process final value
      $_output_value = trim(str_ireplace($value_skip, "", $_output_value));
      
      // Add optional tooltip
      $tooltip = $attr_tooltips[$code] ?? "";
      
      if(strlen($_output_value) > 0  && in_array($code, $delete_these, true) === false) {
        $attributes[$this->__($_additional["title"])][$code] = [
          "label"     => $label,
          "value"     => $_output_value,
          "tooltip"   => $tooltip,
        ];
      }
    }
  }
}
Varien_Profiler::stop("DHH_PRODUCT_DETAILVIEW_PREPROCESS_ATTRIBUTES");

Varien_Profiler::start("DHH_PRODUCT_DETAILVIEW_ECHO_ATTRIBUTES");

if($attributes !== []) {
  echo "<div class='box-collateral box-additional bxgroupifo product-specs'>";
  foreach($attributes as $group => $subattributes) {
    echo "<h3 class='clzattrgname'>{$this->__($group)}</h3>";
    foreach($subattributes as $key => $attr) {
      $tooltip = "";
      if(empty($attr["tooltip"]) === false) {
        $tooltip = "<span class='tooltip-wrapper'><span class='tooltip'><i class='tooltip-icon fa fa-info-circle fa-lg has-tooltip' aria-hidden='true'></i><span class='tooltiptext clztoptoolc'>{$attr["tooltip"]}</span></span></span>";
      }
      echo "<dl><dt>{$tooltip}{$attr["label"]}</dt><dd>{$attr["value"]}</dd></dl>".PHP_EOL;
    }
  }
  echo "</div>";
}

Varien_Profiler::stop("DHH_PRODUCT_DETAILVIEW_ECHO_ATTRIBUTES");
