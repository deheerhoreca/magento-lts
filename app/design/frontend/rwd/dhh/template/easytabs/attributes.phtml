<?php
/**
 * Product additional attributes template
 *
 * @see Mage_Catalog_Block_Product_View_Attributes
 */

// Taken from https://community.magento.com/t5/Magento-1-x-Programming/How-to-display-Attribute-Group-Name-on-Product-page/td-p/12156
$_helper = $this->helper('catalog/output');
$_product = $this->getProduct();

/* No decimals, with number formatting */
$attr_remove_decimals = [
  "hoogte_intern", "breedte_intern", "diepte_intern", 
  "diameter", "breedte", "hoogte", "diepte", "magnetron_output_watt", 
  "grill_output_watt", "aantal_m3_uur", "aantal_deuren", "aantal_roosters", 
  "aantal_laden", "aantal_kippen", "aantal_kuipen", "aantal_spoelbak",
  "aantal_platen", "aantal_borden", "aantal_bakken", "aantal_zetsystemen",
  "aantal_kookzones", "aantal_manden", "aantal_pizzas", "aantal_elementen", 
  "aantal_etages", "aantal_filters", "aantal_branders", "aantal_borden_korven", 
  "aantal_glas_korven", "aantal_snelheden", "aantal_blikjes", "aantal_wasprogrammas",
  "eenheid", "capacity_wine_bottles","geluidsniveau","number_of_cooling_zones",
];

/* No zero decimals, with number formatting */
$attr_trim_decimals = ["inhoud_liters", "inhoud_m3", "voorraadbunker_kg",
  "inhoud_wastank_liter", "vermogen_boiler",
];

if($_additionalgroup = $this->getAdditionalDataCustom()) {
  $attr_remove_decimals = array_flip($attr_remove_decimals);
  $attr_trim_decimals   = array_flip($attr_trim_decimals);
  ?>
  <div class="box-collateral box-additional bxgroupifo">
    <?php
      $i=0;
      foreach ($_additionalgroup as $_additional) {
        $i++;
        ?>
        <span class="h3 clzattrgname"><?php echo $this->__( $_additional['title'] )?></span>
        <table class="data-table product-specs-table" id="product-attribute-specs-table-<?php echo $i?>">
          <tbody>
            <?php
            foreach($_additional['items'] as $_data) {
              $valuex = $_data['value'];
              if(empty($valuex)) {
                continue;
              }
              
              /* Pre-process */
              switch($_data['code']) {
                case "eenheid":
                  if(($valuex > 1) === false) {
                    continue 2;
                  }
                  break;
              }
              
              $label = $this->htmlEscape($this->__($_data['label']));
              ?>
              <tr>
                <?php
                $postfix = null;
               
                switch($_data['code']) {
                  case "vermogen_kw":
                  case "vermogen":
                    if($valuex < 5) {
                      $valuex *= 1000;
                      $postfix = " Watt";
                    } else {
                      $valuex = number_format($valuex, 2, ",", ".");
                      $postfix = " kW";
                    }
                    break;

                  default:
                    $valuex = $_helper->productAttribute($_product, $_data['value'], $_data['code']);
                }
                
                if(isset($attr_remove_decimals[$_data['code']])) {
                  $valuex = (int) number_format($valuex, 0, ",", "");
                }
                
                if(isset($attr_trim_decimals[$_data['code']])) {
                  $valuex = number_format($valuex, 2, ",", ".");
                  $valuex = str_replace(",00", null, $valuex);
                }
                
                /* Post-processing individual attributes */
                switch($_data['code']) {
                  case "number_of_cooling_zones":
                    if($valuex === 1) $valuex .= " (Single-Zone)";
                    elseif($valuex === 2) $valuex .= " (Dual-Zone)";
                    elseif($valuex === 3) $valuex .= " (Triple-Zone)";
                    break;
                }
                
                ?>
                <th class="label"><?php echo $label; ?></th>
                <td class="data"><?php echo $valuex.$postfix; ?></td>
              </tr>
            <?php } ?>
          </tbody>
        </table>
        <script type="text/javascript">decorateTable('product-attribute-specs-table-<?php echo $i?>')</script>
    <?php }
  echo "</div>";
}
