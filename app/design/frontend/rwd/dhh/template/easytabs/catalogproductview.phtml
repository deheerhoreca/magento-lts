if(function_exists("sanitizeForFilename") === false) {
  function sanitizeForFilename($string) {
    $output = mb_ereg_replace("([^\w\s\d\-_~,;\[\]\(\).])", '', (string) $string);
    $output = mb_ereg_replace("([\.]{2,})", '', (string) $string);
    return strtolower($output);
  }
}

function _print_configurable_table($_product) {
  $children = Mage::getModel('catalog/product_type_configurable')->getUsedProducts(null, $_product);
  $table = [];

  // Get a list of attributes that are used in this configurable product
  $_attributes = $_product->getTypeInstance(true)->getConfigurableAttributesAsArray($_product);
  $used_conf_attributes = [];
  foreach($_attributes as $_attribute) {
    $used_conf_attributes[$_attribute["label"]] = $_attribute["attribute_code"];
  }

  foreach ($children as $_child) {
    $stock_data = Mage::helper("deheerhoreca_util/util")->getStockInfo($_child);
    $row = ["SKU" => $_child->getSku()];
    foreach($used_conf_attributes as $label => $code) {
      $row[$label] = $_child->getAttributeText($code);
    }
    $row["Voorraad"] = "<div class='{$stock_data['txtcltcz']}'>{$stock_data["stock_message"]}</div>";
    $table[] = $row;
  }

  return html_table($table);
}

function html_table(array $data): string {  
  if(sizeof($data) === 0) return "";

  $rows = $cells = [];

  $cols = array_keys(array_slice($data, 0, 1)[0]);

  foreach($cols as $col) {
    $cells[] = "<th>{$col}</th>";
  }
  $head = "<tr>" . implode('', $cells) . "</tr>";

  foreach ($data as $row) {
    $cells = [];
    foreach ($row as $cell) {
      $cells[] = "<td>{$cell}</td>";
    }
    $rows[] = "<tr>" . implode('', $cells) . "</tr>";
  }
  return "<table class='table table-striped table-border'><thead>{$head}</thead><tbody>" . implode('', $rows) . "</tbody></table>";
}
