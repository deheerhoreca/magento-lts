// Buyblock EOL text
if($overall_stock_status === "eol") {
  Varien_Profiler::start("DHH_PRODUCT_DETAILVIEW_GET_EOL_REPLACEMENT_SKU");
  $eol_replacement_sku = $_product->getEolReplacementSku();
  $eol_text = "Wij helpen u graag met het vinden van een geschikt vervangend product.";
  if(empty($eol_replacement_sku) === false) {
    $_replacement_product = Mage::getResourceModel("catalog/product_collection")
      ->addFieldToFilter("sku", $eol_replacement_sku)
      ->addAttributeToSelect(["name"])
      ->addAttributeToFilter("status", ["in" => Mage_Catalog_Model_Product_Status::STATUS_ENABLED])
      ->addAttributeToFilter("visibility", ["in" => [Mage_Catalog_Model_Product_Visibility::VISIBILITY_BOTH, Mage_Catalog_Model_Product_Visibility::VISIBILITY_IN_CATALOG]])
      ->setPageSize(1)->getFirstItem();
    if(strlen((string) $_replacement_product->getName()) > 1) {
      $name         = _get_product_attribute($_replacement_product, "name");
      $url          = Mage::helper("deheerhoreca_util/util")->getFullProductUrlSafe($_replacement_product);
      $eol_text     = "<strong>Kijkt u naar het vervangend product:</strong><br /><a href='{$url}'>{$name}</a>";
    }
  }
  Varien_Profiler::stop("DHH_PRODUCT_DETAILVIEW_GET_EOL_REPLACEMENT_SKU");
