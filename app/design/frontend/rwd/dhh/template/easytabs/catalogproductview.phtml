        $values[$code] = (int) ($values[$code] / 10);
      } else {
        unset($values[$code]);
      }
    }
    if(sizeof($values) === sizeof($codes)) {
      $text = implode("x", $values)." cm";
      $highlights[] = [
        "image" => $image,
        "title" => $title,
        "text"  => $text,
      ];
      $i++;
    }
  }

  // Try Width + Depth
  if($dimension_pair_set !== true && $i < $max_highlighted_attributes) {
    $codes  = ["breedte", "diepte"];
    $image  = "{$skin}frontend/rwd/dhh/images/measurement.svg";
    $title  = "Afmetingen (BxD)";
    $values = [];
