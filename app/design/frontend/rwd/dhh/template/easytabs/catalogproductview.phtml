                  $current_hour     = $today->format('H');

                  if($current_hour >= 16) {
                    $i++;
                  }
                  
                  while(in_array($calwekdate, $holidays)) {
                    $i++;
                  }
                  $calwekdate = date('d-m-Y', strtotime($calwekdate . ' +' . $i . ' weekday'));
