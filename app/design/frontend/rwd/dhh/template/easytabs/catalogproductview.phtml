  $title  = "Afmetingen (BxDxH)";
  $name   = "Afmetingen";
  $values = [];
  foreach($codes as $code) {
    $values[$code] = _get_product_attribute($_product, $code);
    if(empty($values[$code]) === false) {
      $values[$code] = (int) ($values[$code] / 10);
    } else {
      unset($values[$code]);
    }
  }
  if(sizeof($values) === sizeof($codes)) {
    $text = implode("x", $values)." cm";
    $highlights[] = [
      "image" => $image,
      "title" => $title,
      "text"  => $text,
      "name"  => $name,
    ];
    $i++;
    $dimension_pair_set = true;
  }

  // Try Width + Height
  if($dimension_pair_set !== true && $i < $max_highlighted_attributes) {
    $codes  = ["breedte", "hoogte"];
    $image  = "{$skin}frontend/rwd/dhh/images/measurement.svg";
    $title  = "Afmetingen (BxL)";
    $values = [];
    foreach($codes as $code) {
      $values[$code] = _get_product_attribute($_product, $code);
