    if($this->hasOptions()) {
      $text = "Betaal in <strong>3 termijnen</strong> met In3";
    } else {
      $payment = number_format($_finalPrice / 3, 2, ",", ".");
      $payment = str_replace(",00", ",-", $payment);
      $text = "Betaal in 3 termijnen van €{$payment} met In3";
