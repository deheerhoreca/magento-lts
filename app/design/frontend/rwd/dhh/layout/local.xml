<!-- @see: https://fishpig.co.uk/magento/optimisation/remove-default-magento-javascript/ -->

<layout version="0.1.0">
  <default>
    
    <customer_logged_in>
      <remove name="sale.reorder.sidebar"/>
      <remove name="left.reports.product.viewed"/>
      <remove name="right.reports.product.viewed"/>
    </customer_logged_in>
    
    <reference name="head">

      <!-- Remove items which the RWD package is not dependent upon -->
      <action method="removeItem"><type>skin_js</type><file>js/ie6.js</file></action>
      
      <!-- Remove 3rd party stuff -->
      <action method="removeItem"><type>js</type><file>varien/menu.js</file></action>
      <action method="removeItem"><type>js</type><file>calendar/calendar.js</file></action>
      <action method="removeItem"><type>js</type><file>calendar/calendar-setup.js</file></action>
      <action method="removeItem"><type>js_css</type><file>calendar/calendar-win2k-1.css</file></action>
      <action method="removeItem"><type>skin_js</type><file>js/lightslider.js</file></action>
      <action method="removeItem"><type>skin_css</type><file>css/easytabs.css</file></action>
      <action method="removeItem"><type>skin_css</type><file>css/lightslider.css</file></action>
      <action method="removeItem"><type>skin_css</type><file>aw_blog/css/style.css</file></action>
      <action method="removeItem"><type>skin_css</type><file>magmodules/kiyoh/sidebar.css</file></action>
      
      <action method="removeItem"><type>js</type><file>prototype/prototype.js</file></action>
      <action method="removeItem"><type>js</type><file>lib/jquery/jquery-1.12.4.min.js</file></action>
      <action method="removeItem"><type>js</type><file>lib/ccard.js</file></action>
      <action method="removeItem"><type>js</type><file>scriptaculous/builder.js</file></action>
      <action method="removeItem"><type>js</type><file>scriptaculous/effects.js</file></action>
      <action method="removeItem"><type>js</type><file>scriptaculous/dragdrop.js</file></action>
      <action method="removeItem"><type>js</type><file>scriptaculous/controls.js</file></action>
      <action method="removeItem"><type>js</type><file>scriptaculous/slider.js</file></action>
      <action method="unsetChild"><name>head.viewport</name></action>
      
      <!-- The following are removed from default, then added where needed in specific controllers (see below) -->
      <action method="removeItem"><type>skin_css</type><name>aw_autorelated/css/category.css</name></action>
      <action method="removeItem"><type>skin_css</type><name>aw_autorelated/css/product.css</name></action>
      <action method="removeItem"><type>skin_css</type><name>css/amshopby.css</name></action>
      <action method="removeItem"><type>skin_css</type><name>css/qquoteadv.css</name></action>
      <action method="removeItem"><type>skin_js</type><name>js/qquoteadv.js</name></action>
      
      <!-- @todo find out if we need this removed -->
      <!-- <action method="addItem"><type>skin_css</type><name>css/qquoteadv.css</name></action> -->
      
      <!-- Remove billink assets if not enabled -->
      <action method="removeItem"><type>skin_css</type><name>css/billink.css</name></action>
      <action method="removeItem"><type>js</type><name>billink/billink_base.js</name></action>
      <action method="removeItem"><type>js</type><name>billink/billink_mage_validationfix.js</name></action>
      <action method="removeItem"><type>js</type><name>billink/billink_checkout_page_controller.js</name></action>
      <action method="removeItem"><type>js</type><name>billink/billink_payment_form_controller.js</name></action>
      <action method="removeItem"><type>js</type><name>billink/billink_payment_form_session.js</name></action>
      <action method="addItem" ifconfig="payment/billink/active"><type>skin_css</type><name>css/billink.css</name></action>
      <action method="addJs" ifconfig="payment/billink/active"><type>js</type><name>billink/billink_base.js</name></action>
      <action method="addJs" ifconfig="payment/billink/active"><type>js</type><name>billink/billink_mage_validationfix.js</name></action>
      <action method="addJs" ifconfig="payment/billink/active"><type>js</type><name>billink/billink_checkout_page_controller.js</name></action>
      <action method="addJs" ifconfig="payment/billink/active"><type>js</type><name>billink/billink_payment_form_controller.js</name></action>
      <action method="addJs" ifconfig="payment/billink/active"><type>js</type><name>billink/billink_payment_form_session.js</name></action>
      
      <!-- Enable html cache for certain blocks -->
      <block type="billink/PageHeader" name="billink-page-header" template="shopworks_billink/pageheader.phtml">
        <action method="setData"><key>cache_lifetime</key><value>86400</value></action>
      </block>
      
      <!-- <action method="addJs" ifconfig="mailchimp/ecommerce/active">
        <script>ebizmarts/mailchimp/campaignCatcher.js</script><params>async</params>
      </action> -->
      
      <!-- DHH additions -->
      <action method="addItem"><type>skin_js</type><name>js/dhh.js</name></action>
      
    </reference>
    
    <!-- Enable html cache for certain blocks - Replace blocks -->
    <reference name="before_body_end">
      <action method="unsetChild"><name>richsnippets.organization</name></action>
      <action method="unsetChild"><name>richsnippets.website</name></action>
      <block type="core/template" name="richsnippets.organization" template="tm/richsnippets/richsnippets_organization.phtml">
        <action method="setData"><key>cache_lifetime</key><value>86400</value></action>
      </block>
      <block type="core/template" name="richsnippets.website" template="tm/richsnippets/richsnippets_website.phtml">
        <action method="setData"><key>cache_lifetime</key><value>86400</value></action>
      </block>
    </reference>
    
  </default>
  
  <!-- Categories -->
  <catalog_category_view>
    <reference name="head">
      <action method="addItem"><type>skin_css</type><name>css/catalog_category_view.css</name></action>
      <action method="addCss"><stylesheet>css/amshopby.css</stylesheet></action>
      <action method="removeItem"><type>skin_css</type><name>css/qquoteadv.css</name></action>
      <action method="removeItem"><type>skin_js</type><name>js/qquoteadv.js</name></action>
      <!-- <action method="removeItem"><type>js</type><name>prototype/validation.js</name></action> Still needed! -->
      <remove name="amshopby.navtop" /><!-- Removing for performance -->
      <remove name="amshopby.top" /><!-- Removing for performance -->
    </reference>
  </catalog_category_view>
  <!-- Amasty ShopBy result page, keep in sync with catalog_category_view -->
  <amshopby_index_index>
    <reference name="head">
      <action method="addItem"><type>skin_css</type><name>css/catalog_category_view.css</name></action>
      <action method="addCss"><stylesheet>css/amshopby.css</stylesheet></action>
      <action method="removeItem"><type>skin_css</type><name>css/qquoteadv.css</name></action>
      <action method="removeItem"><type>skin_js</type><name>js/qquoteadv.js</name></action>
      <!-- <action method="removeItem"><type>js</type><name>prototype/validation.js</name></action> Still needed! -->
      <remove name="amshopby.navtop" /><!-- Removing for performance -->
      <remove name="amshopby.top" /><!-- Removing for performance -->
    </reference>
  </amshopby_index_index>
  <!-- Catalog search result, should be close to catalog_category_view -->
  <catalogsearch_result_index>
    <reference name="head">
      <action method="addItem"><type>skin_css</type><name>css/catalog_category_view.css</name></action>
      <action method="addCss"><stylesheet>css/amshopby.css</stylesheet></action>
      <action method="removeItem"><type>skin_css</type><name>css/qquoteadv.css</name></action>
      <action method="removeItem"><type>skin_js</type><name>js/qquoteadv.js</name></action>
      <!-- <action method="removeItem"><type>js</type><name>prototype/validation.js</name></action> Still needed! -->
      <remove name="amshopby.navtop" /><!-- Removing for performance -->
      <remove name="amshopby.top" /><!-- Removing for performance -->
    </reference>
  </catalogsearch_result_index>
  <!-- Catalog search result, should be close to catalog_category_view -->
  <catalogsearch_advanced_result>
    <reference name="head">
      <action method="addItem"><type>skin_css</type><name>css/catalog_category_view.css</name></action>
      <action method="addCss"><stylesheet>css/amshopby.css</stylesheet></action>
      <action method="removeItem"><type>skin_css</type><name>css/qquoteadv.css</name></action>
      <action method="removeItem"><type>skin_js</type><name>js/qquoteadv.js</name></action>
      <!-- <action method="removeItem"><type>js</type><name>prototype/validation.js</name></action> Still needed! -->
      <remove name="amshopby.navtop" /><!-- Removing for performance -->
      <remove name="amshopby.top" /><!-- Removing for performance -->
    </reference>
  </catalogsearch_advanced_result>
  <!-- Catalog ???, should be close to catalog_category_view -->
  <catalog_category_default>
    <reference name="head">
      <action method="addItem"><type>skin_css</type><name>css/catalog_category_view.css</name></action>
      <action method="addCss"><stylesheet>css/amshopby.css</stylesheet></action>
      <action method="removeItem"><type>skin_css</type><name>css/qquoteadv.css</name></action>
      <action method="removeItem"><type>skin_js</type><name>js/qquoteadv.js</name></action>
      <!-- <action method="removeItem"><type>js</type><name>prototype/validation.js</name></action> Still needed! -->
      <remove name="amshopby.navtop" /><!-- Removing for performance -->
      <remove name="amshopby.top" /><!-- Removing for performance -->
    </reference>
    <!-- Disable memorizing toolbar parameters -->
    <reference name="content">
      <reference name="product_list_toolbar">
        <action method="disableParamsMemorizing" />
      </reference>
    </reference>
  </catalog_category_default>
  <!-- Catalog ???, should be close to catalog_category_view -->
  <catalog_category_layered>
    <reference name="head">
      <action method="addItem"><type>skin_css</type><name>css/catalog_category_view.css</name></action>
      <action method="addCss"><stylesheet>css/amshopby.css</stylesheet></action>
      <action method="removeItem"><type>skin_css</type><name>css/qquoteadv.css</name></action>
      <action method="removeItem"><type>skin_js</type><name>js/qquoteadv.js</name></action>
      <!-- <action method="removeItem"><type>js</type><name>prototype/validation.js</name></action> Still needed! -->
      <remove name="amshopby.navtop" /><!-- Removing for performance -->
      <remove name="amshopby.top" /><!-- Removing for performance -->
    </reference>
    <!-- Disable memorizing toolbar parameters -->
    <reference name="content">
      <reference name="product_list_toolbar">
        <action method="disableParamsMemorizing" />
      </reference>
    </reference>
  </catalog_category_layered>
  
  <!-- <catalog_category_default translate="label"> -->
    <!-- <reference name="content"> -->
      <!-- <reference name="product_list_toolbar"> -->
        <!-- <action method="disableParamsMemorizing" /> -->
      <!-- </reference> -->
    <!-- </reference> -->
  <!-- </catalog_category_default> -->
  <!-- <catalog_category_layered translate="label"> -->
    <!-- <reference name="content"> -->
      <!-- <reference name="product_list_toolbar"> -->
        <!-- <action method="disableParamsMemorizing" /> -->
      <!-- </reference> -->
    <!-- </reference> -->
  <!-- </catalog_category_layered> -->
  
  <!-- Product detail view -->
  <catalog_product_view>
    <reference name="head">
      <!-- <action method="removeItem"><type>js</type><name>prototype/validation.js</name></action> Still needed! -->
      <action method="removeItem"><type>js_css</type><name>calendar/calendar-win2k-1.css</name></action>
      <action method="removeItem"><type>js</type><name>calendar/calendar.js</name></action>
      <action method="removeItem"><type>js</type><name>calendar/calendar-setup.js</name></action>
      <!-- <action method="removeItem"><type>js</type><file>varien/product_options.js</file></action> -->
      <action method="removeItem"><type>skin_css</type><name>css/amshopby.css</name></action>
      <action method="removeItem"><type>skin_js</type><name>js/minicart.js</name></action>
      <action method="addItem"><type>skin_js</type><name>js/minicart.js</name><params>defer</params></action>
      <action method="removeItem"><type>skin_css</type><name>css/tm/richsnippets.css</name></action>
      <action method="removeItem"><type>skin_css</type><name>css/qquoteadv.css</name></action>
      <remove name="richsnippets.json" /><!-- Removing from head so it can be called from template at the bottom -->
      <!-- <action method="removeItem"><type>skin_js</type><name>js/qquoteadv.js</name></action> -->
      <action method="removeItem"><type>skin_js</type><name>js/lib/elevatezoom/jquery.elevateZoom-3.0.8.min.js</name></action>
      <action method="addItem"><type>skin_css</type><name>css/catalog_product_view.css</name></action>
    </reference>
  </catalog_product_view>
  
  <!-- Homepage -->
  <cms_index_index>
    <reference name="head">
      <action method="removeItem"><type>js</type><name>prototype/validation.js</name></action><!-- phasing out per action -->
      <action method="removeItem"><type>skin_js</type><name>js/minicart.js</name></action>
      <action method="addItem"><type>skin_js</type><name>js/minicart.js</name><params>defer</params></action>
      <action method="removeItem"><type>skin_css</type><name>css/amshopby.css</name></action>
      <action method="removeItem"><type>skin_css</type><name>css/codnitive/sidenav.css</name></action>
      <action method="removeItem"><type>skin_css</type><name>magmodules/kiyoh/richsnippets.css</name></action>
      <action method="removeItem"><type>skin_css</type><name>css/qquoteadv.css</name></action>
      <action method="removeItem"><type>skin_js</type><name>js/qquoteadv.js</name></action>
      <action method="addItem"><type>skin_css</type><name>css/cms_index_index.css</name></action>
      <action method="addLinkRel"><rel>canonical</rel><href>https://www.chefstore.nl</href></action>
    </reference>
  </cms_index_index>
  
  <!-- Customer Account (1 name for many controllers) -->
  <customer_account>
    <reference name="head">
      <action method="addItem"><type>skin_css</type><name>css/customer_account.css</name></action>
    </reference>
  </customer_account>
  <customer_account_login>
    <reference name="head">
      <action method="addItem"><type>skin_css</type><name>css/customer_account.css</name></action>
    </reference>
  </customer_account_login>
  <customer_account_create>
    <reference name="head">
      <action method="addItem"><type>skin_css</type><name>css/customer_account.css</name></action>
    </reference>
  </customer_account_create>

  <!-- Cart -->
  <checkout_cart_index>
    <reference name="head">
      <action method="addItem"><type>skin_css</type><name>css/checkout_cart_index.css</name></action>
      <action method="removeItem"><type>skin_css</type><name>aw_autorelated/css/shoppingcart.css</name></action>
      <action method="removeItem"><type>js</type><name>prototype/validation.js</name></action><!-- phasing out per action -->
    </reference>
  </checkout_cart_index>
  
  <!-- FireCheckout -->
  <!-- Prevent including both the .js and the .min.js -->
  <!-- See: app/design/frontend/base/default/layout/tm/firecheckout/geissweb_euvatgrouper.xml -->
  <!-- See: app/design/frontend/base/default/layout/euvatgrouper.xml -->
  <firecheckout_index_index>
      <reference name="head">
          <action method="removeItem"><type>js</type><file>geissweb/vatvalidation.js</file></action>
      </reference>
  </firecheckout_index_index>
  
  <!-- FAQ -->
  <faq_index_index>
    <reference name="head">
      <action method="addItem"><type>skin_css</type><name>css/faq_index_index.css</name></action>
    </reference>
  </faq_index_index>
  
  <!-- Blogs -->
  <blog_cat_view>
    <reference name="head"> 
      <action method="addItem"><type>skin_css</type><name>aw_blog/css/style.css</name></action>
    </reference>
  </blog_cat_view>
  <blog_index_index>
    <reference name="head"> 
      <action method="addItem"><type>skin_css</type><name>aw_blog/css/style.css</name></action>
    </reference>
  </blog_index_index>
  <blog_index_list>
    <reference name="head"> 
      <action method="addItem"><type>skin_css</type><name>aw_blog/css/style.css</name></action>
    </reference>
  </blog_index_list>
  <blog_post_view>
    <reference name="head"> 
      <action method="addItem"><type>skin_css</type><name>aw_blog/css/style.css</name></action>
    </reference>
  </blog_post_view>

</layout>
