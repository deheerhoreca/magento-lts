<layout version="0.1.0">
  <default>
    <reference name="head">
      <action method="removeItem"><type>js</type><file>scriptaculous/builder.js</file></action>
      <action method="removeItem"><type>js</type><file>scriptaculous/dragdrop.js</file></action>
      <action method="removeItem"><type>js</type><file>scriptaculous/controls.js</file></action>
      <action method="removeItem"><type>js</type><file>varien/menu.js</file></action>
      <!--<action method="removeItem"><type>js</type><file>mage/translate.js</file></action>-->
      <action method="removeItem"><type>js</type><file>lib/ccard.js</file></action>
      <action method="removeItem"><type>js</type><file>lib/jquery/jquery-1.12.0.min.js</file></action>
      <action method="removeItem"><type>js</type><file>prototype/prototype.js</file></action>
      <action method="removeItem"><type>js</type><file>scriptaculous/effects.js</file></action>
      <action method="removeItem"><type>js</type><file>scriptaculous/slider.js</file></action>
      <action method="removeItem"><type>skin_js</type><file>js/lightslider.js</file></action>
      <action method="removeItem"><type>skin_css</type><file>css/lightslider.css</file></action>
      <action method="removeItem"><type>skin_js</type><file>js/slideshow.js</file></action>
      <action method="removeItem"><type>js_css</type><name>calendar/calendar-win2k-1.css</name></action>
      <action method="removeItem"><type>js</type><name>calendar/calendar.js</name></action>
      <action method="removeItem"><type>js</type><name>calendar/calendar-setup.js</name></action>
      <action method="removeItem"><type>skin_js</type><name>js/lib/jquery.cycle2.min.js</name></action>
      <action method="removeItem"><type>skin_js</type><name>js/lib/jquery.cycle2.swipe.min.js</name></action>
    </reference>
  </default>
  
  <catalog_product_view>
    <reference name="head"> 
      <action method="removeItem"><type>js_css</type><name>calendar/calendar-win2k-1.css</name></action>
      <action method="removeItem"><type>js</type><name>calendar/calendar.js</name></action>
      <action method="removeItem"><type>js</type><name>calendar/calendar-setup.js</name></action>
      <action method="removeItem"><type>skin_css</type><name>css/billink.css</name></action>
      <action method="removeItem"><type>js</type><name>billink/billink_base.js</name></action>
      <action method="removeItem"><type>js</type><name>billink/billink_mage_validationfix.js</name></action>
      <action method="removeItem"><type>js</type><name>billink/billink_checkout_page_controller.js</name></action>
      <action method="removeItem"><type>js</type><name>billink/billink_payment_form_controller.js</name></action>
      <action method="removeItem"><type>js</type><name>billink/billink_payment_form_session.js</name></action>
      <action method="removeItem"><type>js</type><file>varien/product_options.js</file></action>
      
      <action method="removeItem"><type>skin_js</type><name>js/minicart.js</name></action>
      <action method="addItem"><type>skin_js</type><name>js/minicart.js</name><params>defer</params></action>
      
      <action method="addJs" ifconfig="mailchimp/ecommerce/active">
        <script>ebizmarts/mailchimp/campaignCatcher.js</script><params>defer</params>
      </action>
    </reference>
  </catalog_product_view>
  
  <catalog_product_view translate="label">
    <reference name="head">
        <action method="removeItem"><type>skin_js</type><name>js/lib/elevatezoom/jquery.elevateZoom-3.0.8.min.js</name></action>
    </reference>
  </catalog_product_view>
  
  <!-- homepage -->
  <cms_index_index>
    <reference name="head"> 
      <action method="removeItem"><type>skin_css</type><name>css/billink.css</name></action>
      <action method="removeItem"><type>js</type><name>billink/billink_base.js</name></action>
      <action method="removeItem"><type>js</type><name>billink/billink_mage_validationfix.js</name></action>
      <action method="removeItem"><type>js</type><name>billink/billink_checkout_page_controller.js</name></action>
      <action method="removeItem"><type>js</type><name>billink/billink_payment_form_controller.js</name></action>
      <action method="removeItem"><type>js</type><name>billink/billink_payment_form_session.js</name></action>
      <action method="removeItem"><type>skin_css</type><name>mollie/mpm/style.css</name></action>
      
      <action method="removeItem"><type>skin_js</type><name>js/minicart.js</name></action>
      <action method="addItem"><type>skin_js</type><name>js/minicart.js</name><params>defer</params></action>
      
      <action method="addJs" ifconfig="mailchimp/ecommerce/active">
        <script>ebizmarts/mailchimp/campaignCatcher.js</script><params>defer</params>
      </action>
      
      <action method="removeItem"><type>skin_css</type><name>css/amshopby.css</name></action>
      <action method="removeItem"><type>skin_css</type><name>aw_autorelated/css/category.css</name></action>
      <action method="removeItem"><type>skin_css</type><name>css/codnitive/sidenav.css</name></action>
      <action method="removeItem"><type>skin_css</type><name>css/easytabs.css</name></action>
    </reference>
  </cms_index_index>

</layout>
