<layout version="0.1.0">
    <euvatgrouper_handle>
        <reference name="head">
            <action method="addJs"><script>geissweb/vatvalidation-min.js</script></action>
            <block type="page/html" name="euvat_jsvars" template="euvatgrouper/jsvars.phtml"/>
        </reference>
    </euvatgrouper_handle>
    <customer_account_create>
        <update handle="euvatgrouper_handle"/>
        <reference name="customer_form_register">
            <action method="setShowAddressFields" ifconfig="euvatgrouper/integration/show_address_on_regpage">
                <value>true</value>
            </action>
        </reference>
    </customer_account_create>
    <checkout_multishipping>
        <update handle="euvatgrouper_handle"/>
    </checkout_multishipping>
    <customer_account_edit>
        <update handle="euvatgrouper_handle"/>
    </customer_account_edit>
    <customer_address_form>
        <update handle="euvatgrouper_handle"/>
    </customer_address_form>
    <customer_address_new>
        <update handle="euvatgrouper_handle"/>
    </customer_address_new>
    <opc_index_index><!-- for IWD Checkout -->
        <update handle="euvatgrouper_handle"/>
    </opc_index_index>
    <checkout_onepage_index>
        <update handle="euvatgrouper_handle"/>
    </checkout_onepage_index>
    <checkout_onestep_index><!-- for fmeextensions checkout -->
        <update handle="euvatgrouper_handle"/>
    </checkout_onestep_index>
    <onestepcheckout_index_index><!-- for http://www.onestepcheckout.com/?aid=194 -->
        <update handle="euvatgrouper_handle"/>
    </onestepcheckout_index_index>
    <checkout_cart_index>
        <update handle="euvatgrouper_handle"/>
    </checkout_cart_index>
    <mtonestepcheckout_index_index>
        <update handle="euvatgrouper_handle"/>
    </mtonestepcheckout_index_index>
    <firecheckout_index_index>
        <update handle="euvatgrouper_handle"/>
        <reference name="head">
            <action method="removeItem"><type>js</type><name>geissweb/vatvalidation.js</name></action>
        </reference>
    </firecheckout_index_index>
    <aw_onestepcheckout_index_index>
        <update handle="euvatgrouper_handle"/>
    </aw_onestepcheckout_index_index>
    <onepagecheckout_index_index>
        <update handle="euvatgrouper_handle"/>
    </onepagecheckout_index_index>
    <simplecheckout_index_default><!-- Justselling_Simplecheckout -->
        <update handle="euvatgrouper_handle"/>
    </simplecheckout_index_default>
    <checkout_checkoutnext_index>
        <update handle="euvatgrouper_handle"/>
    </checkout_checkoutnext_index>
    <inquiry_index_index><!-- for CapacityWebSolutions_Inquiry -->
        <update handle="euvatgrouper_handle"/>
    </inquiry_index_index>
    <gomage_checkout_onepage_index><!-- for GoMage Checkout -->
        <update handle="euvatgrouper_handle"/>
    </gomage_checkout_onepage_index>
    <!-- HS_Multistepcheckout Start -->
    <multistepcheckout_index_login>
        <update handle="euvatgrouper_handle"/>
    </multistepcheckout_index_login>
    <multistepcheckout_index_register>
        <update handle="euvatgrouper_handle"/>
    </multistepcheckout_index_register>
    <multistepcheckout_index_guest>
        <update handle="euvatgrouper_handle"/>
    </multistepcheckout_index_guest>
    <multistepcheckout_index_payment>
        <update handle="euvatgrouper_handle"/>
    </multistepcheckout_index_payment>
    <!-- HS_Multistepcheckout End -->
    <lotusbreath_onestepcheckout_index_index>
        <update handle="euvatgrouper_handle"/>
    </lotusbreath_onestepcheckout_index_index>
    <olegnax_osc_index_index>
        <update handle="euvatgrouper_handle"/>
    </olegnax_osc_index_index>
    <onepage_checkout_index>
        <update handle="euvatgrouper_handle"/>
    </onepage_checkout_index>
    <oscheckout_index_index>
        <update handle="euvatgrouper_handle"/>
    </oscheckout_index_index>
    <dragonfroot_onestepcheckout_index_index>
        <update handle="euvatgrouper_handle"/>
    </dragonfroot_onestepcheckout_index_index>
    <typostores_onestepcheckout_index_index>
        <update handle="euvatgrouper_handle"/>
    </typostores_onestepcheckout_index_index>
</layout>
