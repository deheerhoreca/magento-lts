            </strong>
        <?php endif; ?>
        </td>
        <td style="<?php echo $this->getTotal()->getStyle() ?>" class="a-right">
            <?php if ($this->getRenderingArea() == $this->getTotal()->getArea()): ?>
            <strong>
                <?php endif; ?>
                <?php echo $this->helper('checkout')->formatPrice($this->getValue(true)) ?>
                <?php if ($this->getRenderingArea() == $this->getTotal()->getArea()): ?>
            </strong>
        <?php endif; ?>
        </td>
    </tr>
<?php else: ?>
    <?php if ($this->getDisplayMode() === Shopworks_Billink_Block_Fee_Checkout_Total_Fee::DISPLAY_MODE_EXCL): ?>
        <?php $_value = $this->getValue(false); ?>
    <?php else: ?>
        <?php $_value = $this->getValue(true); ?>
    <?php endif; ?>
