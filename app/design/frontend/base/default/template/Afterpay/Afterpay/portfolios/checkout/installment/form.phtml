                <ul>
                    <li><?php echo $this->__('Same amount every month, no surprises') ?></li>
                    <li><?php echo $this->__('You can pay the total balance at anytime you want') ?></li>
                    <li><?php echo $this->__('Fix interest rate of: %s', $installmentPlan->getInterestRate()) ?>%</li>
