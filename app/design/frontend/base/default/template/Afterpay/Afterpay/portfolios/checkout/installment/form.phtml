<?php $this->setBlockData()?>
<?php $_code = $this->getMethodCode(); ?>
<?php $_helper = $this->helper('afterpay');?>
<?php $isEnterprise = (bool) Mage::getConfig()->getModuleConfig("Enterprise_Enterprise")->version;?>

<div id="payment-errors" class="validation-advice" style="display:none;"></div>
<fieldset class="form-list">
    <ul id="payment_form_<?php echo $_code; ?>" style="display:none;">
        <div class="installment-payment-description">
            <?php echo $this->getInstallmentDescription() ?>
            <br/>
        </div>

        <div class="installment-payment-total-wo-interest">
            <?php echo $this->__('Total without interest:') ?>
            <span class="total-value" style="font-weight: bold">
                <?php echo $this->getGrandTotal() ?>
            </span>
        </div>
        <li>
            <select id="<?php echo $_code; ?>_installmentplan" class="afterpay_installmentplan" name="payment[<?php echo $_code; ?>][installmentprofile]">
                <?php foreach($this->getInstallmentOptions() as $option): ?>
                    <option value='<?php echo $option->getInstallmentProfileNumber() ?>'>
                        <?php echo $this->__('%s per month in %s installments',
                            $option->getFormattedInstallmentAmount(),
                            $option->getNumberOfInstallments())
                        ?>
                    </option>
                <?php endforeach ?>
            </select>
        </li>

        <?php foreach ($this->getInstallmentOptions() as $index => $installmentPlan): ?>
