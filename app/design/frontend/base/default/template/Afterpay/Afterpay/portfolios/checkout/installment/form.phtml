            <?php echo $this->getAuthorizationNotice() ?>
        </p>
    </ul>
</fieldset>

<?php //TODO we don't have layouts for this module so doing js and css inline for now ?>
<script type="text/javascript">
    $$(".afterpay_installmentplan").invoke('observe', 'change', function() {
        var selected_installment = 'installment_plan_' + $(this).getValue();
        $$('.installment_plan').invoke('removeClassName', 'installment_active');
        $(selected_installment).addClassName('installment_active');
    });
</script>
<style>
    .installment_plan {
        display:none;
    }
    .installment_plan.installment_active {
        display:block;
    }
    .installment_plan ul {
        list-style-type: disc;
        margin-left: 25px;
    }
</style>