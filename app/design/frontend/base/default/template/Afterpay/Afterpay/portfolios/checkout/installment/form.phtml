                        <input type="text" class="required-entry" id="<?php echo $_code; ?>_bankaccount" name="payment[<?php echo $_code; ?>][bankaccount]" style="">
                    </div>
                </div>
            </li>
        <?php endif; #showBankaccount ?>
        <?php if ($this->showSsn()): ?>
            <li>
                <div class="field">
                    <label for="<?php echo $_code; ?>_ssn" class="required"><em>*</em><?php echo $_helper->__('Social security number'); ?>:</label>
                    <div class="input-box">
                        <input type="text" class="required-entry" id="<?php echo $_code; ?>_ssn" name="payment[<?php echo $_code; ?>][ssn]">
                    </div>
                </div>
            </li>
        <?php endif;# showSsn ?>
            <li>
                <input type="checkbox" class="checkbox required-entry" id="<?php echo $_code; ?>_termsAndConditions" name="payment[<?php echo $_code; ?>][conditions]">
