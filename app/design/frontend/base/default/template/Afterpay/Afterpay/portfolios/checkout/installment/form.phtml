                    <em>*</em>
                    <?php echo $_helper->__(
                        'I have read and accepted the AfterPay %sTerms and Conditions%s.',
                        $this->paymentConditionsUrl,
                        $this->anchorClose
                    );?>
                </label>
            </li>
