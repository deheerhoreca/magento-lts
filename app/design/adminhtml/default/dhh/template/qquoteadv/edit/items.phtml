?>

<?php if(Ophirah_Qquoteadv_Helper_Acl::allowed(Ophirah_Qquoteadv_Helper_Acl::VIEW_PRODUCT_INFORMATION)): ?>
<?php $_quote = $this->getQuote() ?>
<a name="products" style="position: absolute; margin-top: -50px;"></a>
<div class="entry-edit-head">
    <h4 class="icon-head head-edit-form fieldset-legend"><?=Mage::helper('catalog')->__('Product Information') ?></h4>

    <div style="float:right; margin:3px;">
        <?php if(Ophirah_Qquoteadv_Helper_Acl::allowed(Ophirah_Qquoteadv_Helper_Acl::VIEW_BUTTONS)): ?>
            <?php if(Ophirah_Qquoteadv_Helper_Acl::allowed(Ophirah_Qquoteadv_Helper_Acl::VIEW_BUTTONS_ADD_CUSTOM_PRODUCT)): ?>
                <?=$this->getParentBlock()->getChildHtml('customproducts.button')?>
            <?php endif; ?>
            <?php if(Ophirah_Qquoteadv_Helper_Acl::allowed(Ophirah_Qquoteadv_Helper_Acl::VIEW_BUTTONS_EDIT_PRODUCTS)): ?>
                <?php print '&nbsp;&nbsp;' . $this->getEditProductsButton()->_toHtml()?>
            <?php endif; ?>
        <?php endif; ?>
    </div>
</div>
<div class="grid np">
    <div class="hor-scroll">
        <table id="qquoteadv_product_table" cellspacing="0" class="data order-tables">
            <thead>
            <tr class="headings">
                <!-- <td></td> -->
                <?php foreach($this->getColumnHeaderInfo() as $column): ?>
                    <th class="<?=$column->getCssClasses()?>" width="<?=$column->getWidth()?>"><?=$column->getColumnTitle()?></th>
                <?php endforeach; ?>
            </tr>
            </thead>
            <?php $_items = $this->getItemsCollection() ?>
            <?php
            $i=0;
            $productCounter = 0;
            /** @var Ophirah_Qquoteadv_Model_Qqadvproduct $_item */
            foreach ($_items as $_item):
                $span_name = "DHH::Qqadvproduct::{$_item->getId()}";
                Varien_Profiler::start($span_name);
                ?>
                <?php if ($_item->getParentItem()) continue; else $i++;?>
                <tbody class="<?=$i%2?'even':'odd' ?>" id="order_<?=$_item->getId() ?>">
                <tr>
                    <!-- <td>
                        <?php
                        $product = $_item->getProduct();
                        if($_item->hasImage($product)):?>
                            <img src="<?=$_item->getItemPicture($product, 75, false)?>" alt="<?=$_item->getName()?>" width="75" height="75">
                        <?php endif;
                    ?> -->
                    </td>
                    <?php $_item->setCounter($productCounter); $productCounter++?>
                    <?=$this->getAllColumnsHtml($_item) ?>
                </tr>
                </tbody>
                <?php
                Varien_Profiler::stop($span_name);
            endforeach;
            ?>
            <tfoot>
            <tr>
                <!-- <td></td> -->
                <?php foreach($this->getColumnHeaderInfo() as $column): ?>
                    <?php $column->setProductCount($productCounter); ?>
                    <td class="<?=$column->getColumnTotalCssClass()?>">
                        <?=$column->getColumnTotal() ?>
                    </td>
                <?php endforeach; ?>
            </tr>
            </tfoot>
        </table>
    </div>
</div>
<br />
<?php endif; ?>

<script src="<?=Mage::getBaseUrl('js') ?>qquoteadv/jquery-3.3.1.min.js"></script>
<script src="<?=Mage::getBaseUrl('js') ?>qquoteadv/jquery-ui.min.js"></script>
<script src="<?=Mage::getBaseUrl('js') ?>lib/jquery/noconflict.js"></script>
<script type="text/javascript">
    jQuery( function() {
        jQuery( "#qquoteadv_product_table" ).sortable({
            items : 'tbody',
            handle : '.drag',
            update: function (event, ui) {
                var data = jQuery("#qquoteadv_product_table").sortable("toArray");
                var url = "<?=$this->getUrl('*/*/ajaxsort') ?>";
                var formKey = "<?=Mage::getSingleton('core/session')->getFormKey()?>";
                var quoteId = "<?=$_quote->getId();?>";

                jQuery.ajax({
                    data: {form_key:formKey, data:data, quote_id:quoteId},
                    type: 'POST',
                    url: url
                });
            }
        });

        jQuery(document).ajaxStart(function() {
            $('loading-mask').show();
        });

        jQuery(document).ajaxStop(function() {
            $('loading-mask').hide();
        });
    });
</script>
