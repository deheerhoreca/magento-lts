use \Illuminate\Support\Arr;
use \Illuminate\Support\Str;

/**
 * Prepare an order flag for display. Flags are modified to improve readability in order detail view,
 * while their lengths are compressed for storage and order listviews.
 *
 * @param  string  $system_flag   The raw flag value from the database
 *
 * @return array<string, string>  The prepared human-friendly flag value, along with original system value and optional CSS class
 */
function prepareFlag(string $system_flag): array {
  $flag     = $system_flag;
  $cssClass = "";
  
  $flag     = strtoupper(trim($flag));
  
  // Highlight only non-technical flags (adds focus for customer service agents)
  $techFlags = ["SA_PE_SENT", "AO_LOCK", "AO_DONE"];
  if(!in_array($flag, $techFlags, true)) {
    $cssClass = "bold";
  }
  
  // Expand supplier abbreviations
  foreach(OM_SUPPLIER_CODE_NAME_MAP as $code => $name) {
    $flag = Str::replaceStart($code, "{$name}:", $flag);
  }
  
  // Expand/rename other pairs
  // To not draw attention to technical flags, we do not expand them unless very important to customer service agents
  $otherExpansions = [
    // "SA_PE_SENT"    => "Purchase Event Sent",
    // "AO_DONE"       => "Auto Order Processed",
    "AO_LOCK"       => "Auto Order In Progress!",
    "NO_AO"         => "Not Auto Ordered",
    "PARTIAL_AO"    => "Partially Auto Ordered",
    "FULL_AO"       => "Fully Auto Ordered",
  ];
  $flag = Str::replace(array_keys($otherExpansions), $otherExpansions, $flag);
  
  // Expand other abbreviations
  $regex_expansions = [
    // "^(SA)"                 => "Spotler ",
    // "(?:\b|_)(PE)(?:\b|_)"  => " Purchase Event ",
    // "(?:\b|_)(AO)(?:\b|_)"  => " Auto Order ",
  ];
  foreach($regex_expansions as $pattern => $replacement) {
    $flag = preg_replace("/".$pattern."/i", $replacement, $flag);
  }
  
  $flag = str($flag)->replace("_", " ")->squish()->upper()->toString();
  
  return [
    "system"    => $system_flag,
    "human"     => $flag,
    "cssClass"  => $cssClass,
  ];
}

