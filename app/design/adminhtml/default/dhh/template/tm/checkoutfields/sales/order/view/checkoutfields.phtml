          $value = "";
          foreach($flags as $flagInfo) {
            $value .= "<li>
              <span class='".$this->escapeHtml($flagInfo["cssClass"])."' title='".$this->escapeHtml($flagInfo["system"])."'>".$this->escapeHtml($flagInfo["human"])."</span>
            </li>";
          }
          $value = "<ul style='margin: 0; padding-left: 1.2em; list-style-type: disc;'>".$value."</ul>";
        } else {
          $value = $this->escapeHtml($value);
        }
        ?>
        <tr>
          <td class="label"><?= $this->escapeHtml($config['label']) ?></td>
