require __DIR__ . '/vendor/autoload.php';

use Symfony\Component\VarDumper\VarDumper;

// Config
const DOCUMENTS_CACHE_DIR = __DIR__."/media/dhh/documents";
const STORE_ID            = 1;

// Bootstrap
if(!is_dir(DOCUMENTS_CACHE_DIR)) {
  mkdir(DOCUMENTS_CACHE_DIR, 0775, $recursive = true);
}

// Init Mage
require_once __DIR__."/app/Mage.php";
Mage::app();
Mage::init();
Mage::app()->setCurrentStore(STORE_ID);
Mage::log("OpenMage initialized", null, "system.log", true);

// Run
$current_url = Mage::helper('core/url')->getCurrentUrl();
$current_url = filter_var($current_url, FILTER_VALIDATE_URL, FILTER_FLAG_PATH_REQUIRED);

if($current_url === false) {
  // redirect to homepage
  exit;
}

try {
  $parsed_url = parse_url($current_url);
} catch(Exception $e) {
  // redirect to homepage
  exit;
}

if(empty($parsed_url["path"])) {
  // redirect to homepage
  exit;
}

$url_params = explode("/", (string) $parsed_url["path"]);
if(!is_array($url_params)) {
  // redirect to homepage
  exit;
}
$url_params = array_values(array_filter($url_params));

if(sizeof($url_params) !== 4) {
  // redirect to homepage
  exit;
}

$entity_id  = (int) $url_params[1];
$hash       = (string) $url_params[2];
$doc_name   = (string) $url_params[3];

$_resource = Mage::getSingleton('catalog/product')->getResource();
$documents_json = $_resource->getAttributeRawValue($entity_id, 'external_documents_json', Mage::app()->getStore());
try {
  $documents = json_decode($documents_json);
} catch(Exception $e) {
  // redirect to homepage
  exit;
}
dump($documents);

