#
# SEE: https://github.com/h5bp/server-configs-apache/blob/main/dist/.htaccess
# THIS FILE IS INCLUDED AND ONLY READ ***ONCE*** DURING APACHE RESTART
# IF IT'S NAMED .htaccess, OTHERWISE IT'S READ WITH EVERY REQUEST
#
# HOWEVER IT'S STILL WIP BECAUSE OF THE OTHER .htaccess FILES IN THE SUBDIRS
#
# @SEE: https://prod.deheerhoreca.nl:8443/smb/web/web-server-settings/id/TBD
# @SEE: https://dev.deheerhoreca.nl:8443/smb/web/web-server-settings/id/6
#
# PLESK CONFIG SHOULD CONTAIN:
#
# <Directory /var/www/vhosts/chefstore.nl/httpdocs/deheerhoreca-magento>
#   AllowOverride None
#   Include /var/www/vhosts/chefstore.nl/httpdocs/deheerhoreca-magento/_htaccess
# </Directory>
#
# ! Implement .htaccess files found in other dirs, before disabling AllowOverride:
# - /protected/.htaccess
# - /media/downloadable/.htaccess
# - ...
# To find them all, use:  cm && find . -name .htaccess
#
#<Directory "media/downloadable/">
#    Order deny,allow
#    Deny from all
#</Directory>


############################################
## GoDaddy specific options

#   Options -MultiViews

## you might also need to add this line to php.ini
##     cgi.fix_pathinfo = 1
## if it still doesn't work, rename php.ini to php7.ini

############################################
## default index file
    
    DirectoryIndex index.php

############################################
## php8 settings

<IfModule mod_php.c>

############################################
## adjust max execution time

    php_value max_execution_time 18000

############################################
## disable automatic session start
## before autoload was initialized

    php_flag session.auto_start off

############################################
## enable resulting html compression

    #php_flag zlib.output_compression on

###########################################
# disable user agent verification to not break multiple image upload

    php_flag suhosin.session.cryptua off

</IfModule>

<IfModule mod_security.c>
###########################################
# disable POST processing to not break multiple image upload

    SecFilterEngine Off
    SecFilterScanPOST Off
</IfModule>

# <IfModule mod_deflate.c>

############################################
## enable apache served files compression
## http://developer.yahoo.com/performance/rules.html#gzip
    
    # > Do NOT let apache compress things, nginx will do it after.
    
    # Insert filter on all content
    ###SetOutputFilter DEFLATE
    # Insert filter on selected content types only
    # AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript
    # AddOutputFilterByType BROTLI;DEFLATE text/html text/plain text/xml text/php text/css text/js text/javascript text/javascript-x application/x-javascript font/truetype
    # AddOutputFilterByType BROTLI;DEFLATE application/javascript
    # AddOutputFilterByType BROTLI;DEFLATE application/vnd.mozilla.xul+xml
    # DeflateCompressionLevel 9

    # Netscape 4.x has some problems...
    #BrowserMatch ^Mozilla/4 gzip-only-text/html

    # Netscape 4.06-4.08 have some more problems
    #BrowserMatch ^Mozilla/4\.0[678] no-gzip

    # MSIE masquerades as Netscape, but it is fine
    #BrowserMatch \bMSIE !no-gzip !gzip-only-text/html

    # Don't compress images
    #SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png)$ no-gzip dont-vary

    # Make sure proxies don't deliver the wrong content
    #Header append Vary User-Agent env=!dont-vary

# </IfModule>

<IfModule mod_ssl.c>

############################################
## make HTTPS env vars available for CGI mode

    SSLOptions StdEnvVars

</IfModule>

<IfModule mod_rewrite.c>

############################################
## enable rewrites

    Options +FollowSymLinks
    RewriteEngine on

########################################################################################
## START DHH
########################################################################################

    # Allow certain files and stop processing -- ABOVE "Prevent serving "hidden" files"
    # https://webmasters.stackexchange.com/questions/138033/what-is-well-known-traffic-advice-directory
    RewriteRule ^\.well-known/security.txt$ - [L]
    RewriteRule ^\.well-known/assetlinks.json$ - [L]
    RewriteRule ^\.well-known/traffic-advice$ - [T=application/trafficadvice+json,END]

    ## DHH: OpenMage cachebuster -- mirror /.htaccess, ./media/.htaccess !!!
    ## Add additional tag to the cachebusted URL because we don't have regex support in Cloudflare
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-l
    RewriteRule ^(.+)\.(ts\d{10})\.(min\.js|js|min\.css|css|png|jpeg|jpg|gif|webp|avif|eco|min\.svg|svg)$ $1.$3 [L]
    # RewriteRule ^/(media|skin|js)/(.+)\.(ts\d{10})\.(js|css|png|jpeg|jpg|gif|webp|avif|eco|min\.svg|svg)$ /$1/$2.$3 [L]
    
    # Fix malformed URLs: ...foo.html&bar=baz  =>  ...foo.html?bar=baz
    RewriteRule ^(?!.*\?)(.*?)\&(.*)$ /$1?$2 [R=301,NC,L]

    # Redirect catalog URLs -- https://htaccess.madewithlove.com
    # 1. Change the URL key of a category without a "permanent redirect"
    # 2. Products and category work immediately

    # /koelingen/vrieskasten*  =>  /koelingen/horeca-vriezers*
    Redirect 301 /koelingen/vrieskasten.html /koelingen/horeca-vriezers.html
    RewriteRule "^/?koelingen/vrieskasten/(.+)$" "/koelingen/horeca-vriezers/$1" [R=301,L]
    
    # /koelingen/ijsblokjesmachines/crushed-ijs*  =>  /koelingen/ijsblokjesmachines/crushed-ice-machines*
    Redirect 301 /koelingen/ijsblokjesmachines/crushed-ijs.html /koelingen/ijsblokjesmachines/crushed-ice-machines.html
    RewriteRule "^/?koelingen/ijsblokjesmachines/crushed-ijs/(.+)$" "/koelingen/ijsblokjesmachines/crushed-ice-machines/$1" [R=301,L]
    
    # Bots keep going in circles in these categories but there are no product listings there anymore.
    # But do not remove the query string of Google Ads, ?refreshfpc, etc. So only when multipass=true is present (= certainly useless).
    # /apparatuur-1.html?...&multipass=true  =>  /apparatuur-1.html
    RewriteCond %{QUERY_STRING} multipass=true$
    RewriteRule "^/?apparatuur-1\.html$" "/apparatuur-1.html" [R=301,L,QSD]

########################################################################################
## END DHH
########################################################################################

############################################
## you can put here your OpenMage root folder
## path relative to web root
    
    #RewriteBase /magento/

############################################
## Prevent serving "hidden" files like git repository
    
    RewriteCond %{REQUEST_URI} /\.
    RewriteRule ^(.*)$ /?csredir=hta [R=404,L]

############################################
## uncomment next line to enable light API calls processing

#    RewriteRule ^api/([a-z][0-9a-z_]+)/?$ api.php?type=$1 [QSA,L]

############################################
## rewrite API2 calls to api.php (by now it is REST only)

    RewriteRule ^api/rest api.php?type=rest [QSA,L]

############################################
## workaround for HTTP authorization
## in CGI environment

    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

############################################
## TRACE and TRACK HTTP methods disabled to prevent XSS attacks

    RewriteCond %{REQUEST_METHOD} ^TRAC[EK]
    RewriteRule .* - [L,R=405]

<IfModule mod_setenvif.c>

############################################
## Enable Developer Mode based on OS environment variable
    
    SetEnvIfExpr "osenv('MAGE_IS_DEVELOPER_MODE') == '1'" MAGE_IS_DEVELOPER_MODE=1

    <IfModule mod_headers.c>

        ############################################
        # X-Content-Type-Options: nosniff disable content-type sniffing on some browsers.
        # DHH: Also set via Cloudflare Transform Rules, because this .htaccess rule somehow does not work on all extensions
        Header set X-Content-Type-Options: nosniff

        ############################################
        # This header forces to enables the Cross-site scripting (XSS) filter in browsers (if disabled)
        BrowserMatch \bMSIE\s8 ie8
        Header set X-XSS-Protection: "1; mode=block" env=!ie8

    </IfModule>
</IfModule>

############################################
## redirect for mobile user agents
    
    #RewriteCond %{REQUEST_URI} !^/mobiledirectoryhere/.*$
    #RewriteCond %{HTTP_USER_AGENT} "android|blackberry|ipad|iphone|ipod|iemobile|opera mobile|palmos|webos|googlebot-mobile" [NC]
    #RewriteRule ^(.*)$ /mobiledirectoryhere/ [L,R=302]

############################################
## always send 404 on missing files in these folders

    RewriteCond %{REQUEST_URI} !^/(media|media\.nfs|skin|js)/

############################################
## START DHH -- CANNOT MOVE BELOW NEXT OPENMAGE RULE "never rewrite for existing files, directories and links"
    
    # Fuck off competitors -- MOVE TO CLOUDFLARE
    # gastrodeals.nl:
    RewriteCond %{HTTP:CF-CONNECTING-IP} 83.217.93.24
    RewriteRule .* https://www.intertoys.nl [R=302,L]
    # Fraudsters:
    RewriteCond %{HTTP:CF-CONNECTING-IP} 5.159.34.104
    RewriteRule .* https://www.disney.com [R=301,L]
    RewriteCond %{HTTP:CF-CONNECTING-IP} 82.180.146.181
    RewriteCond %{HTTP:CF-CONNECTING-IP} 91.92.255.184
    RewriteRule .* https://www.disney.com [R=301,L]

    # Remove trailing slash from non-filepath urls
    # https://gist.github.com/evgv/e7e84e84c46e027c3fff7396a13b3a43
    #RewriteCond %{REQUEST_METHOD} GET
    #RewriteCond %{REQUEST_FILENAME} !-f
    #RewriteCond %{REQUEST_URI} !^/downloader.*$
    #RewriteCond %{REQUEST_URI} ^(.+)/$
    #RewriteRule ^(.+)$ %1 [L,R=301]
    
    # Moved to cloudflare:
    # https://dash.cloudflare.com/23d255e4c9a2735ba8ba1858dc410533/chefstore.nl/security/waf/custom-rules/55b7afb90c2d442387279164b5a4e934
    # # Block scrapers
    # # https://ma.ttias.be/block-user-agent-in-htaccess-for-apache-webserver/
    # RewriteCond %{HTTP_USER_AGENT} "(serpstatbot|MegaIndex|Google-Apps-Script|infoobot|Vagabondo|Linguee|MauiBot|BorneoBot|Elisabot)"
    # RewriteRule ^ - [F]
    
    # Redirect /document/asdf to document.php
    RewriteRule ^document/.*$ document.php

    # Redirects file.php to view.php
    RewriteRule "^file.php.*$" "/view.php?csredir=hta" [R=301,NC,L,QSA]

    # Do not listen to /index.php? requests, redirect them
    RedirectMatch 301 /index.php/((?!admin).*)$1 /$1
    RewriteCond %{THE_REQUEST} ^.*/index.php
    RewriteRule ^(.*)index.php$ /$1 [R=301,L]

    # OpenMage exposes this stuff, weird
    RewriteRule ^/errors/report.php(.*)$ /?csredir=hta [R=301,NC,L,QSD]
    RewriteRule ^/errors/(.*)$ /?csredir=hta [R=301,NC,QSD]

    # Redirects script kiddies
    RewriteRule (.*)amfeed/main/(.*)$ https://www.bol.com/nl/nl/p/hacken-voor-dummies/9200000107966600/ [R=301,NC,L]

    # Landing URL from flyers
    Redirect /hallochef /promoties.html

############################################
## END DHH

############################################
## never rewrite for existing files, directories and links

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-l

############################################
## rewrite everything else to index.php

    RewriteRule .* index.php [L]

</IfModule>


############################################
## Prevent character encoding issues from server overrides
## If you still have problems, use the second line instead

    AddDefaultCharset Off
    #AddDefaultCharset UTF-8

<IfModule mod_expires.c>

############################################
## Add default Expires header
## http://developer.yahoo.com/performance/rules.html#expires
    # Add correct content-type for fonts, without this, .woff2 files have no content-type
    AddType application/vnd.ms-fontobject .eot
    AddType font/woff2 .woff2
    
    ExpiresActive On
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType text/x-javascript "access plus 1 month"
    ExpiresByType application/x-shockwave-flash "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType text/html "access plus 300 seconds"
    ExpiresDefault "access plus 1 hour"
    
    # Leads to private + public together, which is nonsense
    # Header append Cache-Control "public"
</IfModule>

############################################
## By default allow all access

    Order allow,deny
    Allow from all

###########################################
## Deny access to other project files to prevent disclosure of the installed OpenMage version or other information
## Only robots.txt and manifest.json should be allowed by default

    # BEGIN DHH
    
    # No indexes ever
    Options -Indexes
    
    # Allow a few more files
    <FilesMatch "(robots|security|ads)\.txt">
        Require all granted
    </FilesMatch>
    <Files "_htaccess">
        Require all denied
    </Files>
    <FilesMatch \.(ndjson|jsonl)$>
        Require all denied
    </FilesMatch>
    
    # <FilesMatch (?<!robots)\.txt$> # Original rule:
    <FilesMatch (?<!robots|security|ads)\.txt$>
        Require all denied
    </FilesMatch>
    
    # END DHH
    
    <FilesMatch (?<!manifest)\.json$>
        Require all denied
    </FilesMatch>
    <FilesMatch \.(dist|flag|ip|lock|md|neon|sample|sh|yml|yaml|bak)$>
        Require all denied
    </FilesMatch>

############################################
## If running in cluster environment, uncomment this
## http://developer.yahoo.com/performance/rules.html#etags

    #FileETag none

###########################################
## Deny access to cron.php
    <Files cron.php>

############################################
## uncomment next lines to enable cron access with base HTTP authorization
## http://httpd.apache.org/docs/2.2/howto/auth.html
##
## Warning: .htpasswd file should be placed somewhere not accessible from the web.
## This is so that folks cannot download the password file.
## For example, if your documents are served out of /usr/local/apache/htdocs
## you might want to put the password file(s) in /usr/local/apache/.

        #AuthName "Cron auth"
        #AuthUserFile ../.htpasswd
        #AuthType basic
        #Require valid-user

############################################

        Order allow,deny
        Deny from all

    </Files>

###########################################
## BEGIN DHH

# Insert preconnect/dns fetch headers here, where they are supported the most
# This is on top of the preload headers by mod_pagespeed

# Remember, most important resources only:
# Maximum 4 preconnects (Lighthouse rule)
# If a page needs to make connections to many third-party domains, preconnecting them all can be counterproductive.
# The rel="preconnect" hint is best used for only the most critical connections. For the others, just use
# rel="dns-prefetch" to save time on the first step — the DNS lookup.

# <//skm.chefstore.nl>;rel=dns-prefetch,
# <//cdn.mouseflow.com>;rel=dns-prefetch,
# <//cdn.cookie-script.com>;rel=dns-prefetch,
# <//static.sooqr.com>;rel=dns-prefetch,
# <//api.taggrs.io>;rel=dns-prefetch,
# <//connect.facebook.net>;rel=dns-prefetch,
# <//dynamic.spotlersearch.com>;rel=dns-prefetch,
# <//rum.chefstore.nl:8200>;rel=dns-prefetch,
# <//bat.bing.com>;rel=dns-prefetch,
# <//spotlersearchanalytics.com>;rel=preconnect, <//static.spotlersearch.com>;rel=dns-prefetch,
# <//squeezely.tech>;rel=dns-prefetch, <//t.squeezely.tech>;rel=dns-prefetch
# After chrome dev console AI:
# Additionally, several preconnect hints were found for origins that were not utilized during the page load: ...
# Unused preconnect hints can negatively impact performance.
# <//www.googletagmanager.com>;rel=preconnect,<//td.doubleclick.net>;rel=preconnect,<//googleads.g.doubleclick.net>;rel=preconnect,

<FilesMatch ".+\.(?!(jpg|jpeg|png|gif|ico|svg|webp|css|js|woff|woff2|webmanifest)$)[^\.]+?$">
    Header add Link '<https://images.chefstore.nl>;rel="preconnect"'
    Header add Link '<https://v2.zopim.com>;rel="preconnect"'
    Header add Link '<https://static.zdassets.com>;rel="preconnect"'
    Header add Link '<https://ekr.zdassets.com>;rel="preconnect"'
</FilesMatch>

###########################################
## Limit access to certain files:

<IfModule mod_deflate.c>
    ## Force compression for mangled `Accept-Encoding` request headers
    <IfModule mod_setenvif.c>
        <IfModule mod_headers.c>
            SetEnvIfNoCase ^(Accept-EncodXng|X-cept-Encoding|X{15}|~{15}|-{15})$ ^((gzip|deflate)\s*,?\s*)+|[X~-]{4,13}$ HAVE_Accept-Encoding
            RequestHeader append Accept-Encoding "gzip,deflate" env=HAVE_Accept-Encoding
        </IfModule>
    </IfModule>
    
    ## Map the following filename extensions to the specified
    ## encoding type in order to make Apache serve the file types
    ## with the appropriate `Content-Encoding` response header
    ## (do note that this will NOT make Apache compress them!).
    <IfModule mod_mime.c>
        AddEncoding gzip              svgz
    </IfModule>
</IfModule>

<IfModule mod_rewrite.c>
    ############################################
    # Do not listen to /index.php? requests, redirect them
    # @todo moved upstairs, delete this block
    RedirectMatch 301 /index.php/((?!admin).*)$1 /$1
    RewriteCond %{THE_REQUEST} ^.*/index.php
    RewriteRule ^(.*)index.php$ /$1 [R=301,L]
</IfModule>

# # ImageKit -- remove now that it is on another subdomain?
# <FilesMatch ".+\.(?!(jpg|jpeg|png|gif|ico|svg|webp|css|js|woff|woff2)$)[^\.]+?$">
#     <IfModule mod_headers.c>
#         Header set Accept-CH "DPR, Width, Downlink, Viewport-Width, Save-Data, Sec-CH-UA"
#         Header set Permissions-Policy "ch-dpr=(*), ch-width=(*), ch-viewport-width=(*), ch-save-data=(*)"
        
#         # Imagekit and security. Disable microphone and geolocation for all including iframes:
#         # Header set Permissions-Policy "microphone=(), geolocation=(), ch-dpr=(*), ch-width=(*), ch-viewport-width=(*), ch-save-data=(*)"
#     </IfModule>
# </FilesMatch>

# Modify more headers -- Also note Rules in Cloudflare!
<IfModule mod_headers.c>
    # Generic security best practices:
    Header set X-XSS-Protection "1; mode=block"
	Header set X-Frame-Options "SAMEORIGIN"
    Header set Accept-CH "DPR, Sec-CH-DPR, Sec-CH-Width"
    Header set Permissions-Policy "ch-dpr=(*), ch-width=(*), ch-viewport-width=(*)"
    
    # CORS:
    
    # Do not set this to FALSE. Leave it out if not TRUE
    # Header set Access-Control-Allow-Credentials: true
    
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET,PUT,POST,DELETE"
    Header set Access-Control-Max-Age: 86400
    # Header set Access-Control-Allow-Headers "Content-Type, Authorization"

    # - Static files might be served by nginx!

    # # CSS/JS
    # <FilesMatch "\.(css|js)$">
    #     Header unset Etag
    #     Header set Cache-Control "public, max-age=3600"
    # </FilesMatch>

    # # IMAGES
    # <FilesMatch "\.(jpg|jpeg|png|gif|ico|svg|webp)$">
    #     Header set Cache-Control "public, max-age=3600"
    # </FilesMatch>

    # TEXT, ARCHIVES
    # <FilesMatch "\.(html|htm|php|xml|zip)$">
    #     Header unset Etag
    #     Header set Cache-control "private, max-age=300, no-cache"
    # </FilesMatch>

    <FilesMatch "\.ico$">
        Header set Cache-control max-age=3600
    </FilesMatch>
</IfModule>

# DEVELOPMENT SETTINGS
<If "%{HTTP_HOST} == 'dev.chefstore.nl'">
    SetEnv MAGE_IS_DEVELOPER_MODE "1"
    
    # Moved to Cloudflare:
    # <IfModule mod_headers.c>
    #     Header set Referrer-Policy "no-referrer"
    # </IfModule>
    
    # Pay.nl: 85.158.206.20
#    <RequireAll>
#        Require ip 149.210.249.150 5.132.21.238 87.210.61.235 81.59.51.217 62.194.92.226 87.212.157.180 185.127.111.0/24 85.158.206.20 87.208.26.238
#    </RequireAll>
</If>
# END DEVELOPMENT SETTINGS

# PRODUCTION SETTINGS
<Else>
    <IfModule mod_headers.c>
        Header set Referrer-Policy "strict-origin-when-cross-origin"
    </IfModule>
</Else>
# END PRODUCTION SETTINGS

ServerSignature Off

### END DHH
